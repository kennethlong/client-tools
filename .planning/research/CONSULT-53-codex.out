1668:					// Phase 17 asset-PS + 17-09 SRV remap + the FFP cascade closed
1669:					// that gap. The forcing bug: TERRAIN layer passes are additive
1670:					// One/One (pass0 = layer0*(1-alpha), pass1 = layer1*alpha,
1671:					// blend=ADD reconstructs the lerp) but collapsed to the install
1672:					// default SrcAlpha/InvSrcAlpha; the terrain PS packs BLOOM (not
1673:					// coverage) in o0.a (~0), so every blend layer vanished and the
1674:					// pre-darkened base pass showed through = hard-edged dark
1675:					// terrain patches (Mos Eisley plaza A/B screenShot0366 vs 0367,
1676:					// Capture39 event 903/927 pixel trace). Mirrors D3D9's
1677:					// unconditional RSM(D3DRS_SRCBLEND/DESTBLEND/BLENDOP) per-pass
1678:					// writes (Direct3d9_ShaderImplementationData.cpp:259-261).
1679:					Direct3d11_StateCache::setAlphaBlendFactors(
1680:						translateBlend(engPass->m_alphaBlendSource),
1681:						translateBlend(engPass->m_alphaBlendDestination),
1682:						translateBlendOp(engPass->m_alphaBlendOperation));
1683:
1684:					// Plan 11-09.15 Iter-44B: per-pass ALPHA-TEST. D3D11 has
1685:					// no FFP alpha-test; we push enable + reference (0..1) into
1686:					// PS cbuffer slot 1 and the dynamic-generated PS reads it
1687:					// and conditionally clip()s. Reference resolution mirrors
1688:					// the D3D9 sibling at Direct3d9_StaticShaderData.cpp:740-760:
1689:					// hardcoded TAG_A255/A128/A001/A000 -> 255/128/1/0, otherwise
1690:					// per-StaticShader getAlphaTestReferenceValue(tag) lookup.
1691:					{
1692:						uint8 refUint = 128;  // safe default (50% threshold)
1693:						if (engPass->m_alphaTestEnable)
1694:						{
1695:							Tag const t = engPass->m_alphaTestReferenceValueTag;
1696:							if      (t == TAG_A255) refUint = 255;
1697:							else if (t == TAG_A128) refUint = 128;
1698:							else if (t == TAG_A001) refUint = 1;
1699:							else if (t == TAG_A000) refUint = 0;
1700:							else if (!m_shader || !m_shader->getAlphaTestReferenceValue(t, refUint))
1701:								refUint = 1;  // matches D3D9's fallback
1702:						}
1703:						Direct3d11_StateCache::setAlphaTest(
1704:							engPass->m_alphaTestEnable,
1705:							static_cast<float>(refUint) / 255.0f);
1706:					}
1707:
1708:					// Plan 11-09.15 Iter-44A: per-pass DEPTH state. Mirrors
1709:					// D3D9's RSB/RSM writes for ZENABLE/ZWRITEENABLE/ZFUNC
1710:					// (Direct3d9_ShaderImplementationData.cpp:255-257). Pre-
1711:					// Iter-44A every D3D11 draw used the install() defaults
1712:					// (DepthEnable=TRUE, WriteMask=ALL, Func=LESS_EQUAL),
1713:					// causing the "eyes through back-of-head" symptom: the
1714:					// eye/decal pass on the skeletal character expected
1715:					// either Z-disabled or Always-compare to render last over
1716:					// the back-of-head opaque pass, but got LESS_EQUAL with
