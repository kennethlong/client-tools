168:		{
169:			UIImage * const image = *imageIterator;
170:			if (image)
171:			{
172:				image->SetVisible(false);
173:			}
174:		}
175:		
176:		int const maxReticles = static_cast<int>(m_reticles->size() - 1);
177:		int const clampedIndex = clamp(0, index, maxReticles);
178:		m_reticleCurrent = (*m_reticles)[static_cast<unsigned>(clampedIndex)];
179:
180:		if (m_reticleCurrent)
181:		{
182:			m_reticleCurrent->SetVisible(true);
183:		}
184:	}
185:}
