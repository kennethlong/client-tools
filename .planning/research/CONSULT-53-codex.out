190:void SwgCuiShipReticle::update(float const deltaTimeSecs)
191:{
192:	//-- Center before the update to prevent frame lag.
193:	UIPoint screenCenter;
194:	CuiManager::getIoWin().getScreenCenter(screenCenter);
195:	getPage().SetLocation(screenCenter, true);
196:
197:	CuiMediator::update(deltaTimeSecs);
198:
199:	// In third person, you may want to disable the reticle.
200:	bool shouldShowReticle = !(s_disableReticleInThirdPerson && Game::isViewFreeCamera());
201:	
202:	ShipObject const * const playerShip = Game::getPlayerContainingShip();
203:	if (playerShip)
204:	{
205:		shouldShowReticle = shouldShowReticle && !playerShip->hasCondition(TangibleObject::C_docking);
206:
207:		//-- Engine speed.
208:		float const maxSpeed = playerShip->getEngineSpeedMaximum() * 
(playerShip->getChassisSpeedMaximumModifier() * 
playerShip->getComponentEfficiencyGeneral(ShipChassisSlotType::SCST_engine));
209:		m_arcSpeed->setMax(maxSpeed);
210:		m_arcSpeed->setCurrent(playerShip->getCurrentSpeed());
211:		
212:		PlayerShipController const * const shipController = dynamic_cast<PlayerShipController const 
*>(playerShip->getController());
213:		float const speedTickValue = shipController ? (shipController->getThrottlePosition() * 
maxSpeed) : 0.0f;
214:		m_arcSpeed->setTick(speedTickValue);
215:
216:		//-- Weapon capacitor.
217:		if (!playerShip->isComponentDemolished(ShipChassisSlotType::SCST_capacitor))
218:		{
219:			m_arcWeapon->setMax(playerShip->getCapacitorEnergyMaximum());
220:			m_arcWeapon->setCurrent(playerShip->getCapacitorEnergyCurrent());
221:			m_arcWeapon->setTick(playerShip->getCapacitorEnergyCurrent());
222:		}
223:		else
224:		{
225:			m_arcWeapon->setMax(0);
226:			m_arcWeapon->setCurrent(0);
227:			m_arcWeapon->setTick(0);
228:		}
229:
230:		//-- Booster energy.
231:		
m_arcBooster->getPage().SetVisible(playerShip->isSlotInstalled(ShipChassisSlotType::SCST_booster));
232:		m_arcBooster->setMax(playerShip->getBoosterEnergyMaximum());
233:		m_arcBooster->setCurrent(playerShip->getBoosterEnergyCurrent() * 
playerShip->getComponentEfficiencyGeneral(ShipChassisSlotType::SCST_booster));

