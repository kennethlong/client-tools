import sys, struct
from pathlib import Path
sys.path.insert(0, r'D:\\Code\\swg-blender-plugin')
from swg_pipeline.tre_reader import read_tre_payload, read_search_toc_entries
root=Path(r'D:\\Code\\SWGSource Client v3.0')
blend={0:'Zero',1:'One',2:'SourceColor',3:'InverseSourceColor',4:'SourceAlpha',5:'InverseSourceAlpha'
,6:'DestinationAlpha',7:'InverseDestinationAlpha',8:'DestinationColor',9:'InverseDestinationColor',10
:'SourceAlphaSaturate'}
op={0:'Add',1:'Subtract',2:'ReverseSubtract',3:'Min',4:'Max'}
cmp={0:'Never',1:'Less',2:'Equal',3:'LessOrEqual',4:'Greater',5:'GreaterOrEqual',6:'NotEqual',7:'Alwa
ys'}

def tagstr(b):
    if b==b'\\0\\0\\0\\0': return '0'
    try: return b[::-1].decode('latin1')
    except: return b.hex()

def entries_all():
    seen={}
    for toc in ['sku0_client.toc','sku1_client.toc','sku2_client.toc','sku3_client.toc']:
        for e in read_search_toc_entries(root/toc):
            seen[e.path]=e
    return seen
entries=entries_all()

def payload(name):
    e=entries.get(name)
    if not e: return None
    return read_tre_payload(root/e.tre_file,name)

def walk(data, off=0, end=None, stack=()):
    if end is None: end=len(data)
    while off+8<=end:
        tag=data[off:off+4].decode('latin1'); size=struct.unpack('>I',data[off+4:off+8])[0]
        start=off+8; stop=start+size
        if tag=='FORM':
            ftag=data[start:start+4].decode('latin1')
            yield from walk(data,start+4,stop,stack+(ftag,))
        else:
            yield stack, tag, data[start:stop], off
        off=stop

def read_cstr(b):
    return b.split(b'\\0',1)[0].decode('latin1')

def parse_pass(ver, d):
    p=0
    def u8():
        nonlocal p; x=d[p]; p+=1; return x
    def tag():
        nonlocal p; x=tagstr(d[p:p+4]); p+=4; return x
    r={}
    r['ver']=ver; r['stages']=u8(); r['shade']=u8(); r['fog']=u8(); r['dither']=bool(u8())
    if ver=='0010': r['heat']=bool(u8())
    r['zEnable']=bool(u8()); r['zWrite']=bool(u8()); r['zCompare']=cmp.get(u8())
    r['alphaBlendEnable']=bool(u8()); r['alphaBlendOperation']=op.get(u8()); 
r['alphaBlendSource']=blend.get(u8()); r['alphaBlendDestination']=blend.get(u8())
    r['alphaTestEnable']=bool(u8()); r['alphaTestReferenceValueTag']=tag(); 
r['alphaTestFunction']=cmp.get(u8()); r['writeEnable']=u8()
    r['textureFactorTag']=tag(); r['textureFactorTag2']=tag()
    if ver in ('0009','0010'): r['textureScrollTag']=tag()
    r['stencilEnable']=bool(u8())
    if ver in ('0009','0010'): r['stencilTwoSidedMode']=bool(u8())
    return r

def effect_name_from_sht(data):
    for stack,tag,data2,off in walk(data):
        if tag=='NAME' and stack[-1:] == ('0001',):
            s=read_cstr(data2)
            if s.startswith('effect/'): return s
    return None

def passes_for_asset(name, seen_effects=None):
    if seen_effects is None: seen_effects=set()
    d=payload(name)
    if d is None: return []
    ref=effect_name_from_sht(d)
    results=[]
    if ref and ref not in seen_effects:
        seen_effects.add(ref)
        results += passes_for_asset(ref, seen_effects)
    for stack,tag,ch,off in walk(d):
        if tag=='DATA' and len(stack)>=2 and stack[-2]=='PASS' and stack[-1] in 
('0007','0009','0010'):
            results.append((name, stack[-1], off, parse_pass(stack[-1],ch)))
    return results

for name in ['shader/uicanvas_filtered.sht','shader/uicanvas_radar.sht','shader/ui_shader_add.sht','e
ffect/ui_add.eft','shader/2d_vertexcolora.sht']:
    print('\\n',name)
    for asset,ver,off,r in passes_for_asset(name):
        print(' ',asset,ver,'off',off,{k:r[k] for k in ['alphaBlendEnable','alphaBlendOperation','alp
haBlendSource','alphaBlendDestination','alphaTestEnable','alphaTestReferenceValueTag','alphaTestFunct
ion']})

print('\\nUI alpha-test enabled scan')
for name in sorted(entries):
    low=name.lower()
    if not (low.startswith('shader/ui') or low.startswith('shader/uicanvas') or 
low.startswith('shader/2d_') or low.startswith('effect/ui')): continue
    try:
        ps=passes_for_asset(name)
    except Exception as ex:
        continue
    for asset,ver,off,r in ps:
        if r['alphaTestEnable']:
            ref=r['alphaTestReferenceValueTag']
            discards = ref in ('A128','A255')
            print(name,'passAsset=',asset,'ver',ver,'off',off,'blend',r['alphaBlendEnable'],r['alphaB
lendSource'],r['alphaBlendDestination'],r['alphaBlendOperation'],'alphaTest',ref,r['alphaTestFunction
'],'would_discard_0.229=',discards)
