47:// ======================================================================
48:
49:void StaticShaderTemplate::install(bool preloadStaticVertexShaders)
50:{
51:	DEBUG_FATAL(ms_memoryBlockManager, ("Already installed"));
52:
53:	ms_memoryBlockManager = new MemoryBlockManager("StaticShaderTemplate", true, 
sizeof(StaticShaderTemplate), 0, 0, 0);
54:	ShaderTemplateList::registerShaderTemplateType(TAG_SSHT, create);
55:
56:	if (preloadStaticVertexShaders)
57:		ShaderTemplateList::preloadVertexColorShaderTemplates ();
58:
59:	ExitChain::add(remove, "StaticShaderTemplate::remove()");
60:}
61:
62:// ----------------------------------------------------------------------
63:
64:void StaticShaderTemplate::remove()
65:{
66:	NOT_NULL(ms_memoryBlockManager);
67:
68:	ShaderTemplateList::releaseVertexColorShaderTemplates();
69:
70:	delete ms_memoryBlockManager;
71:	ms_memoryBlockManager = 0;
72:
73:	ShaderTemplateList::deregisterShaderTemplateType(TAG_SSHT);
74:}
75:
76:// ----------------------------------------------------------------------
77:
78:void *StaticShaderTemplate::operator new(size_t size)
79:{
80:	UNREF(size);
81:	NOT_NULL(ms_memoryBlockManager);
82:	DEBUG_FATAL(size != sizeof(StaticShaderTemplate), ("Looks like a decendent class is trying to 
use our new routine"));
83:	DEBUG_FATAL(size != static_cast<size_t> (ms_memoryBlockManager->getElementSize()), ("installed 
with bad size"));
84:
85:	return ms_memoryBlockManager->allocate();
86:}
87:
88:// ----------------------------------------------------------------------
89:
90:void  StaticShaderTemplate::operator delete(void *pointer)
91:{
92:	NOT_NULL(ms_memoryBlockManager);
93:
94:	ms_memoryBlockManager->free(pointer);
95:}
