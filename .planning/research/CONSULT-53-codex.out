893:Unicode::String CuiDataDrivenPageNamespace::formatText(Unicode::String & input)
894:{
895:	std::string inputString = Unicode::wideToNarrow(input);
896:
897:	if(inputString[0] == '@')
898:	{
899:		// String ID
900:		std::string::size_type splitPos = inputString.find(':');
901:
902:		if(splitPos == std::string::npos)
903:			return input;
904:
905:		std::string cat = inputString.substr(1, splitPos - 1);
906:		std::string index = inputString.substr(splitPos + 1);
907:
908:		StringId myStringID(cat, index);
909:
910:		return myStringID.localize();
911:	}
912:	else if (inputString[0] == '\\' && inputString[1] == '#')
913:	{
914:		// Color code.
915:
916:		std::string colorHex = inputString.substr(2, 6);
917:		std::string textString = inputString.substr(8, inputString.size() - 8);
918:		char buffer[256];
919:		memset(buffer, 0, 256);
920:		sprintf(buffer,"<font color=#%s>%s</font>", colorHex.c_str(), textString.c_str());
921:		
922:		return Unicode::narrowToWide(buffer);
923:	}
924:
925:	return input;

