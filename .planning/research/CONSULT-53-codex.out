978:ShaderImplementationPass::~ShaderImplementationPass()
979:{
980:	if (m_stage)
981:	{
982:		Stages::iterator end = m_stage->end();
983:		for (Stages::iterator i = m_stage->begin(); i != end; ++i)
984:			delete (*i);
985:		delete m_stage;
986:	}
987:
988:	if (m_vertexShader)
989:		m_vertexShader->release();
990:
991:	delete m_pixelShader;
992:	delete m_fixedFunctionPipeline;
993:}
