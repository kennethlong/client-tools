The IFF format in this code path is unpadded, which matters for walking odd-sized chunks. I found 
that and am rerunning the decoder with no alignment padding.
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import sys, struct
from pathlib import Path
sys.path.insert(0, r'D:\\Code\\swg-blender-plugin')
from swg_pipeline.tre_reader import read_tre_payload, read_search_toc_entries
root=Path(r'D:\\Code\\SWGSource Client v3.0')

def find_entry(name):
    for toc in ['sku0_client.toc','sku1_client.toc','sku2_client.toc','sku3_client.toc']:
        for e in read_search_toc_entries(root/toc):
            if e.path==name:
                return root/e.tre_file

def tree(data, off=0, end=None, depth=0):
    if end is None: end=len(data)
    while off+8<=end:
        tag=data[off:off+4].decode('latin1'); size=struct.unpack('>I',data[off+4:off+8])[0]; 
start=off+8; stop=start+size
        if tag=='FORM':
            ftag=data[start:start+4].decode('latin1')
            print('  '*depth+f'FORM {ftag} size={size} off={off}')
            tree(data,start+4,stop,depth+1)
        else:
            preview=data[start:min(stop,start+32)]
            print('  '*depth+f'CHNK {tag} size={size} off={off} prev={preview"'!r}'"')
        off=stop

for name in ['shader/uicanvas_filtered.sht','shader/uicanvas_radar.sht','shader/ui_shader_add.sht','e
ffect/ui_add.eft','shader/2d_vertexcolora.sht','shader/reticle.sht']:
    tre=find_entry(name)
    print('\\n==',name,tre)
    data=read_tre_payload(tre,name); tree(data)
