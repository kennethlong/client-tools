161:void SwgCuiShipReticle::enableReticle(int const index)
162:{
163:	m_reticleCurrent = NULL;
164:
165:	if (m_reticles->size())
166:	{
167:		for (ImageVector::iterator imageIterator = m_reticles->begin(); imageIterator != 
