141:		for (TextureDataMap::iterator i = m_textureDataMap->begin(); i != end; ++i)
142:			if (i->second.texture)
143:				i->second.texture->release();
144:	}
145:
146:	delete m_materialMap;
147:	delete m_textureDataMap;
148:	delete m_textureCoordinateSetMap;
149:	delete m_textureFactorMap;
150:	delete m_textureScrollMap;
151:	delete m_alphaTestReferenceValueMap;
152:	delete m_stencilReferenceValueMap;
153:
154:	m_effect->release();
155:	m_effect = 0;
156:}
