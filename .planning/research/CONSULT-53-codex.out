1005:				break;
1006:
1007:			case TAG_0001:
1008:				load_0001(iff);
1009:				break;
1010:
1011:			case TAG_0002:
1012:				load_0002(iff);
1013:				break;
1014:
1015:			case TAG_0003:
1016:				load_0003(iff);
1017:				break;
1018:
1019:			case TAG_0004:
1020:				load_0004(iff);
1021:				break;
1022:
1023:			case TAG_0005:
1024:				load_0005(iff);
1025:				break;
1026:
1027:			case TAG_0006:
1028:				load_0006(iff);
1029:				break;
1030:
1031:			case TAG_0007:
1032:				load_0007(iff);
1033:				break;
1034:
1035:			case TAG_0008:
1036:				load_0008(iff);
1037:				break;
1038:
1039:			case TAG_0009:
1040:				load_0009(iff);
1041:				break;
1042:
1043:			case TAG_0010:
1044:				load_0010(iff);
1045:				break;
1046:
1047:			default:
1048:				{
1049:					char buffer[256];
1050:					iff.formatLocation(buffer, sizeof(buffer));
1051:					DEBUG_FATAL(true, ("Bad pass version %s", buffer));
1052:				}
1053:				break;
1054:		}
1055:
1056:	iff.exitForm(TAG_PASS);
1057:}
