112:	m_textureCoordinateSetMap(NULL),
113:	m_textureFactorMap(NULL),
114:	m_textureScrollMap(NULL),
115:	m_alphaTestReferenceValueMap(NULL),
116:	m_stencilReferenceValueMap(NULL),
117:	m_staticShader(NULL),
118:	m_addedDot3Placeholder(false)
119:{
120:	load(iff);
121:
122:	// hack to add dot3 texture coordinate set for old art
123:	if (m_textureCoordinateSetMap && m_textureCoordinateSetMap->find(TAG_NRML) != 
m_textureCoordinateSetMap->end() && m_textureCoordinateSetMap->find(TAG_DOT3) == 
