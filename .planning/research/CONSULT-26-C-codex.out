4453-			}
4454-			break;
4455-
4456-		case FS_fadingIn:
4457-			{
4458-				//-- Continue fading in until the fade-in time expires.  Then transition
4459-				//   to state FS_notFading.  Currently we fade in over one second.
4460-				m_fadeFraction += elapsedTime;
4461-				if (m_fadeFraction >= 1.0f)
4462-				{
4463-					// Fade-in timer has expired, transition to the "not fading" state.
4464-					setFadeState(FS_notFading, 1.0f);
4465-				}
4466-			}
4467-			break;
4468-
4469-		case FS_fadeOutToRemove:
4470-			{
4471-				//-- Continue fading out until the fade-out time expires.  Then transition
4472-				//   to state FS_removed.  Currently we fade out over one second.
4473-				m_fadeFraction -= elapsedTime;

