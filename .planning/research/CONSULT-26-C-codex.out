3950-		Object *const owner = nonConstAppearance->getOwner();
3951-
3952-		if (owner)
3953-			CharacterLodManager::addCharacter(owner);
3954-
3955:		if (m_plannedLodSetFrameNumber + 2 < Os::getNumberOfUpdates())
3956-		{
3957-			//-- This appearance doesn't appear to have a planned lod set in the last frame.
