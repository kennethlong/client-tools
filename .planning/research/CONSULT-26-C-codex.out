4447-				//   the fade in timer, transitioning to state FS_fadingIn.
4448:				if ((m_displayLodIndex >= 0) && isDetailLevelAvailable(m_displayLodIndex))
4449-				{
4450-					// Transition to the fade-in state, start timer.
