78:
79:void Direct3d11_DynamicVertexBufferData::install()
80:{
81:	DEBUG_FATAL(ms_memoryBlockManager, ("Direct3d11_DynamicVertexBufferData already installed"));
82:	ms_memoryBlockManager = new MemoryBlockManager(
83:		"Direct3d11_DynamicVertexBufferData", true,
84:		sizeof(Direct3d11_DynamicVertexBufferData), 0, 0, 0);
85:
86:	// Always-shader path (no FFP branch per Plan 11-01 D-04a DESCOPE).
87:	// Query DXGI for DedicatedVideoMemory and pick a ring size.
88:	ID3D11Device * const device = Direct3d11_Device::getDevice();
89:	NOT_NULL(device);
90:
91:	int videoMemoryMB = 256;  // defensive default if DXGI query fails
92:
93:	ComPtr<IDXGIDevice>  dxgiDevice;
94:	ComPtr<IDXGIAdapter> adapter;
95:	HRESULT hr = device->QueryInterface(IID_PPV_ARGS(&dxgiDevice));
96:	if (SUCCEEDED(hr) && dxgiDevice)
97:	{
98:		hr = dxgiDevice->GetAdapter(&adapter);
99:		if (SUCCEEDED(hr) && adapter)
100:		{
101:			DXGI_ADAPTER_DESC adapterDesc = {};
102:			if (SUCCEEDED(adapter->GetDesc(&adapterDesc)))
103:				videoMemoryMB = static_cast<int>(adapterDesc.DedicatedVideoMemory / (1024 * 1024));
104:		}
105:	}
106:
107:	if      (videoMemoryMB <=  16) ms_size =  256 * 1024;
108:	else if (videoMemoryMB <=  32) ms_size =  512 * 1024;
109:	else if (videoMemoryMB <=  64) ms_size = 1024 * 1024;
110:	else                           ms_size = 2048 * 1024;
111:
112:	D3D11_BUFFER_DESC bd = {};
113:	bd.ByteWidth      = static_cast<UINT>(ms_size);
114:	bd.Usage          = D3D11_USAGE_DYNAMIC;
115:	bd.BindFlags      = D3D11_BIND_VERTEX_BUFFER;
116:	bd.CPUAccessFlags = D3D11_CPU_ACCESS_WRITE;
117:	bd.MiscFlags      = 0;
118:
119:	hr = device->CreateBuffer(&bd, nullptr, &ms_d3dRingBuffer);
120:	FATAL_DX_HR("Direct3d11_DynamicVertexBufferData::CreateBuffer (dynamic VB ring) failed: %s", hr);
121:
122:	ms_used     = 0;
123:	ms_newFrame = true;
124:	ms_locksSinceResourceCreation    = 0;
125:	ms_discardsSinceResourceCreation = 0;
126:
127:	DEBUG_REPORT_LOG_PRINT(true,
128:		("Direct3d11_DynamicVertexBufferData: ring buffer %d KB (videoMemory ~%d MB)\n",
129:		 ms_size / 1024, videoMemoryMB));
130:}
