 // ----------------------------------------------------------------------
+// Once per frame, from Gl_api::update (Direct3d11.cpp update_impl), BEFORE
+// the first beginScene. Flip to the next buffer and wait until the GPU has
+// finished the frame that last used it -- this is the explicit fence the
+// shared-ring design lacked.
 
 void Direct3d11_DynamicVertexBufferData::beginFrame()
 {
-	// Wrap at the start of each frame so per-frame dynamic uploads don't
-	// stomp on previous-frame data still in-flight.
+	int const next = (ms_currentBuffer + 1) % kDynamicFrameBuffers;
+	waitForBuffer(next);
+
+	ms_currentBuffer           = next;
+	ms_used                    = 0;
 	ms_newFrame                = true;
+	ms_bufferUsedThisFrame     = false;
 	ms_locksSinceBeginFrame    = 0;
 	ms_discardsSinceBeginFrame = 0;
 }
 
+// ----------------------------------------------------------------------
+// Once per frame, from Direct3d11_Device::present() AFTER the frame's last
+// draw and before Present. Marks the GPU-completion point for the buffer
+// this frame used.
+
+void Direct3d11_DynamicVertexBufferData::signalFrameFence()
+{
+	if (!ms_bufferUsedThisFrame)
+		return;
+
+	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
+	if (!context)
+		return;
+
+	context->End(ms_fences[ms_currentBuffer].Get());
+	ms_fencePending[ms_currentBuffer] = true;
+}
+
+// ----------------------------------------------------------------------
+
+void Direct3d11_DynamicVertexBufferData::waitForBuffer(int index)
+{
+	if (!ms_fencePending[index])
+		return;
+
+	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
+	if (!context)
+	{
+		ms_fencePending[index] = false;
+		return;
+	}
+
+	for (;;)
+	{
+		BOOL done = FALSE;
+		HRESULT const hr = context->GetData(ms_fences[index].Get(), &done, sizeof(done), 0);
+		if (hr == S_OK)
+			break;
+		FATAL(FAILED(hr), ("Direct3d11_DynamicVertexBufferData: fence GetData failed 0x%08X", static_cast<unsigned>(hr)));
+		// hr == S_FALSE: GPU not done yet. Spin (matches the proven query
+		// template in Direct3d11_Device::present()). The wait is normally
+		// empty -- a buffer is reused N frames after its query was signalled.
+	}
+
+	ms_fencePending[index] = false;
+}
+
 // ----------------------------------------------------------------------
 
