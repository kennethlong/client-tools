144:void Direct3d11_DynamicVertexBufferData::beginFrame()
145:{
146:	// Wrap at the start of each frame so per-frame dynamic uploads don't
147:	// stomp on previous-frame data still in-flight.
148:	ms_newFrame                = true;
149:	ms_locksSinceBeginFrame    = 0;
150:	ms_discardsSinceBeginFrame = 0;
151:}
