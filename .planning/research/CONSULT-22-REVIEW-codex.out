93:void *Direct3d9_DynamicVertexBufferData::operator new(size_t size)
94:{
95:	UNREF(size);
96:	NOT_NULL(ms_memoryBlockManager);
97:	DEBUG_FATAL(size != sizeof(Direct3d9_DynamicVertexBufferData), ("wrong new called"));
98:	DEBUG_FATAL(size != static_cast<size_t> (ms_memoryBlockManager->getElementSize()), ("installed with bad size"));
99:
100:	return ms_memoryBlockManager->allocate();
101:}
