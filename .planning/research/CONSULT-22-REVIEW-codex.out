220:void *Direct3d11_DynamicVertexBufferData::lock(int numberOfVertices, bool forceDiscard)
221:{
222:	roundUpUsed();
223:
224:	int const vertexSize = m_vertexBufferDescriptor.vertexSize;
225:	int const length     = numberOfVertices * vertexSize;
226:
227:#if P19_THREAD_AUDIT
228:	if (!Os::isMainThread())
229:	{
230:		static int s_offThreadVBLocks = 0;
231:		++s_offThreadVBLocks;
232:		char tbuf[160];
233:		_snprintf_s(tbuf, sizeof(tbuf), _TRUNCATE,
234:			"[P19THREAD] dynamic VB ring lock OFF MAIN THREAD tid=%lu count=%d numVerts=%d",
235:			GetCurrentThreadId(), s_offThreadVBLocks, numberOfVertices);
236:		ID3D11InfoQueue *iq = Direct3d11_Device::getInfoQueue();
237:		if (iq) iq->AddApplicationMessage(D3D11_MESSAGE_SEVERITY_WARNING, tbuf);
238:	}
239:#endif
240:
241:	++ms_locksSinceBeginFrame;
242:	++ms_locksSinceResourceCreation;
243:	++ms_locksEver;
244:
245:	D3D11_MAP    mapType  = D3D11_MAP_WRITE_NO_OVERWRITE;
246:	int          discard  = 0;
247:#if P19_DISCARD_ONLY
248:	forceDiscard = true;  // diagnostic: rename every lock (kills intra-frame reuse hazard)
249:#endif
250:	if (ms_newFrame || forceDiscard || ms_used + length > ms_size)
251:	{
252:		ms_newFrame = false;
253:		++ms_discardsSinceBeginFrame;
254:		++ms_discardsSinceResourceCreation;
255:		++ms_discardsEver;
256:		discard = 1;
257:
258:		DEBUG_FATAL(length > ms_size, ("Too many vertices %d/%d", numberOfVertices, ms_size / vertexSize));
259:
260:		mapType = D3D11_MAP_WRITE_DISCARD;
261:		ms_used = 0;
262:	}
263:
264:	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
265:	NOT_NULL(context);
266:
267:	D3D11_MAPPED_SUBRESOURCE mapped = {};
268:	HRESULT const hr = context->Map(ms_d3dRingBuffer.Get(), 0, mapType, 0, &mapped);
269:	FATAL(FAILED(hr),
270:		("Could not lock dynamic vb %d=err %d=discard %d=offset %d=length %d/%d/%d=locks %d/%d/%d=discards",
271:		 HRESULT_CODE(hr), discard, ms_used, length,
272:		 ms_locksSinceBeginFrame, ms_locksSinceResourceCreation, ms_locksEver,
273:		 ms_discardsSinceBeginFrame, ms_discardsSinceResourceCreation, ms_discardsEver));
274:	NOT_NULL(mapped.pData);
275:
276:	// Track this lock's slice. The engine writes into the byte range
277:	// [m_offset, m_offset + length); after Unmap the GPU sees the writes.
278:	m_numberOfVertices = numberOfVertices;
279:	m_offset           = ms_used / vertexSize;  // VERTEX index (engine sets BaseVertexLocation per draw)
280:
281:	void * const sliceStart = static_cast<char *>(mapped.pData) + ms_used;
282:	ms_used += length;
283:
284:	// Plan 11-09.15 Iter-4 (Test A): stash for unlock-time snapshot.
285:	s_lastLockedSliceCPUPtr = sliceStart;
286:
287:	return sliceStart;
288:}
