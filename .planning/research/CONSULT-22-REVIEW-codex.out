163:
164:void Direct3d9_DynamicVertexBufferData::roundUpUsed() const
165:{
166:	const int vertexSize = getVertexSize();
167:	ms_used = ((ms_used + vertexSize - 1) / vertexSize) * vertexSize;
168:}
169:
170:// ----------------------------------------------------------------------
171:
172:void *Direct3d9_DynamicVertexBufferData::lock(int numberOfVertices, bool forceDiscard)
173:{
174:	roundUpUsed();
175:
176:	const int vertexSize = getVertexSize();
177:	const int length = numberOfVertices * vertexSize;
178:
179:	++ms_locksSinceBeginFrame;
180:	++ms_locksSinceResourceCreation;
181:	++ms_locksEver;
182:
183:	// check for space
184:	DWORD lockFlag = D3DLOCK_NOOVERWRITE;
185:	int discard = 0;
186:	if (ms_newFrame || forceDiscard || ms_used + length > ms_size)
187:	{
188:		ms_newFrame = false;
189:		++ms_discardsSinceBeginFrame;
190:		++ms_discardsSinceResourceCreation;
191:		++ms_discardsEver;
192:		discard = 1;
193:
194:		// make sure this VB will fit even when the dynamic vb is empty
195:		DEBUG_FATAL(length > ms_size, ("Too many vertices %d/%d", numberOfVertices, ms_size / getVertexSize()));
196:
197:#ifdef _DEBUG
198:		Direct3d9_Metrics::vertexBufferDiscards += 1;
199:#endif
200:
201:		// lock with discard contents
202:		lockFlag = D3DLOCK_DISCARD;
203:		ms_used = 0;
204:	}
205:
206:	void *data = NULL;
207:	HRESULT const hresult = ms_d3dVertexBuffer->Lock(ms_used, length, &data, lockFlag);
208:	FATAL(FAILED(hresult), ("Could not lock dynamic %s %d=err %d=discard %d=offset %d=length %d/%d/%d=locks %d/%d/%d=discards", "vb", HRESULT_CODE(hresult), discard, ms_used, length, ms_locksSinceBeginFrame, ms_locksSinceResourceCreation, ms_locksEver, ms_discardsSinceBeginFrame, ms_discardsSinceResourceCreation, ms_discardsEver));
209:	NOT_NULL(data);
210:
211:	// handle bad NVidia drivers
212:	if (IsBadWritePtr(data, 1) != 0)
213:		data = Direct3d9::getTemporaryBuffer(length);
214:
215:	// use up vertices from this dynamic vb
216:	m_numberOfVertices = numberOfVertices;
217:	m_offset = ms_used / vertexSize;
218:
219:	return data;
220:}
221:
222:// ----------------------------------------------------------------------
223:
224:void Direct3d9_DynamicVertexBufferData::unlock()
225:{
226:	Direct3d9_DynamicVertexBufferData::unlock(m_numberOfVertices);
227:}
228:
229:// ----------------------------------------------------------------------
230:
231:void Direct3d9_DynamicVertexBufferData::unlock(int numberOfVertices)
232:{
233:	const HRESULT hresult = ms_d3dVertexBuffer->Unlock();
234:	FATAL_DX_HR("Could not unlock vb %s", hresult);
235:
236:	m_numberOfVertices = numberOfVertices;
237:	const int vertexSize = getVertexSize();
238:	const int length = numberOfVertices * vertexSize;
239:
240:#ifdef _DEBUG
241:	Direct3d9_Metrics::vertexBufferMemoryDynamic += length;
242:#endif
243:
244:	ms_used += length;
245:}
246:
247:// ------------------------------------------------------------------	----
248:
249:int Direct3d9_DynamicVertexBufferData::getNumberOfLockableDynamicVertices(bool withDiscard)
250:{
251:	roundUpUsed();
252:
253:	// with a discard, they can get all the vertices
254:	// without discard, they can only get access to the remaining ones
255:	return (ms_size - (withDiscard ? 0 : ms_used)) / getVertexSize();
256:}
