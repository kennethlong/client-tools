// ----------------------------------------------------------------------

void Direct3d11_DynamicVertexBufferData::waitForBuffer(int index)
{
	if (!ms_fencePending[index])
		return;

	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
	if (!context)
	{
		ms_fencePending[index] = false;
		return;
	}

	for (;;)
	{
		BOOL done = FALSE;
		HRESULT const hr = context->GetData(ms_fences[index].Get(), &done, sizeof(done), 0);
		if (hr == S_OK)
			break;
		FATAL(FAILED(hr), ("Direct3d11_DynamicVertexBufferData: fence GetData failed 0x%08X", static_cast<unsigned>(hr)));
		// hr == S_FALSE: GPU not done yet. Spin (matches the proven query
		// template in Direct3d11_Device::present()). The wait is normally
		// empty -- a buffer is reused N frames after its query was signalled.
	}

	ms_fencePending[index] = false;
}

// ----------------------------------------------------------------------

ID3D11Buffer *Direct3d11_DynamicVertexBufferData::getSharedRingBuffer()
{
	return ms_buffers[ms_currentBuffer].Get();
}

// ----------------------------------------------------------------------

void *Direct3d11_DynamicVertexBufferData::operator new(size_t size)
{
	UNREF(size);
	NOT_NULL(ms_memoryBlockManager);
	DEBUG_FATAL(size != sizeof(Direct3d11_DynamicVertexBufferData), ("wrong new called"));
	DEBUG_FATAL(size != static_cast<size_t>(ms_memoryBlockManager->getElementSize()), ("installed with bad size"));
	return ms_memoryBlockManager->allocate();
}

// ----------------------------------------------------------------------

void Direct3d11_DynamicVertexBufferData::operator delete(void *memory)
{
	NOT_NULL(ms_memoryBlockManager);
	ms_memoryBlockManager->free(memory);
}

// ======================================================================

Direct3d11_DynamicVertexBufferData::Direct3d11_DynamicVertexBufferData(const VertexBuffer &vertexBuffer)
:
	DynamicVertexBufferGraphicsData(),
	m_vertexBufferDescriptor(Direct3d11_VertexBufferDescriptorMap::getDescriptor(vertexBuffer.getFormat())),
	m_numberOfVertices(0),
	m_offset(0)
{
}

// ----------------------------------------------------------------------

Direct3d11_DynamicVertexBufferData::~Direct3d11_DynamicVertexBufferData()
{
}

// ----------------------------------------------------------------------

const VertexBufferDescriptor &Direct3d11_DynamicVertexBufferData::getDescriptor() const
{
	return m_vertexBufferDescriptor;
}

// ----------------------------------------------------------------------

int Direct3d11_DynamicVertexBufferData::getVertexSize() const
{
	return m_vertexBufferDescriptor.vertexSize;
}

// ----------------------------------------------------------------------

void Direct3d11_DynamicVertexBufferData::roundUpUsed() const
{
	int const vertexSize = m_vertexBufferDescriptor.vertexSize;
	ms_used = ((ms_used + vertexSize - 1) / vertexSize) * vertexSize;
}

// ----------------------------------------------------------------------

void *Direct3d11_DynamicVertexBufferData::lock(int numberOfVertices, bool forceDiscard)
{
	roundUpUsed();

	int const vertexSize = m_vertexBufferDescriptor.vertexSize;
	int const length     = numberOfVertices * vertexSize;

	++ms_locksSinceBeginFrame;
	++ms_locksSinceResourceCreation;
	++ms_locksEver;

	D3D11_MAP mapType = D3D11_MAP_WRITE_NO_OVERWRITE;
	bool const overflow = (ms_used + length > ms_size);

	if (ms_newFrame || forceDiscard || overflow)
	{
		ms_newFrame = false;
		++ms_discardsSinceBeginFrame;
		++ms_discardsSinceResourceCreation;
		++ms_discardsEver;

		DEBUG_FATAL(length > ms_size, ("Too many vertices %d/%d", numberOfVertices, ms_size / vertexSize));

		// A mid-frame discard (overflow) invalidates deferred slices already
		// written into this frame's buffer -- the very hazard this design
		// avoids. It only fires if a frame exceeds one buffer; log loudly so
		// we bump ms_size rather than ship the corruption.
		if (overflow && !ms_newFrame)
			DEBUG_REPORT_LOG_PRINT(true,
				("Direct3d11_DynamicVertexBufferData: MID-FRAME OVERFLOW (used=%d + len=%d > %d) -- bump per-buffer size\n",
				 ms_used, length, ms_size));

		mapType = D3D11_MAP_WRITE_DISCARD;
		ms_used = 0;
	}

	ID3D11Buffer * const buffer = ms_buffers[ms_currentBuffer].Get();

	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
	NOT_NULL(context);

	D3D11_MAPPED_SUBRESOURCE mapped = {};
	HRESULT const hr = context->Map(buffer, 0, mapType, 0, &mapped);
	FATAL(FAILED(hr),
		("Could not lock dynamic vb: err=%d buf=%d used=%d len=%d",
		 HRESULT_CODE(hr), ms_currentBuffer, ms_used, length));
	NOT_NULL(mapped.pData);

	ms_bufferUsedThisFrame = true;

	// D3D9-faithful accounting: record this slice's start; ms_used is
	// advanced by the ACTUAL count in unlock(), NOT by the upper-bound
	// locked length here (so CuiLayerRenderer's lock-all-remaining does not
	// max the cursor).
	m_numberOfVertices = numberOfVertices;
	m_offset           = ms_used / vertexSize;   // VERTEX index; engine binds byteOffset = m_offset*stride

	return static_cast<char *>(mapped.pData) + ms_used;
}

// ----------------------------------------------------------------------

void Direct3d11_DynamicVertexBufferData::unlock()
{
	unlock(m_numberOfVertices);
}

// ----------------------------------------------------------------------

void Direct3d11_DynamicVertexBufferData::unlock(int numberOfVertices)
{
	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
	NOT_NULL(context);

	context->Unmap(ms_buffers[ms_currentBuffer].Get(), 0);

	m_numberOfVertices = numberOfVertices;

	// D3D9-faithful: advance the cursor by the ACTUAL used count
	// (Direct3d9_DynamicVertexBufferData::unlock@244). lock() set m_offset
	// from the pre-advance ms_used, so the slice end is (m_offset + n) verts.
	int const vertexSize = m_vertexBufferDescriptor.vertexSize;
	ms_used = (m_offset + numberOfVertices) * vertexSize;
}

// ----------------------------------------------------------------------

int Direct3d11_DynamicVertexBufferData::getNumberOfLockableDynamicVertices(bool withDiscard)
{
	roundUpUsed();
	return (ms_size - (withDiscard ? 0 : ms_used)) / m_vertexBufferDescriptor.vertexSize;
}

// ----------------------------------------------------------------------

int Direct3d11_DynamicVertexBufferData::getSortKey()
{
	return static_cast<int>(reinterpret_cast<uintptr_t>(ms_buffers[ms_currentBuffer].Get()));
}

