362:int Direct3d11_DynamicVertexBufferData::getNumberOfLockableDynamicVertices(bool withDiscard)
363:{
364:	roundUpUsed();
365:	return (ms_size - (withDiscard ? 0 : ms_used)) / m_vertexBufferDescriptor.vertexSize;
366:}
