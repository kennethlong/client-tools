298:
299:void Direct3d11_DynamicVertexBufferData::unlock(int numberOfVertices)
300:{
301:	// Plan 11-09.15 Iter-4 (Test A): CPU-side VB snapshot for radial-pattern
302:	// investigation. Iter-3's per-fan-draw state diagnostic showed 15/16 fan
303:	// samples at byte offset 0 + same shared-ring VB pointer; the math on
304:	// the fan-list IB path is clean (CODEX Bucket A verified) so the next
305:	// question is whether the engine is writing a real quad into CPU memory
306:	// or degenerate/collapsed data. Read from s_lastLockedSliceCPUPtr BEFORE
307:	// Unmap -- after Unmap the mapped memory may be rotated by the driver
308:	// (D3D11_USAGE_DYNAMIC + WRITE_DISCARD semantics).
309:	//
310:	// Filtered to fan-shaped slices (numberOfVertices==4 && vertexSize==24:
311:	// position(12)+color(4)+UV(8)) to keep log volume low. Sampled like the
312:	// Iter-3 diagnostic: first 5 + every 500th.
313:	{
314:		int const vertexSize = m_vertexBufferDescriptor.vertexSize;
315:		bool const fanShaped = (numberOfVertices == 4) && (vertexSize == 24);
316:		if (fanShaped && s_lastLockedSliceCPUPtr)
317:		{
318:			static int s_diagFanShapedUnlocks = 0;
319:			++s_diagFanShapedUnlocks;
320:			bool const earlyBucket  = (s_diagFanShapedUnlocks <= 5);
321:			bool const sampleBucket = (s_diagFanShapedUnlocks > 5) && ((s_diagFanShapedUnlocks % 500) == 0);
322:			if (earlyBucket || sampleBucket)
323:			{
324:				uint8_t const *vb = static_cast<uint8_t const *>(s_lastLockedSliceCPUPtr);
325:				ID3D11InfoQueue *iq = Direct3d11_Device::getInfoQueue();
326:				for (int v = 0; v < 4; ++v)
327:				{
328:					uint8_t const *src = vb + v * vertexSize;
329:					float const px = *reinterpret_cast<float const *>(src + 0);
330:					float const py = *reinterpret_cast<float const *>(src + 4);
331:					float const pz = *reinterpret_cast<float const *>(src + 8);
332:					uint32_t const c = *reinterpret_cast<uint32_t const *>(src + 12);
333:					float const u  = *reinterpret_cast<float const *>(src + 16);
334:					float const tv = *reinterpret_cast<float const *>(src + 20);
335:					char buf[256];
336:					_snprintf_s(buf, sizeof(buf), _TRUNCATE,
337:						"Plan 11-09.15 Iter-4 fan-shaped unlock#%d vert#%d pos=(%.3f,%.3f,%.3f) color=0x%08X uv=(%.3f,%.3f) offsetVerts=%d",
338:						s_diagFanShapedUnlocks, v, px, py, pz, c, u, tv, m_offset);
339:					if (iq)
340:						iq->AddApplicationMessage(D3D11_MESSAGE_SEVERITY_INFO, buf);
341:				}
342:			}
343:		}
344:		s_lastLockedSliceCPUPtr = nullptr;
345:	}
346:
347:	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
348:	NOT_NULL(context);
349:
350:	context->Unmap(ms_d3dRingBuffer.Get(), 0);
351:
352:	m_numberOfVertices = numberOfVertices;
353:	// Note: ms_used was already advanced in lock(); we don't re-adjust
354:	// here. (D3D9 plugin advances on unlock because Lock takes only an
355:	// upper-bound length and Unlock takes the actual used length; D3D11
356:	// Map gets a slice pointer and the actual-used count only affects
357:	// the draw call, not the buffer accounting.)
358:}
