125:
126:void Direct3d9_DynamicVertexBufferData::restoreDevice()
127:{
128:	ms_newFrame = ConfigDirect3d9::getDiscardDynamicBuffersAtBeginningOfFrame();
129:	IDirect3DDevice9 *device = Direct3d9::getDevice();
130:	HRESULT hresult = device->CreateVertexBuffer(ms_size, D3DUSAGE_DYNAMIC | D3DUSAGE_WRITEONLY, 0, D3DPOOL_DEFAULT, &ms_d3dVertexBuffer, NULL);
131:	FATAL_DX_HR("Could not create dynamic VB %s", hresult);
132:	ms_used = 0;
133:	ms_locksSinceResourceCreation = 0;
134:	ms_discardsSinceResourceCreation = 0;
135:}
