35:
36:void Direct3d9_DynamicVertexBufferData::install()
37:{
38:	DEBUG_FATAL(ms_memoryBlockManager, ("Already installed"));
39:	ms_memoryBlockManager  = new MemoryBlockManager("Direct3d9_DynamicVertexBufferData", true, sizeof(Direct3d9_DynamicVertexBufferData), 0, 0, 0);
40:
41:	bool ffp = !Direct3d9::supportsVertexShaders();
42:	if (ffp)
43:	{
44:		ms_size=256*1024;
45:	}
46:	else
47:	{
48:		int videoMemory = Direct3d9::getVideoMemoryInMegabytes();
49:		if (videoMemory<=16)
50:		{
51:			ms_size=256*1024;
52:		}
53:		else if (videoMemory<=32)
54:		{
55:			ms_size=512*1024;
56:		}
57:		else if (videoMemory<=64)
58:		{
59:			ms_size=1024*1024;
60:		}
61:		else
62:		{
63:			ms_size=2048*1024;
64:		}
65:	}
66:	//ms_size = ConfigDirect3d9::getDynamicVertexBufferSize() * 1024;
67:
68:	ms_used = 0;
69:	restoreDevice();
70:}
