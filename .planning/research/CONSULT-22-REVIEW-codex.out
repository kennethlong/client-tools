113:void Direct3d9_DynamicVertexBufferData::lostDevice()
114:{
115:	if (ms_d3dVertexBuffer)
116:	{
117:		IGNORE_RETURN(ms_d3dVertexBuffer->Release());
118:		ms_d3dVertexBuffer = NULL;
119:		ms_locksSinceResourceCreation = 0;
120:		ms_discardsSinceResourceCreation = 0;
121:	}
122:}
