139:
140:void CuiBackdrop::SceneRenderer::Render( UICanvas & ) const
141:{
142:	Graphics::clearViewport (true, 0, true, 1.0f, true, 0);
143:
144:	if (m_camera)
145:		m_camera->renderScene ();
146:}
147:
148://-----------------------------------------------------------------
149:
150:void CuiBackdrop::SceneRenderer::setRenderData (Camera * camera, ObjectList * objectList)
151:{
152:
153:	if (m_camera)
154:	{
155:		delete m_camera;
156:		m_camera = 0;
157:	}
158:
159:	if (m_objectList)
160:	{
161:		m_objectList->removeAll (true);
162:		delete m_objectList;
163:		m_objectList = 0;
164:	}
165:
166:	m_camera = camera;
167:	MEM_OWN(m_camera);
168:	m_objectList = objectList;
169:	MEM_OWN(m_objectList);
170:}
