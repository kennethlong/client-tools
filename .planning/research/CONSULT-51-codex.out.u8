129:CuiBackdrop::SceneRenderer::~SceneRenderer ()
130:{
131:	UIClock::gUIClock().StopListening( this );
132:
133:	setRenderData (0,0);
134:	m_camera     = 0;
135:	m_objectList = 0;
136:}
