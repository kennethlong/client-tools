136:
137:void PostProcessingEffectsManagerNamespace::deviceRestored()
138:{
139:	TextureFormat formats[] = { TF_ARGB_8888 };
140:	
141:	ms_primaryBuffer   = TextureList::fetch(TCF_renderTarget, Graphics::getFrameBufferMaxWidth(), 
Graphics::getFrameBufferMaxHeight(), 1, formats, sizeof(formats) / sizeof(formats[0]));
142:	ms_secondaryBuffer = TextureList::fetch(TCF_renderTarget, Graphics::getFrameBufferMaxWidth(), 
Graphics::getFrameBufferMaxHeight(), 1, formats, sizeof(formats) / sizeof(formats[0]));
143:	ms_tertiaryBuffer  = TextureList::fetch(TCF_renderTarget, Graphics::getFrameBufferMaxWidth(), 
Graphics::getFrameBufferMaxHeight(), 1, formats, sizeof(formats) / sizeof(formats[0]));
144:	ms_copyShader            = dynamic_cast<StaticShader 
*>(ShaderTemplateList::fetchModifiableShader("shader/2d_texture.sht"));
145:	ms_heatCompositingShader = dynamic_cast<StaticShader 
*>(ShaderTemplateList::fetchModifiableShader("shader/2d_heat_composite.sht"));
146:}
