1274:
1275:void  CuiIoWin::requestKeyboard (bool b)
1276:{
1277:	if (b)
1278:	{
1279:		m_keyboardRequestCount = std::max (1, m_keyboardRequestCount + 1);
1280:		setKeyboardInputActive (true);
1281:	}
1282:	else if (--m_keyboardRequestCount <= 0)
1283:		setKeyboardInputActive (false);
1284:}
