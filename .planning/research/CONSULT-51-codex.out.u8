33:CuiBackdrop::CuiBackdrop (UIPage & thePage) :
34:CuiMediator     ("CuiBackdrop", thePage),
35:m_sceneRenderer (0),
36:m_numBackdrops  (0),
37:m_backdrops     (0)
38:{
39:
40:	m_sceneRenderer = new SceneRenderer ();
41:	IGNORE_RETURN (getPage ().AddChild (m_sceneRenderer));
42:
43:	m_sceneRenderer->SetSize (getPage ().GetSize ());
44:	m_sceneRenderer->SetLocation (0,0);
45:	m_sceneRenderer->SetPropertyNarrow (UIWidget::PropertyName::PackSize, "1,1");
46:
47:	s_backdrop = this;
48:
49:	const UIData * const codeData = getCodeData ();
50:
51:	if (codeData)
52:	{
53:		const static UILowerString prop_backdropCount ("BackdropCount");
54:		if (codeData->GetPropertyInteger (prop_backdropCount, m_numBackdrops))
55:		{
56:			m_backdrops = new UIWidget * [m_numBackdrops];
57:
58:			char buf [64];
59:			const size_t buf_size = sizeof (buf);
60:
61:			for (int i = 0; i < m_numBackdrops; ++i)
62:			{
63:				m_backdrops [i] = 0;
64:				snprintf (buf, buf_size, "Backdrop%02d", i);
65:				getCodeDataObject (TUIWidget, m_backdrops [i], buf);
66:			}
67:		}
68:	}
69:
70:	// the scene renderer will always clear the viewport for us
71:	getPage ().SetBackgroundColor (UIColor::black);
72:
73:}
