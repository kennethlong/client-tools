1012:
1013:void Graphics::beginScene()
1014:{
1015:	// gl11 embed-resize deferral: apply a pending resize at a frame boundary, but
1016:	// only once the first present has happened (render state established). This is
1017:	// the safe point for the resize/device-restored fan-out; an early embed
1018:	// WM_SIZE (Utinni reparent during startup) is queued by displayModeChanged
1019:	// and lands here on the next frame after the first present. beginScene runs
1020:	// only from the game loop (the install-time clear uses the plugin's beginScene
1021:	// directly), so this never runs mid-init.
1022:	if (ms_resizePending && ms_firstPresentDone)
1023:	{
1024:		ms_resizePending = false;
1025:		if (ms_pendingResizeWidth > 0 && ms_pendingResizeHeight > 0
1026:			&& (ms_pendingResizeWidth != ms_currentRenderTargetWidth || ms_pendingResizeHeight != 
ms_currentRenderTargetHeight))
1027:		{
1028:			static bool s_loggedResizeApply = false;
1029:			WARNING(!s_loggedResizeApply,
1030:				("Graphics::beginScene: applying deferred gl11 resize w=%d h=%d", ms_pendingResizeWidth, 
ms_pendingResizeHeight));
1031:			s_loggedResizeApply = true;
1032:
1033:			Graphics::resize(ms_pendingResizeWidth, ms_pendingResizeHeight);
1034:		}
1035:	}
