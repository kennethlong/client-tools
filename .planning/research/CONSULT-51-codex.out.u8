116:
117:CuiLayer::TextureCanvas::~TextureCanvas ()
118:{
119:	if (m_shader)
120:	{
121:		CuiLayerRenderer::flushRenderQueueIfCurShader (*m_shader);
122:		m_shader->release();
123:		m_shader = 0;
124:	}
125:}
