1286://----------------------------------------------------------------------
1287:
1288:void  CuiIoWin::requestPointer (bool b)
1289:{
1290:	if (b)
1291:		++m_pointerToggledCount;
1292:	else if (--m_pointerToggledCount <= 0)
1293:		m_pointerToggledCount = 0;
1294:
1295:	CuiManager::InputManager::setPointerInputActive  (b || CuiPreferences::getMouseModeDefault ());
1296:}
