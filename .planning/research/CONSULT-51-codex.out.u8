148:// ----------------------------------------------------------------------
149:
150:void PostProcessingEffectsManagerNamespace::deviceLost()
151:{
152:	if (ms_primaryBuffer)
153:	{
154:		ms_primaryBuffer->release();
155:		ms_primaryBuffer = NULL;
156:	}
157:	
158:	if (ms_secondaryBuffer)
159:	{
160:		ms_secondaryBuffer->release();
161:		ms_secondaryBuffer = NULL;
162:	}
163:
164:	if (ms_tertiaryBuffer)
165:	{
166:		ms_tertiaryBuffer->release();
167:		ms_tertiaryBuffer = NULL;
168:	}
169:
170:	if (ms_copyShader)
171:	{
172:		ms_copyShader->release();
173:		ms_copyShader= NULL;
174:	}
175:
176:	if (ms_heatCompositingShader)
177:	{
178:		ms_heatCompositingShader->release();
179:		ms_heatCompositingShader= NULL;
180:	}
181:}
