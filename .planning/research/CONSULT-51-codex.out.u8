122:void PostProcessingEffectsManager::disable()
123:{
124:	if (ms_enabled)
125:	{
126:		deviceLost();
127:		Graphics::removeDeviceLostCallback(deviceLost);
128:		Graphics::removeDeviceRestoredCallback(deviceRestored);
129:		
130:		ms_enable = false;
131:		ms_enabled = false;
132:	}
133:}
