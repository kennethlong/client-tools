1405:void CuiIoWin::getScreenCenter (UIPoint & screenCenter) const
1406:{
1407:	if (m_pointerInputActive || !Game::isViewFirstPerson())
1408:	{
1409:		if (!Game::isHudSceneTypeSpace())
1410:		{
1411:			screenCenter.Set (Graphics::getCurrentRenderTargetWidth() / 2, 
Graphics::getCurrentRenderTargetHeight() / 2);
1412:			return;
1413:		}
1414:	}
1415:
1416:	screenCenter = m_screenCenter;
1417:}
