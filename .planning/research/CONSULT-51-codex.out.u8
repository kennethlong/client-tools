28:	const char * const UICANVAS_SHT            = "shader/uicanvas_filtered.sht";
29:
30:	inline const StaticShader * loadUIShader (const std::string & shaderName, const std::string & 
textureName, UISize & size)
31:	{
32:		std::string fname;
33:		
34:		const StaticShader * shader = 0;
35:		const Texture * texture = 0;	
36:		
37:		const ShaderTemplate * const shaderTemplate = ShaderTemplateList::fetch (shaderName.empty () ? 
UICANVAS_SHT : shaderName.c_str ());
38:		
39:		if (shaderTemplate)
40:		{
41:			StaticShader * const modShader = safe_cast<StaticShader *>(NON_NULL 
(shaderTemplate->fetchModifiableShader ()));
42:			
43:			if (!textureName.empty ())
44:			{
45:				texture = TextureList::fetch (textureName.c_str ());
46:				
47:				if (texture)
48:				{
49:					modShader->setTexture(TAG(M,A,I,N), *texture); //lint !e1774
50:					shader = modShader;
51:				}
52:				else
53:					WARNING (true, ("No such UI texture: '%s'", textureName.c_str ()));
54:			}
55:			else
56:			{
57:				shader = modShader;
58:				modShader->getTexture(TAG (M,A,I,N), texture);
59:				if (texture)
60:					texture->fetch ();
61:			}
62:
63:			shaderTemplate->release ();
64:		}
65:		else
66:			WARNING (true, ("No such UI shader template: '%s'", shaderName.c_str ()));
67:
68:		if (texture)
69:		{
70:			//-- extract size
71:			size.x = texture->getWidth ();
72:			size.y = texture->getHeight ();			
73:			texture->release();
74:		}
75:		else
76:		{
77:			WARNING (true, ("UI shader with no texture: %s:%s", textureName.c_str (), shaderName.c_str 
()));
78:		}
79:
80:		return shader;
81:	}
82:}
