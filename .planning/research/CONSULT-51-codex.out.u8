77:CuiBackdrop::~CuiBackdrop ()
78:{
79:	// PS UI cleans up scene renderer
80:	m_sceneRenderer = 0; //lint !e423 //memleak
81:	
82:	if (s_backdrop == this)
83:		s_backdrop = 0;
84:
85:	delete [] m_backdrops;
86:	m_backdrops = 0;
87:}
