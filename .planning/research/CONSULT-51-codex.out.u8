93:CuiLayer::TextureCanvas::TextureCanvas (const std::string & shaderName, const std::string & 
textureName) :
94:UICanvas       (UISize ()),
95:m_shaderName   (shaderName),
96:m_textureName  (textureName),
97:m_shader       (0),
98:m_initialized  (false),
99:m_lastTimeUsed (0.0f),
100:m_lastFrameUsed (0)
101:{
102:	if (!s_debugReportCanvasesInit)
103:	{
104:		s_debugReportCanvasesInit = true;
105:		DebugFlags::registerFlag(s_debugReportCanvases, "ClientUserInterface", "canvases");
106:	}
107:
108:	if (!m_shaderName.empty ())
109:		m_shaderName = "shader/" + m_shaderName + ".sht";
110:
111:	if (!m_textureName.empty ())
112:		m_textureName = "texture/" + m_textureName + ".dds";
113:}
