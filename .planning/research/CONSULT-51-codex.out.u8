127://-------------------------------------------------------------------
128:
129:/**
130:* initShader will simply re-initialize the shader if called more than once.
131:* It will properly release the old shader.
132:*/
133:void CuiLayer::TextureCanvas::initShader () const
134:{
135:	if (m_shader)
136:	{
137:		CuiLayerRenderer::flushRenderQueueIfCurShader (*m_shader);
138:		m_shader->release();
139:		m_shader = 0;
140:	}
141:
142:	UISize s;
143:	m_shader = loadUIShader (m_shaderName, m_textureName, s);
144:
145:	if (m_shader)
146:		const_cast<TextureCanvas *>(this)->SetSize (s);
147:
148:	m_initialized = true;
149:	REPORT_LOG_PRINT (s_debugReportCanvases, (":: Cui initialized shader %s:%s\n", 
m_shaderName.c_str (), m_textureName.c_str ()));
150:}
151:
152://-----------------------------------------------------------------
153:
154:/**
155:* releases the shader, sets the initialized flag to false
156:*/
157:void CuiLayer::TextureCanvas::unloadShader ()
158:{
159:	if (m_shader)
160:	{
161:		CuiLayerRenderer::flushRenderQueueIfCurShader (*m_shader);
162:		m_shader->release();
163:		m_shader = 0;
164:	}
165:
166:	m_initialized = false;
167:	REPORT_LOG_PRINT (s_debugReportCanvases, (":: Cui unloaded shader %s:%s\n", m_shaderName.c_str 
(), m_textureName.c_str ()));
168:}
