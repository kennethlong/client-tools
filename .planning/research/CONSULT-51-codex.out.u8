184:
185:void PostProcessingEffectsManager::preSceneRender()
186:{
187:	// handle switching between PostProcessingEffectsManager enabled & disabled
188:	if (ms_enabled && !ms_enable)
189:		disable();
190:	else if (!ms_enabled && ms_enable)
191:		enable();
192:		
193:	if (ms_enabled)
194:	{
195:		Graphics::setRenderTarget(ms_primaryBuffer, CF_none, 0);
196:		DEBUG_FATAL(ms_primaryBuffer->getWidth() != 
Graphics::getCurrentRenderTargetWidth(),("rendertarget and big widths do not match"));
197:		DEBUG_FATAL(ms_primaryBuffer->getHeight() != 
Graphics::getCurrentRenderTargetHeight(),("rendertarget and big heights do not match"));
198:	}
199:	
200:	Graphics::setViewport(0, 0, Graphics::getCurrentRenderTargetWidth(), 
Graphics::getCurrentRenderTargetHeight(), 0.0f, 1.0f);
201:}
202:
203:// ----------------------------------------------------------------------
204:
205:void PostProcessingEffectsManager::postSceneRender()
206:{
207:	if (ms_enabled)
208:	{
209:		VertexBufferFormat format;
210:		format.setPosition();
211:		format.setTransformed();
212:		format.setNumberOfTextureCoordinateSets(1);
213:		format.setTextureCoordinateSetDimension(0, 2);
214:		
215:		// copy the back buffer to the frame buffer
216:		DynamicVertexBuffer vertexBuffer(format);
217:		
218:		int destinationWidth = ms_primaryBuffer->getWidth();
219:		int destinationHeight = ms_primaryBuffer->getHeight();
220:		
221:		vertexBuffer.lock(4);
222:		{
223:			VertexBufferWriteIterator v = vertexBuffer.begin();
