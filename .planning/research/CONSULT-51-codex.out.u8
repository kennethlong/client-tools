90:
91:void CuiBackdrop::performActivate ()
92:{
93:	m_sceneRenderer->SetEnabled (true);
94:	m_sceneRenderer->SetVisible (true);
95:}
96:
97://-----------------------------------------------------------------
98:
99:void CuiBackdrop::performDeactivate ()
100:{
101:	m_sceneRenderer->SetEnabled (false);
102:	m_sceneRenderer->SetVisible (false);
103:}
