390:// clean (non-crashing) injected run -- which is why "the WARNINGs never appeared."
391:// This flushed trace is always on disk, so the next injected smoke conclusively
392:// shows whether displayModeChanged fires, whether the deferred apply runs, and
393:// whether Graphics::resize (scene RTs + projection) actually executes.
394:
395:static void gl11ResizeTrace(char const * const what, int const a, int const b)
396:{
397:	FILE * const f = fopen("swgclient-resize-trace.log", "a");
398:	if (f) { fprintf(f, "[gl11-resize] %-34s %d x %d\n", what, a, b); fflush(f); fclose(f); }
399:}
400:
401:void GraphicsNamespace::displayModeChanged()
402:{
403:	gl11ResizeTrace("displayModeChanged CALLED rM/fpd", ms_rasterMajor, ms_firstPresentDone ? 1 : 
0);
404:
405:	// D3D11 (gl11): a WM_SIZE / display change means the window client rect
406:	// changed. Drive the engine's full resize -- Graphics::resize updates the
407:	// render-target dimension globals AND calls ms_api->resize, which resizes the
408:	// swap-chain back-buffer and fires the device-restored callbacks so the
409:	// offscreen scene render target(s) (PostProcessingEffectsManager / Bloom) +
410:	// the per-frame camera viewport/projection (GroundScene re-reads
411:	// getCurrentRenderTarget* every frame) all track the new size. Without this
412:	// only the back-buffer resized while the scene viewport/RT/projection stayed
413:	// at the creation size, so the embedded scene rendered cropped to the
414:	// top-left of a resized back-buffer.
415:	//
416:	// D3D9 keeps its legacy deferred path (ms_api->displayModeChanged sets a flag
417:	// handled by checkDisplayMode) -- the embedded D3D9 case relies on
418:	// render-target-space stretch and must not be rerouted through a device reset.
419:	if (ms_rasterMajor == 11 && ms_api && ms_api->resize)
420:	{
421:		HWND const window = Os::getWindow();
422:		if (window)
423:		{
424:			RECT rc;
425:			if (GetClientRect(window, &rc))
426:			{
427:				int const newWidth  = rc.right - rc.left;
428:				int const newHeight = rc.bottom - rc.top;
429:				if (newWidth > 0 && newHeight > 0)
430:				{
431:					// DEFER -- never resize synchronously here. Under Utinni
432:					// injection the window is reparented + SetWindowPos-resized
433:					// during startup, delivering WM_SIZE before the first frame.
434:					// Doing the resize/device-restored fan-out before the first
435:					// present (device/RTs/callback targets not yet established)
436:					// regressed the injected render path (no render). Record the
437:					// latest requested size; Graphics::beginScene applies it once
438:					// ms_firstPresentDone -- i.e. the latest size wins, applied at
439:					// a frame boundary after render state exists. Standalone is
440:					// unaffected (it gets no early embed resize).
441:					ms_pendingResizeWidth  = newWidth;
442:					ms_pendingResizeHeight = newHeight;
443:					ms_resizePending       = true;
444:
445:					gl11ResizeTrace(ms_firstPresentDone ? "REQUEST (apply next frame)" : "REQUEST (deferred, 
pre-present)", newWidth, newHeight);
446:
447:					static bool s_loggedResizeRequest = false;
448:					WARNING(!s_loggedResizeRequest,
449:						("Graphics::displayModeChanged(gl11): resize request w=%d h=%d rasterMajor=%d 
firstPresentDone=%d -> %s",
450:						 newWidth, newHeight, ms_rasterMajor, ms_firstPresentDone ? 1 : 0,
451:						 ms_firstPresentDone ? "apply next beginScene" : "DEFERRED until first present"));
452:					s_loggedResizeRequest = true;
453:				}
454:			}
455:		}
456:		return;
457:	}
458:
459:	if (ms_api && ms_api->displayModeChanged)
460:		ms_api->displayModeChanged();
461:}
