// ----------------------------------------------------------------------

bool CPixelShaderProgramView::Compile()
{
	CString left = m_pixelShaderProgramNode->m_text.Left(6);
	left.MakeLower();
	if (left == "//hlsl")
		return CompileHlsl();

	return CompileAsm();
}

// ----------------------------------------------------------------------

void CPixelShaderProgramView::OnPixelshaderprogramCompile()
{
	Compile();
}

