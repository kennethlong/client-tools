					const int index = error.Find (')');
					if (index != -1)
					{
						CString source;
						m_source.GetWindowText (source);

						CString desiredLineNumber = error.Mid (1, index - 1);
						int lineNumber = atoi (desiredLineNumber) - 1;

						int start = 0;
						while (lineNumber > 0)
						{
							start = source.Find ('\n', start + 1);
							--lineNumber;
						}

						int end = source.Find ('\n', start + 1);
						if (end == -1)
