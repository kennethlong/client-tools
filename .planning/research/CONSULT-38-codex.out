236-	PWR_WalkFailed,         // The walk failed (probably an error)
237:	PWR_HitEdge,            // The walk hit an edge of the mesh
238:	PWR_HitPortalEdge,      // The walk hit a portal-adjacent edge of the mesh
239-	PWR_HitPast,            // The walk hit an edge some time in the past
240:	PWR_InContact,          // The walk was unable to move because the point/circle was already in 
