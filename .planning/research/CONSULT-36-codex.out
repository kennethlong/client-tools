1248-
1249:void ShaderPrimitiveSorter::addWithAlphaFadeOpacity(const ShaderPrimitive &shaderPrimitive, bool opaqueEnable, float opaqueAlpha, bool alphaEnable, float alphaAlpha)
1250-{
1251:	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add alphaflags");
1252-
1253-	UNREF(alphaAlpha);
1254-
1255-	DEBUG_FATAL(ms_popped, ("Adding primitives after cell popped"));
1256-	StaticShader const & staticShader = ms_prepareToViewFunction(shaderPrimitive);
1257-
1258-	// this may be true when the shader has failed validation because of a lost device
1259-	if (!staticShader.isValid())
1260-		return;
1261-
1262-	int phase = staticShader.getPhase();
1263-	DEBUG_FATAL(phase < 0 || phase >= static_cast<int>(ms_phase.size()), ("Invalid phase %d/%d", phase, ms_phase.size()));
1264-
1265-	float alphaFadeOpacity = 1.0f;
1266-	if (phase == 3) // Main phase
1267-	{
1268-		if (!opaqueEnable)
1269-		{
1270-			if (staticShader.containsPrecalculatedVertexLighting())
1271-				ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1272-			else
1273-				ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1274-			return;
1275-		}
1276-
1277-		alphaFadeOpacity = opaqueAlpha;
1278-		phase = 6;
1279-	}
1280-	else
1281-		if (phase == 5 || phase == 6) // Alpha/Blend/PreAlpha phases.
1282-		{
1283-			if (!alphaEnable)
1284-			{
1285-				if (staticShader.containsPrecalculatedVertexLighting())
1286-					ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1287-				else
1288-					ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1289-				return;
1290-			}
1291-
1292-			alphaFadeOpacity = alphaAlpha;
1293-		}
1294-
1295-	//-- see if the primitive is supposed to be affected by water
1296-	if (ms_useWaterTests && ms_belowTransparentWaterFunction && phase == ms_belowTransparentWaterTestPhase)
1297-	{
1298:		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add alphaflags test below water");
1299-		
1300-		if (ms_belowTransparentWaterFunction(shaderPrimitive.getPosition_w()))
1301-			phase = ms_belowTransparentWaterPhase;
1302-		else
1303-			phase = ms_aboveWaterPhase;
1304-	}
1305-
1306-	if (staticShader.containsPrecalculatedVertexLighting())
1307-		ms_phase[phase].addWithAlphaFadeOpacity(shaderPrimitive, staticShader, alphaFadeOpacity, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1308-	else
1309-		ms_phase[phase].addWithAlphaFadeOpacity(shaderPrimitive, staticShader, alphaFadeOpacity, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1310-}
