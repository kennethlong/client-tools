1213:void ShaderPrimitiveSorter::add(const ShaderPrimitive &shaderPrimitive, const int phase)
1214-{
1215:	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add");
1216-
1217-	if (ms_useClipRectangle)
1218-	{
1219-		Vector const & pos_w = shaderPrimitive.getPosition_w();
1220-		float const radius = shaderPrimitive.getRadius();
1221-
1222-		if (radius > 0.0f)
1223-		{
1224-			Rectangle2d const shaderPrimitiveRectangle(pos_w.x - radius, pos_w.z - radius, pos_w.x + radius, pos_w.z + radius);
1225-			if (!ms_clipRectangle.intersects(shaderPrimitiveRectangle))
1226-			{
1227-				return;
1228-			}
1229-		}
1230-	}
1231-
1232-	DEBUG_FATAL(ms_popped, ("Adding primitives after cell popped"));
1233-	StaticShader const & staticShader = ms_prepareToViewFunction(shaderPrimitive);
1234-	DEBUG_FATAL(phase < 0 || phase >= static_cast<int>(ms_phase.size()), ("Invalid phase %d/%d", phase, ms_phase.size()));
1235-
1236-	if (staticShader.containsPrecalculatedVertexLighting())
1237-		ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1238-	else
1239-		ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1240-}
