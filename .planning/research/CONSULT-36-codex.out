1204-	/////////////////////////////////////////////////////////////////////////////////////////
1205-
1206-	/////////////////////////////////////////////////////////////////////////////////////////
1207-	//-- copy positions, weights and normals
1208-	TransformData *destTransformData = m_transformData;
1209-	for (vertexIndex = 0; vertexIndex < m_vertexCount; ++vertexIndex)
1210-	{
