321-			bool const sampleBucket = (s_diagFanShapedUnlocks > 5) && ((s_diagFanShapedUnlocks % 500) == 0);
322-			if (earlyBucket || sampleBucket)
323-			{
324-				uint8_t const *vb = static_cast<uint8_t const *>(s_lastLockedSliceCPUPtr);
325-				ID3D11InfoQueue *iq = Direct3d11_Device::getInfoQueue();
326-				for (int v = 0; v < 4; ++v)
327-				{
328-					uint8_t const *src = vb + v * vertexSize;
329-					float const px = *reinterpret_cast<float const *>(src + 0);
330-					float const py = *reinterpret_cast<float const *>(src + 4);
331-					float const pz = *reinterpret_cast<float const *>(src + 8);
332-					uint32_t const c = *reinterpret_cast<uint32_t const *>(src + 12);
333-					float const u  = *reinterpret_cast<float const *>(src + 16);
334-					float const tv = *reinterpret_cast<float const *>(src + 20);
335-					char buf[256];
336-					_snprintf_s(buf, sizeof(buf), _TRUNCATE,
337-						"Plan 11-09.15 Iter-4 fan-shaped unlock#%d vert#%d pos=(%.3f,%.3f,%.3f) color=0x%08X uv=(%.3f,%.3f) offsetVerts=%d",
338-						s_diagFanShapedUnlocks, v, px, py, pz, c, u, tv, m_offset);
339-					if (iq)
340-						iq->AddApplicationMessage(D3D11_MESSAGE_SEVERITY_INFO, buf);
341-				}
342-			}
343-		}
344-
345-		// CONSULT-36 COPY-OUTPUT RATIO PROBE (passive, non-draining): read the dynamic-VB slice the
346-		// engine just wrote (post-copy, BEFORE Unmap) and compute the scale-free outlier ratio
347-		// (maxDist^2/meanDist^2 from vert0) over the position. The soft fill's blendPosition is proven
348-		// clean; this tests whether the COPY/lock/stride corrupts it. ratio>>1 => the copy introduced
349-		// the spike; clean => the written GPU bytes match the clean soft output (=> spike is the GPU
350-		// READ, live-only). Logs only a new worst ratio. stage/cape-copyout.txt.
351:		if (s_lastLockedSliceCPUPtr && vertexSize >= 32 && numberOfVertices >= 32 && numberOfVertices < 8192)
352-		{
353-			uint8_t const *covb = static_cast<uint8_t const *>(s_lastLockedSliceCPUPtr);
354-			float const co0x = *reinterpret_cast<float const *>(covb + 0);
355-			float const co0y = *reinterpret_cast<float const *>(covb + 4);
356-			float const co0z = *reinterpret_cast<float const *>(covb + 8);
357-			double coSumD2 = 0.0; float coMaxD2 = 0.f; int coMaxI = 0; float coMx = co0x, coMy = co0y, coMz = co0z;
