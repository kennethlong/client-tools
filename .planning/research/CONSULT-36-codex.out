1400:void ShaderPrimitiveSorter::popCell()
1401-{
1402-	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::popCell");
1403-
1404-	if (!ms_popped && ms_cellPropertyStack.back())
1405-		ms_cellPropertyStack.back()->callPreDrawRenderHookFunctions();
1406-
1407-	DEBUG_FATAL(ms_lightListStackOffset.size() == 1, ("Stack underflow"));
1408-
1409-	// tell all the phases we're popping
1410-	{
1411-		const int count = static_cast<int>(ms_phase.size());
1412-		for (int i = 0; i < count; ++i)
1413-			ms_phase[i].popCell();
1414-	}
1415-
1416-	ms_environmentTextures.pop_back();
1417-	Graphics::setGlobalTexture(TAG_ENVM, *ms_environmentTextures.back());
1418-
1419-	ms_fogStack.pop_back();
1420-	FogData fogData = ms_fogStack.back();
1421-	Graphics::setFog(fogData.enabled, fogData.density, fogData.color);
1422-
1423-	// make sure the lights are cleared out
1424-	ms_activeLightList.clear();	
1425-	Graphics::setLights(ms_activeLightList);
1426-
1427-	// remove all the lights added in the popped cell
1428-	LightList::const_iterator iEnd = ms_lightList.end();
1429-	const int offset = ms_lightListStackOffset.back();
1430-	for (LightList::const_iterator i = ms_lightList.begin() + offset; i != iEnd; ++i)
1431-		(*i)->setShaderPrimitiveSorterLightIndex(-1);
1432-	ms_lightList.erase(ms_lightList.begin() + offset, ms_lightList.end());
1433-	ms_lightListStackOffset.pop_back();
1434-	ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting.reset();
1435-	ms_lightsAffectingShadersWithPrecalculatedVertexLighting.reset();
1436-
1437-	if (ms_cellPropertyStack.back())
1438-	{
1439-		ms_cellPropertyStack.back()->callExitRenderHookFunctions();
1440-#ifdef _DEBUG
1441-		ms_cellPropertyStack.back() = NULL;
1442-#endif
1443-	}
1444-	ms_cellPropertyStack.pop_back();
1445-
1446-	ms_popped = true;
1447-
1448-#ifdef _DEBUG
1449-	ms_lightListOverflow = false;
1450-#endif
1451-
1452-	DEBUG_REPORT_PRINT(ms_reportPixelsComposited && ms_pixelsCompositedThisFrame > 0, 
1453-		("Composited [%8d] KiloPixels in [%4d] passes\n", ms_pixelsCompositedThisFrame / 1000, ms_compositePasses));
