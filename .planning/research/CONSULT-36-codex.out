1014-void SoftwareBlendSkeletalShaderPrimitive::_initialize(const MeshConstructionHelper &mesh, int shaderIndex, bool multiStream)
1015-{
1016-	/*
1017-		NOTES
1018-
1019-		In multi stream rendering, the skinned components (position, normal,
1020-		dot3 if present) are skinned directly into a dynamic vertex buffer.  The
1021-		non-skinned, constant components (color and non-dot3 texture coordinates)
1022-		are stored in a per-instance static buffer.
1023-
1024-		In single stream rendering, the skinned components (position, normal,
1025-		dot3 if present) are skinned in a common system vertex buffer.  The
1026-		non-skinned, constant components (color and non-dot3 texture coordinates) are
1027-		stored in an instance system buffer.  The dynamic vertex buffer
1028-		contains the full set of vertex information and is constructed by
1029-		merging skinned common system vertex buffer with the constant component
1030-		system vertex buffer.
1031-	*/
1032-
1033-	/////////////////////////////////////////////////////////////////////////////////////////
1034-	//-- Setup index buffer and render commands.
1035:	buildIndexBufferAndRenderCommands(mesh, shaderIndex);
1036-
1037-	/////////////////////////////////////////////////////////////////////////////////////////
1038-	//-- Retrieve some common values from the mesh.
1039-	const MeshConstructionHelper::PerShaderData *const meshPerShaderData = mesh.getPerShaderData(shaderIndex);
1040-	const uint inputFormat = mesh.getVertexFormat(meshPerShaderData);
1041-	const bool hasArgb     = (inputFormat & MeshConstructionHelper::SVF_argb) != 0;
1042-	const int  tcSetCount  = mesh.getTextureCoordinateSets(meshPerShaderData);
1043-
1044-	/////////////////////////////////////////////////////////////////////////////////////////
1045-	//-- Create the shader.
1046-	m_shader = ShaderTemplateList::fetchModifiableShader(mesh.getShaderTemplateName(meshPerShaderData));
1047-
1048-	/////////////////////////////////////////////////////////////////////////////////////////
1049-	//-- some debug checks
1050-	DEBUG_FATAL((inputFormat & MeshConstructionHelper::SVF_xyz) == 0, ("input mesh does not include xyz data"));
1051-	DEBUG_FATAL((inputFormat & MeshConstructionHelper::SVF_normal) == 0, ("support for non-normal skeletal meshes has been removed, re-export data with normals."));
1052-	UNREF(inputFormat);
1053-
1054-	/////////////////////////////////////////////////////////////////////////////////////////
1055-	//-- get # vertices
1056-	m_vertexCount = mesh.getVertexCount(meshPerShaderData);
1057-	DEBUG_FATAL(m_vertexCount < 1, ("there are no vertices!"));
1058-
1059-	/////////////////////////////////////////////////////////////////////////////////////////
1060-	//-- Construct the constant static vertex buffer.  This format will contain
1061-	//   color and non-dot3 texture coordinates.
1062-	VertexBufferFormat  constantFormat;
1063-	if (multiStream)
1064-	{
1065-		constantFormat.setColor0(hasArgb);
1066-	}
1067-	/////////////////////////////////////////////////////////////////////////////////////////
1068-
1069-	/////////////////////////////////////////////////////////////////////////////////////////
1070-	// Setup dot3 texture coordinate set info and stuff constant texture coordinate set info
1071-	// into constantFormat.
1072-	//
1073-	// Count # non-dot3 texture coordinate sets.
1074-	int constantTcSetCount = 0;
1075-	for (int i = 0; i < tcSetCount; ++i)
1076-	{
1077-		const int dimensionality = mesh.getTextureCoordinateDimensionality(meshPerShaderData, i);
1078-		if (dimensionality != 4)
1079-		{
1080-			++constantTcSetCount;
1081-		}
1082-		else
1083-		{
1084-			// This tc set is the dot3 vector.
1085-			DEBUG_FATAL(m_hasDot3Vector, ("2 sets of 4d texture coordinates are not supported, detected at tc set index [%d] and [%d].", m_dot3TextureCoordinateSetIndex, i));
1086-			DEBUG_FATAL(i != tcSetCount - 1, ("dot3 4d texture coordinates are only supported as the last texture coordinate set, but it is [%d] of [%d].", i + 1, tcSetCount));
1087-
1088-			m_hasDot3Vector                 = true;
1089-			m_dot3TextureCoordinateSetIndex = ms_useMultiStreamVertexBuffers ? 0 : i;
1090-		}
1091-	}
1092-
1093-	// Set constant texture coordinate set info in the vertex buffer.
1094-	if (constantTcSetCount > 0)
1095-	{
1096-		constantFormat.setNumberOfTextureCoordinateSets(constantTcSetCount);
1097-
1098-		int constantTcIndex = 0;
1099-		for (int j = 0; j < tcSetCount; ++j)
1100-		{
1101-			// Retrieve dimensionality.
1102-			const int dimensionality = mesh.getTextureCoordinateDimensionality(meshPerShaderData, j);
1103-			if (dimensionality != 4)
1104-			{
1105-				// Set this non-dot3 texture set into the constant VB format.
1106-				constantFormat.setTextureCoordinateSetDimension(constantTcIndex, dimensionality);
1107-				++constantTcIndex;
1108-			}
1109-		}
1110-	}
1111-	/////////////////////////////////////////////////////////////////////////////////////////
1112-
1113-	/////////////////////////////////////////////////////////////////////////////////////////
1114-	//-- Construct the dynamic vertex buffer.
1115-	VertexBufferFormat  dynamicFormat;
1116-
1117-	// Dynamic always contains position and normal.
1118-	dynamicFormat.setPosition(true);
1119-	dynamicFormat.setNormal(true);
1120-
1121-	if (!multiStream)
1122-	{
1123-		dynamicFormat.setColor0(hasArgb);
1124-		dynamicFormat.setNumberOfTextureCoordinateSets(tcSetCount);
1125-		{
--
1238-			sourceVertex.m_firstTransformData.m_transformIndex = sourceTransformData->m_transformIndex;
1239-			sourceVertex.m_firstTransformData.m_transformWeight = sourceTransformData->m_transformWeight;
1240-
1241-			sourceVertex.m_extraTransformDataCount = localVertexTransformCount-1;
1242-			
1243-			// grab transform data
1244-			for (int j = 1; j < localVertexTransformCount; ++j, ++destTransformData)
1245-			{
1246-				sourceTransformData = &mesh.getVertexTransformData(vertexData, j);
1247-				destTransformData->m_transformIndex  = sourceTransformData->m_transformIndex;
1248-				destTransformData->m_transformWeight = sourceTransformData->m_transformWeight;
1249-			}
1250-		}
1251-	}
1252-
1253-	WARNING(destTransformData-m_transformData != numberOfExtraTransformWeightPairs, ("logic error: TransfromData count [%d] != numberOfExtraTransformWeightPairs [%d]", destTransformData-m_transformData, numberOfExtraTransformWeightPairs));
1254-	/////////////////////////////////////////////////////////////////////////////////////////
1255-
1256-	IS_NULL(m_vertexBufferVector);
1257-	if (multiStream)
1258-	{
1259-		///////////////////////////////////////////////////////////////////////
1260-		//-- Fill the constant static vertex buffer.
1261-		m_staticStream = new StaticVertexBuffer(constantFormat, m_vertexCount);
1262-		m_staticStream->lock();
1263-		VertexBufferWriteIterator outIt = m_staticStream->begin();
1264-		fillConstantVertexBufferData(mesh, shaderIndex, outIt);
1265-		m_staticStream->unlock();
1266-		///////////////////////////////////////////////////////////////////////
1267-
1268-		m_systemStream = new SystemVertexBuffer(dynamicFormat, m_vertexCount);
1269-
1270-		m_vertexBufferVector = new VertexBufferVector(*m_staticStream, *m_dynamicStream);
1271-	}
1272-	else
1273-	{
1274-		///////////////////////////////////////////////////////////////////////
1275-		//-- Construct and fill the system vertex buffer with constant data.
1276-		//   We'll stuff both constant and per-frame-skinned geometry in the system vertex buffer
1277-		//   so we can do a single memory copy to the dynamic VB used at render time.
1278-		m_systemStream = new SystemVertexBuffer(dynamicFormat, m_vertexCount);
1279-		VertexBufferWriteIterator outIt = m_systemStream->begin();
1280-		fillConstantVertexBufferData(mesh, shaderIndex, outIt);
1281-		///////////////////////////////////////////////////////////////////////
1282-
1283-		//-- Track which vertex buffers we render with.  Non-multi-streaming always uses just the
1284-		//   dynamic vertex buffer.
1285-		m_vertexBufferVector = new VertexBufferVector(*m_dynamicStream);
1286-	}
1287-}
