325-void SoftwareBlendSkeletalShaderPrimitive::install()
326-{
327-	DEBUG_FATAL(ms_installed, ("SoftwareBlendSkeletalShaderPrimitive already installed"));
328-
329-	installMemoryBlockManager();
330-	RenderCommand::install();
331-
332-	// Plan 17-08 (GAP-6) diagnostic: the multi-stream tangent path (skinned DOT3
333-	// surfaced as TEXCOORD2 for bump VS) only fires when this flag latches true.
334-	// It is computed ONCE here, so if any input reads a default value (e.g. gl11
335-	// caps not yet live at this point in the boot sequence), multi-stream stays
336-	// off for the whole session and the bump VS's TEXCOORD2 gets phantom-zeroed
337-	// -> normalize(0) -> NaN COLOR0 -> wrong sleeves/hands. Capture each
338-	// sub-condition + the final flag so one boot says exactly which input is
339-	// false at latch time. (Logic below is unchanged from the original &&-chain.)
340-	int  const  gap6MaxStreamCount = Graphics::getMaximumVertexBufferStreamCount();
341-	bool const  gap6StreamOffsets  = Graphics::supportsStreamOffsets();
342-	bool const  gap6DisableCfg     = ConfigClientGraphics::getDisableMultiStreamVertexBuffers();
343-
344-	ms_useMultiStreamVertexBuffers =
345-		   (gap6MaxStreamCount > 1)
346-		&& gap6StreamOffsets
347-		&& !gap6DisableCfg
348-		;
349-
350-	DEBUG_REPORT_LOG(true, ("GAP-6 multistream latch: maxStreamCount=%d (>1=%d) supportsStreamOffsets=%d disableMultiStreamCfg=%d -> ms_useMultiStreamVertexBuffers=%d\n",
351-		gap6MaxStreamCount, (gap6MaxStreamCount > 1) ? 1 : 0, gap6StreamOffsets ? 1 : 0, gap6DisableCfg ? 1 : 0, ms_useMultiStreamVertexBuffers ? 1 : 0));
352-	// GAP-6 diagnostic: DEBUG_REPORT_LOG only reaches OutputDebugString (needs a
353-	// debugger/DebugView); the plugin's d3d11-debug.log is InfoQueue-only. Write
354-	// the latch result straight to a file in the client CWD (stage/) so a plain
355-	// boot captures it with no extra tooling. Temporary -- remove when GAP-6 closes.
356-	if (FILE *gap6Log = fopen("gap6_latch.log", "w"))
357-	{
358-		fprintf(gap6Log,
359-			"GAP-6 multistream latch: maxStreamCount=%d (>1=%d) supportsStreamOffsets=%d disableMultiStreamCfg=%d -> ms_useMultiStreamVertexBuffers=%d\n",
360-			gap6MaxStreamCount, (gap6MaxStreamCount > 1) ? 1 : 0, gap6StreamOffsets ? 1 : 0, gap6DisableCfg ? 1 : 0, ms_useMultiStreamVertexBuffers ? 1 : 0);
361-		fclose(gap6Log);
362-	}
