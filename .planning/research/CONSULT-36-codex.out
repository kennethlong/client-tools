1463-/**
1464- * Fills the specified VB iterator with color and non-dot3 texture coordinate
1465- * data and extracts this instance's dot3 data.
1466- */
1467-
1468-void SoftwareBlendSkeletalShaderPrimitive::fillConstantVertexBufferData(const MeshConstructionHelper &mesh, int shaderIndex, VertexBufferWriteIterator &destVertexIt)
1469-{
1470-	const MeshConstructionHelper::PerShaderData *const meshPerShaderData = mesh.getPerShaderData(shaderIndex);
1471-	const uint inputFormat = mesh.getVertexFormat(meshPerShaderData);
1472-	const bool hasArgb     = (inputFormat & MeshConstructionHelper::SVF_argb) != 0;
1473-	const int  tcSetCount  = mesh.getTextureCoordinateSets(meshPerShaderData);
1474-
1475-	//-- Cache tc set dimensionality.
1476-	int  tcSetDimensionality[cs_maxTextureSetCount];
1477-
1478-	for (int i = 0; i < tcSetCount; ++i)
1479-	{
1480-		tcSetDimensionality[i] = mesh.getTextureCoordinateDimensionality(meshPerShaderData, i);
1481-	}
1482-
1483-	//-- Extract data for each vertex.
1484-	float textureCoordinate[4];
1485-	for (int vertexIndex = 0; vertexIndex < m_vertexCount; ++vertexIndex, ++destVertexIt)
1486-	{
1487-		const MeshConstructionHelper::VertexData &vertexData = mesh.getVertexData(meshPerShaderData, vertexIndex);
1488-
1489-		// copy color
1490-		if (hasArgb)
1491-		{
1492-			const PackedArgb &argb = mesh.getDiffuseColor(vertexData);
1493-			destVertexIt.setColor0(argb.getArgb());
1494-		}
1495-
1496-		// copy texture data
1497-		for (int tcSetIndex = 0; tcSetIndex < tcSetCount; ++tcSetIndex)
1498-		{
1499-			// Get texture set dimensionality.
1500-			const int tcCount = tcSetDimensionality[tcSetIndex]; //lint !e644 !e771 // Warning -- Variable 'tcSetDimensionality' may not have been initialized // false
1501-
1502-			// Get texture set values.
1503-			switch (tcCount)
1504-			{
1505-			case 2:
1506-				mesh.getTextureCoordinates(meshPerShaderData, vertexData, tcSetIndex, textureCoordinate[0], textureCoordinate[1]);
1507-				destVertexIt.setTextureCoordinates(tcSetIndex, textureCoordinate[0], textureCoordinate[1]);
1508-				break;
1509-
1510-			case 4:
1511-			{
1512-				// Extract the dot3 coordinate.
1513-				DEBUG_FATAL(!m_hasDot3Vector, ("we should not be receiving 4d texture coordinates."));
1514-				mesh.getTextureCoordinates(meshPerShaderData, vertexData, tcSetIndex, textureCoordinate[0], textureCoordinate[1], textureCoordinate[2], textureCoordinate[3]);
1515-
1516-				// Save it.
1517-				NOT_NULL(m_sourceDot3Vectors);
1518-				Dot3Vector &d3v = m_sourceDot3Vectors[vertexIndex];
1519-				d3v.m_dot3Vector.x=textureCoordinate[0];
1520-				d3v.m_dot3Vector.y=textureCoordinate[1];
1521-				d3v.m_dot3Vector.z=textureCoordinate[2];
1522-				d3v.m_flipState   =textureCoordinate[3];
1523-			}	break;
1524-
1525-			default:
1526-				DEBUG_FATAL(true, ("not supported."));
1527-			}
1528-		}
1529-	}
1530-}
