1130:void ShaderPrimitiveSorter::setLights(const LightBitSet &lightBitSet)
1131-{
1132-	ms_activeLightList.clear();	
1133-
1134-	// check all the lights to see which ones are currently active
1135-	const uint offset = ms_lightListStackOffset.back();
1136-	const uint max = ms_lightList.size() - offset;
1137-	for (uint i = 0; i < max; ++i)
1138-		if (lightBitSet[i])
1139-		{
1140-			const Light *light = ms_lightList[offset + i];
1141-			ms_activeLightList.push_back(light);
1142-		}
1143-
1144-	Graphics::setLights(ms_activeLightList);
1145-}
