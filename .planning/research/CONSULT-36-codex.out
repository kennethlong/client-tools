1328:void SoftwareBlendSkeletalShaderPrimitive::buildIndexBufferAndRenderCommands(const MeshConstructionHelper &mesh, int perShaderDataIndex)
1329-{
1330-	//-- get mesh data for this shader
1331-	const MeshConstructionHelper::PerShaderData *const meshPerShaderData = mesh.getPerShaderData(perShaderDataIndex);
1332-
1333-	//-- figure out # indices we need
1334-	const int indexCount = mesh.getNumberOfWeightedPrimitiveIndices(meshPerShaderData);
1335-	m_indexBuffer        = new StaticIndexBuffer(indexCount);
1336-
1337-	//-- reserve space for render commands
1338-	const int triStripCount = mesh.getTriStripCount(meshPerShaderData);
1339:	const int triListCount  = mesh.getTriListCount(meshPerShaderData);
1340-
1341-	m_renderCommands->reserve(static_cast<size_t>(triStripCount + triListCount));
1342-
1343-	//-- populate index buffer and construct primitive rendering commands
1344-	m_indexBuffer->lock();
1345-
1346-	std::vector<IndexedTriangle> tempIndexBuffer;
1347-	tempIndexBuffer.reserve(indexCount);
1348-
1349-		int          currentIndex = 0;
1350-		Index *const indexData    = m_indexBuffer->begin();
1351-
1352-		// handle tri lists
1353-		{
1354-			for (int triListIndex = 0; triListIndex < triListCount; ++triListIndex)
1355-			{
1356-				tempIndexBuffer.clear();
1357-
1358-				//-- Get # triangles in the tri list.
1359:				const MeshConstructionHelper::TriListHeader &triListHeader = mesh.getTriList(meshPerShaderData, triListIndex);
1360:				const int                                    triCount      = mesh.getTriListTriangleCount(triListHeader);
1361-				DEBUG_FATAL(triCount < 1, ("invalid tri count %d", triCount));
1362-
1363-				const int firstTriListIndex = currentIndex;
1364-
1365-				int index[3];
1366-
1367-				//-- initialize vertex buffer index min/max
1368-				Index  minVbIndex;
1369-				Index  maxVbIndex;
1370-				{
1371:					mesh.getTriListTriangle(meshPerShaderData, triListHeader, 0, index[0], index[1], index[2]);
1372-					minVbIndex = static_cast<Index>(index[0]);
1373-					maxVbIndex = static_cast<Index>(index[0]);
1374-				}			
1375-
1376-				//-- copy index data
1377-				for (int triIndex = 0; triIndex < triCount; ++triIndex)
1378-				{
1379-					// Retrieve index values for the tri.
1380:					mesh.getTriListTriangle(meshPerShaderData, triListHeader, triIndex, index[0], index[1], index[2]);
1381-
1382-					tempIndexBuffer.push_back(IndexedTriangle(index[0], index[1], index[2]));
1383-
1384-					// Copy index values into the index buffer.
1385-					for (int triVertIndex = 0; triVertIndex < 3; ++triVertIndex/*, ++currentIndex*/)
1386-					{
1387-						const Index indexValue  = static_cast<Index>(index[triVertIndex]);
1388-
1389-						// keep track of min/max
1390-						minVbIndex = std::min(minVbIndex, indexValue);
1391-						maxVbIndex = std::max(maxVbIndex, indexValue);
1392-					}
1393-				}
1394-
1395-				std::sort(tempIndexBuffer.begin(), tempIndexBuffer.end());
1396-
1397-				for (unsigned i=0;i<tempIndexBuffer.size();i++)
1398-				{
1399-					const IndexedTriangle &itri = tempIndexBuffer[i];
1400-					indexData[currentIndex++] = static_cast<Index>(itri.indeces[0]);
1401-					indexData[currentIndex++] = static_cast<Index>(itri.indeces[1]);
1402-					indexData[currentIndex++] = static_cast<Index>(itri.indeces[2]);
1403-				}
1404-
1405-				//-- create the primitive
1406:				RenderCommand *const renderCommand = RenderCommand::createTriList(static_cast<int>(minVbIndex), static_cast<int>((maxVbIndex - minVbIndex) + 1), firstTriListIndex, triCount);
1407-				m_renderCommands->push_back(renderCommand);
1408-			}
1409-		}
1410-
1411-		// handle tri strips
1412-		{
1413-			for (int triStripIndex = 0; triStripIndex < triStripCount; ++triStripIndex)
1414-			{
1415-				const MeshConstructionHelper::TriStripHeader &triStripHeader = mesh.getTriStrip(meshPerShaderData, triStripIndex);
1416-				const int vertexCount = mesh.getTriStripVertexCount(triStripHeader);
1417-				DEBUG_FATAL(vertexCount < 3, ("invalid vertex count %d", vertexCount));
1418-
1419-				const int firstTriStripIndex = currentIndex;
1420-
1421-				//-- initialize vertex buffer index min/max
1422-				Index  minVbIndex;
1423-				Index  maxVbIndex;
1424-				{
1425-					const int vertexIndex = mesh.getTriStripVertexIndex(triStripHeader, 0);
1426-					minVbIndex = static_cast<Index>(vertexIndex);
1427-					maxVbIndex = static_cast<Index>(vertexIndex);
1428-				}			
1429-
1430-				//-- copy index data
1431-				for (int triStripVertexIndex = 0; triStripVertexIndex < vertexCount; ++triStripVertexIndex, ++currentIndex)
1432-				{
1433-					// copy index values
1434-					const Index indexValue  = static_cast<Index>(mesh.getTriStripVertexIndex(triStripHeader, triStripVertexIndex));
1435-					indexData[currentIndex] = indexValue;
1436-
1437-					// keep track of min/max
1438-					minVbIndex = std::min(minVbIndex, indexValue);
1439-					maxVbIndex = std::max(maxVbIndex, indexValue);
1440-				}
1441-
1442-				//-- create the primitive
