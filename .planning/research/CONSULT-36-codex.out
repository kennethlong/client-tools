1290-struct IndexedTriangle
1291-{
1292-	IndexedTriangle() {}
1293-
1294-	IndexedTriangle(int i_i0, int i_i1, int i_i2)
1295-	{
1296-		indeces[0]=i_i0;
1297-		indeces[1]=i_i1;
1298-		indeces[2]=i_i2;
1299-	}
1300-
1301-	bool operator<(const IndexedTriangle &o) const
1302-	{
1303-		if (indeces[0]<o.indeces[0])
1304-		{
1305-			return true;
1306-		}
1307-		else if (indeces[0]>o.indeces[0])
1308-		{
1309-			return false;
1310-		}
1311-		else if (indeces[1]<o.indeces[1])
1312-		{
1313-			return true;
1314-		}
1315-		else if (indeces[1]>o.indeces[1])
1316-		{
1317-			return false;
1318-		}
1319-		else
1320-		{
1321-			return indeces[2]<o.indeces[2];
1322-		}
1323-
1324-	}
1325-	int indeces[3];
1326-};
