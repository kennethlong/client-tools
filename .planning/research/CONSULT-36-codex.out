643-		if ((moOutlier || s_moLogged < 200) && s_moLogged < 8000)
644-		{
645-			++s_moLogged;
646-			static bool s_moFirst = true;
647-			FILE *moFp = nullptr;
648-			fopen_s(&moFp, "cape-mode-output.txt", s_moFirst ? "wb" : "ab");
649-			s_moFirst = false;
650-			if (moFp)
651-			{
652-				fprintf(moFp, "%s mode=%d vc=%d outIdx=%d dist2=%.0f outPos=[%.1f %.1f %.1f] vert0=[%.1f %.1f %.1f]\n",
653-					moOutlier ? "MODE-OUTLIER" : "ok", static_cast<int>(m_skinningMode), m_vertexCount,
