984:void ShaderPrimitiveSorter::setPhase(Tag tag, int index)
985-{
986-	VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, index, static_cast<int>(ms_phase.size()));
987-
988-	PhaseMap::iterator i = ms_phaseMap.find(tag);
989-	if (i != ms_phaseMap.end())
990-	{
991-		// the the new phase index
992-		i->second = index;
993-	}
994-	else
995-	{
996-		// insert the new descriptor
997-		PhaseMap::value_type entry(tag, index);
998-		std::pair<PhaseMap::iterator, bool> result = ms_phaseMap.insert(entry);
999-		DEBUG_FATAL(!result.second, ("insert() said entry was already there, but find() didn't locate it"));
