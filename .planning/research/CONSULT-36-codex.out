1328-void SoftwareBlendSkeletalShaderPrimitive::buildIndexBufferAndRenderCommands(const MeshConstructionHelper &mesh, int perShaderDataIndex)
1329-{
1330-	//-- get mesh data for this shader
1331-	const MeshConstructionHelper::PerShaderData *const meshPerShaderData = mesh.getPerShaderData(perShaderDataIndex);
1332-
1333-	//-- figure out # indices we need
1334-	const int indexCount = mesh.getNumberOfWeightedPrimitiveIndices(meshPerShaderData);
1335-	m_indexBuffer        = new StaticIndexBuffer(indexCount);
1336-
1337-	//-- reserve space for render commands
1338-	const int triStripCount = mesh.getTriStripCount(meshPerShaderData);
1339-	const int triListCount  = mesh.getTriListCount(meshPerShaderData);
1340-
1341-	m_renderCommands->reserve(static_cast<size_t>(triStripCount + triListCount));
1342-
1343-	//-- populate index buffer and construct primitive rendering commands
1344-	m_indexBuffer->lock();
1345-
1346-	std::vector<IndexedTriangle> tempIndexBuffer;
1347-	tempIndexBuffer.reserve(indexCount);
1348-
1349-		int          currentIndex = 0;
1350-		Index *const indexData    = m_indexBuffer->begin();
1351-
1352-		// handle tri lists
