688-
689:void ShaderPrimitiveSorter::Phase::draw()
690-{
691-#ifdef _DEBUG
692-	if (!m_drawEnable)
693-		return;
694-
695-	PerformanceTimer performanceTimer;
696-	performanceTimer.start();
697-#endif
698-
699:	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::Phase::draw");
700-
701-	ShaderPrimitives::iterator end = m_shaderPrimitives.end();
702-	for (ShaderPrimitives::iterator i = m_shaderPrimitives.begin() + m_stackOffsets.back(); i != end; ++i)
703-	{
704-		Entry const           &entry           = *i;
705-		StaticShader const    &staticShader    = *entry.staticShader;
706-		ShaderPrimitive const &shaderPrimitive = *entry.shaderPrimitive;
707-		bool const alphaFadeOpacityEnabled     = entry.alphaFadeOpacityEnabled;
708-		float const alphaFadeOpacity           = entry.alphaFadeOpacity;
709-		int const              numberOfPasses  = staticShader.getNumberOfPasses();
710-
711-#if PRODUCTION == 0
712-		char const * const typeName = ms_profileByType ? typeid(shaderPrimitive).name() : NULL;
713-		NP_PROFILER_BLOCK_DEFINE(profilerBlockByTime, typeName);
714-		if (typeName)
715-			NP_PROFILER_BLOCK_ENTER(profilerBlockByTime);
716-#endif
717-
718:		ShaderPrimitiveSorter::setLights(i->lightBitSet);
719-
720-#if PRODUCTION == 0
721-		if (ms_profilePrepareToDraw)
722-			NP_PROFILER_BLOCK_ENTER(ms_profilerBlockPrepareToDraw);
723-#endif
724-
725:		shaderPrimitive.prepareToDraw();
726-
727-#if PRODUCTION == 0
728-		if (ms_profilePrepareToDraw)
729-			NP_PROFILER_BLOCK_LEAVE(ms_profilerBlockPrepareToDraw);
730-#endif
731-
732-		Texture * const primaryBuffer = PostProcessingEffectsManager::getPrimaryBuffer();
733-
734-		int const destinationWidth = primaryBuffer ? primaryBuffer->getWidth() : 0;
735-		int const destinationHeight = primaryBuffer ? primaryBuffer->getHeight() : 0;
736-
737-		int sectionRectX0 = 0;
738-		int sectionRectY0 = 0;
739-		int sectionRectX1 = destinationWidth;
740-		int sectionRectY1 = destinationHeight;
741-		
742-		Graphics::setAlphaFadeOpacity(alphaFadeOpacityEnabled, alphaFadeOpacity);
743-		
744-		for (int i = 0; i < numberOfPasses; ++i)
745-		{
746-			Graphics::setStaticShader(staticShader, i);
747-						
748-			bool const isHeat = entry.staticShader->isHeatPass(i);
749-			
750-			if (isHeat)
751-			{
752-				if (!ms_heatShadersEnabled)
753-				{
754-					continue;
755-				}
756-				
757-#if PRODUCTION == 0
758-				if (ms_profileDraw)
759-					NP_PROFILER_BLOCK_ENTER(ms_profilerBlockCompositeStart);
760-#endif
761-				
762-				bool const result = startCompositing(shaderPrimitive, sectionRectX0, sectionRectY0, sectionRectX1, sectionRectY1);
763-				
764-#if PRODUCTION == 0
765-				if (ms_profileDraw)
766-					NP_PROFILER_BLOCK_LEAVE(ms_profilerBlockCompositeStart);
767-#endif
768-				
769-				if (!result)
770-					continue;
771-
772-				Graphics::setAlphaFadeOpacity(false, alphaFadeOpacity);
773-			}
774-			
775-			
776-#if PRODUCTION == 0
777-			if (ms_profileDraw)
778-				NP_PROFILER_BLOCK_ENTER(ms_profilerBlockDraw);
779-#endif
780-
781:			shaderPrimitive.draw();
782-			
783-#if PRODUCTION == 0
784-			if (ms_profileDraw)
785-				NP_PROFILER_BLOCK_LEAVE(ms_profilerBlockDraw);
786-#endif
787-
788-			if (isHeat)
789-			{
790-				//-- @todo: this should probably be specified by the shader primitive's shader
791-				StaticShader * const compositingShader = PostProcessingEffectsManager::getHeatCompositingShader();
792-				
793-				if (compositingShader)
794-				{
795-
796-#if PRODUCTION == 0
797-				if (ms_profileDraw)
798-					NP_PROFILER_BLOCK_ENTER(ms_profilerBlockCompositeFinish);
799-#endif
800-					
801-					finishCompositing(sectionRectX0, sectionRectY0, sectionRectX1, sectionRectY1, *compositingShader);
802-
803-#if PRODUCTION == 0
804-				if (ms_profileDraw)
805-					NP_PROFILER_BLOCK_LEAVE(ms_profilerBlockCompositeFinish);
806-#endif
807-
808-				}
809-				
810-			}
811-		}
812-		
813-#if PRODUCTION == 0
814-		if (typeName)
815-			NP_PROFILER_BLOCK_LEAVE(profilerBlockByTime);
816-#endif
817-	}
818-
819-	Graphics::setAlphaFadeOpacity(false, 1.0f);
820-
821-#ifdef _DEBUG
822-	performanceTimer.stop();
823-	m_frameDrawTime += performanceTimer.getElapsedTime ();
824-#endif
825-}
