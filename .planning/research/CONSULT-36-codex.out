721-/**
722- * Calculate the bounding box coordinates for this blended mesh.
723- *
724- * Since this instance represents a mesh that is modified by transforms,
725- * the bounding box will necessarily change when the transforms change.
726- * Therefore, it makes no sense for this instance to try to cache this
727- * data internally.  Users of this class that want a cheap bounding box
728- * calculation will need to be smart about (1) how accurate the bounding
729- * box must be and (2) how often they need to run over this data to
730- * caculate it.
731- *
732- * Performance side-effects: this function will force the skeleton to evaluate 
733- * its transforms if that event hasn't already happened.
734- *
735- * @param minVector  the minimum x, y and z value for the bounding box
736- *                   are returned in this vector.
737- * @param maxVector  the maximum x, y and z value for the bounding box
738- *                   are returned in this vector.
739- */
740-
741-void SoftwareBlendSkeletalShaderPrimitive::calculateBoundingBox(Vector &minVector, Vector &maxVector) const
742-{
743-	//-- initialize min and max value
744-	minVector.set(std::numeric_limits<float>::max(), std::numeric_limits<float>::max(), std::numeric_limits<float>::max());
745-	maxVector.set(-std::numeric_limits<float>::max(), -std::numeric_limits<float>::max(), -std::numeric_limits<float>::max());
746-
747-	//-- get the current transform data from the appearance
748-	const Skeleton &skeleton = m_appearance.getSkeleton(m_lodIndex);
749-
750-#ifdef _DEBUG
751-	const int              transformCount = skeleton.getTransformCount();
752-#endif
753-	const PoseModelTransform *const transformArray = skeleton.getBindPoseModelToRootTransforms();
754-	NOT_NULL(transformArray);
755-
756-	const TransformData *transformData = m_transformData;
757-
758-	//-- calculate transformed xyz, track min and max
759-	for (int vertexIndex = 0; vertexIndex < m_vertexCount; ++vertexIndex)
760-	{
761-		const SourceVertex &sourceVertex = m_sourceVectors[vertexIndex];
762-		const Vector &sourcePosition     = sourceVertex.m_position;
763-
764-		//-- initialize first position with first influencing transform
765-		const TransformData &firstTransformData = sourceVertex.m_firstTransformData;
766-		VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, firstTransformData.m_transformIndex, transformCount);
767-
768-		const PoseModelTransform &firstTransform = transformArray[firstTransformData.m_transformIndex];
769-
770-		Vector blendPosition = firstTransform.rotateTranslate_l2p(sourcePosition) * firstTransformData.m_transformWeight;
771-
772-		//-- apply remaining transforms
773-		for (int j=sourceVertex.m_extraTransformDataCount;j>0;j--, transformData++)
774-		{
775-			// get transform data
776-			VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformData->m_transformIndex, transformCount);
777-
778-			// apply it
779-			const PoseModelTransform &transform = transformArray[transformData->m_transformIndex];
780-
781-			blendPosition += transform.rotateTranslate_l2p(sourcePosition) * transformData->m_transformWeight;
782-		}
783-
--
