623-	// CAPE-MODE-OUTPUT PROBE 2026-06-07 (diagnostic): read the skinned OUTPUT (m_systemStream, written by
624-	// EITHER the soft fill OR the hard SSE fill) and log the ACTUAL skinning MODE + the farthest outlier
625-	// vert. Answers definitively what mode the spiking creature is in and whether its skinned output is
626-	// displaced -- without guessing the mode or instrumenting SSE. Guarded like collide() against a freed
627-	// stream (getNumberOfVertices()==m_vertexCount). Writes stage/cape-mode-output.txt.
628-	if (m_systemStream && (m_systemStream->getNumberOfVertices() == m_vertexCount) && (m_vertexCount >= 32))
629-	{
630-		VertexBufferReadIterator rit = m_systemStream->begin();
631-		Vector const moP0 = rit.getPosition();
632-		float moMaxD2 = 0.f; int moMaxI = 0; Vector moMaxP = moP0;
633-		for (int moV = 1; moV < m_vertexCount; ++moV)
634-		{
635-			++rit;
636-			Vector const moP = rit.getPosition();
637-			float const moDx = moP.x-moP0.x, moDy = moP.y-moP0.y, moDz = moP.z-moP0.z;
