1334:void ShaderPrimitiveSorter::pushCell(CellProperty const * cellProperty, Texture const * environmentTexture, bool fogEnabled, float fogDensity, PackedArgb const & fogColor)
1335-{
1336:	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::pushCell");
1337-
1338-#ifdef _DEBUG
1339-	{
1340-		const int count = static_cast<int>(ms_phase.size());
1341-		for (int i = 0; i < count; ++i)
1342-			if (ms_phase[i].getDrawEnable() != ms_debugPhase[i].enabled)
1343-				ms_phase[i].setDrawEnable(ms_debugPhase[i].enabled);
1344-	}
1345-#endif
1346-
1347-	ms_pixelsCompositedThisFrame = 0;
1348-	ms_compositePasses = 0;
1349-
1350-	if (!ms_popped && !ms_cellPropertyStack.empty() && ms_cellPropertyStack.back())
1351-		ms_cellPropertyStack.back()->callPreDrawRenderHookFunctions();
1352-
1353-	// tell all the phases we're pushing
1354-	{
1355-		const int count = static_cast<int>(ms_phase.size());
1356-		for (int i = 0; i < count; ++i)
1357-			ms_phase[i].pushCell();
1358-	}
1359-
1360-	ms_environmentTextures.push_back(environmentTexture ? environmentTexture : ms_defaultEnvironmentTexture);
1361-	ms_fogStack.push_back(FogData(fogEnabled, fogDensity, fogColor));
1362-
1363-	Graphics::setGlobalTexture(TAG_ENVM, *ms_environmentTextures.back());
1364-	Graphics::setFog(fogEnabled, fogDensity, fogColor);
1365-
1366-	// preserve all the lights in the current cell
1367-	ms_lightListStackOffset.push_back(ms_lightList.size());
1368-
1369-	// empty out the light bits for the new cell
1370-	ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting.reset();
1371-	ms_lightsAffectingShadersWithPrecalculatedVertexLighting.reset();
1372-
1373-	ms_cellPropertyStack.push_back(cellProperty);
1374-	if (cellProperty)
1375-		cellProperty->callEnterRenderHookFunctions();
1376-
1377-	ms_popped = false;
1378-
1379-#ifdef _DEBUG
1380-	ms_lightListOverflow = false;
1381-#endif
1382-}
