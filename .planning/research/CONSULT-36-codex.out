1153-
1154:void ShaderPrimitiveSorter::add(const ShaderPrimitive &shaderPrimitive)
1155-{
1156:	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple");
1157-
1158-	DEBUG_FATAL(ms_popped, ("Adding primitives after cell popped"));
1159-	const StaticShader &staticShader = ms_prepareToViewFunction(shaderPrimitive);
1160-
1161-	// this may be true when the shader has failed validation because of a lost device
1162-	if (!staticShader.isValid())
1163-		return;
1164-
1165-	if (ms_useClipRectangle)
1166-	{
1167:		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple test clipRectangle");
1168-
1169-		Vector const & pos_w = shaderPrimitive.getPosition_w();
1170-		float const radius = shaderPrimitive.getRadius();
1171-
1172-		if (radius > 0.0f)
1173-		{
1174-			Rectangle2d const shaderPrimitiveRectangle(pos_w.x - radius, pos_w.z - radius, pos_w.x + radius, pos_w.z + radius);
1175-			if (!ms_clipRectangle.intersects(shaderPrimitiveRectangle))
1176-			{
1177-				return;
1178-			}
1179-		}
1180-	}
1181-
1182-	int phase = staticShader.getPhase();
1183-	DEBUG_FATAL(phase < 0 || phase >= static_cast<int>(ms_phase.size()), ("Invalid phase %d/%d", phase, ms_phase.size()));
1184-
1185-	//-- see if the primitive is supposed to be affected by water
1186-	if (ms_useWaterTests && phase == ms_belowTransparentWaterTestPhase && ms_belowTransparentWaterFunction)
1187-	{
1188:		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple test below water");
1189-		if (ms_belowTransparentWaterFunction (shaderPrimitive.getPosition_w()))
1190-			phase = ms_belowTransparentWaterPhase;
1191-		else
1192-			phase = ms_aboveWaterPhase;
1193-	}
1194-
1195-	{
1196:		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple insertion");
1197-
1198-		if (staticShader.containsPrecalculatedVertexLighting())
1199-			ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1200-		else
1201-			ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1202-	}
1203-}
