589-//----------------------------------------------------------------------
590-
591:bool ShaderPrimitiveSorter::startCompositing(ShaderPrimitive const & shaderPrimitive, int & sectionRectX0, int & sectionRectY0, int & sectionRectX1, int & sectionRectY1)
592-{
593-	static int const s_minimumCompositeArea = 200;
594-	static int const s_maximumCompositeDistance = 100;
595-
596-	Texture * const primaryBuffer = PostProcessingEffectsManager::getPrimaryBuffer();
597-	Texture * const heatBuffer = PostProcessingEffectsManager::getTertiaryBuffer();
598-	
599-	if (!heatBuffer || !primaryBuffer)
600-		return false;
601-	
602:	//-- if we are showing debug heat shaders, just render them normally
603-	if (ms_showDebugHeatShaders)
604-		return true;
605-	
606:	//-- don't do any special heat rendering
607-	if (ms_debugDisableHeatShaders)
608-		return false;				
609-	
610-	int sectionRectWidth = sectionRectX1 - sectionRectX0;
611-	int sectionRectHeight = sectionRectY1 - sectionRectY0;
612-
613-	//Sphere const cameraCompositeDistanceSphere_c(Vector::zero, s_maximumCompositeDistance);
614-
615:	//-- calculate the screen size of the primitive, so we can render as little as possible
616-	Vector screenPos;				
617-	Vector const shaderPrimitivePos_c = ms_currentCamera->rotateTranslate_p2o(shaderPrimitive.getPosition_w());
618-	
619-	//-- The various shader primitives need to implement radius for this to work.
620-	//-- If you are having problems with heat shimmer not appearing, make sure your shader primitive has a radius
621-	float shaderPrimitiveRadius = shaderPrimitive.getRadius();
622-
623-	if ((shaderPrimitivePos_c.magnitude() - shaderPrimitiveRadius) > s_maximumCompositeDistance)
624-		return false;
625-	
626-	float screenRadiusInPixels = 0.0f;
627-	ms_currentCamera->computeRadiusInScreenSpace(shaderPrimitivePos_c, shaderPrimitiveRadius, screenRadiusInPixels);
628-
629-	int const destinationWidth = primaryBuffer->getWidth();
630-	int const destinationHeight = primaryBuffer->getHeight();
631-	
632-	//-- inside the sphere
633-	if (ms_currentCamera->getPosition_w().magnitudeBetweenSquared(shaderPrimitive.getPosition_w()) < sqr(shaderPrimitiveRadius))
634-	{
635-		sectionRectX0 = 0;
636-		sectionRectY0 = 0;
637-		sectionRectX1 = destinationWidth;
638-		sectionRectY1 = destinationHeight;
639-	}	
640-	
641-	else if (ms_currentCamera->projectInWorldSpace(shaderPrimitive.getPosition_w(), &screenPos.x, &screenPos.y, NULL, false))
642-	{
643-		screenPos.x = clamp(0.0f, screenPos.x, static_cast<float>(destinationWidth));
644-		screenPos.y = clamp(0.0f, screenPos.y, static_cast<float>(destinationHeight));
645-		sectionRectX0 = clamp(0, static_cast<int>(screenPos.x - screenRadiusInPixels), destinationWidth);
646-		sectionRectY0 = clamp(0, static_cast<int>(screenPos.y - screenRadiusInPixels), destinationHeight);
647-		sectionRectX1 = clamp(0, static_cast<int>(screenPos.x + screenRadiusInPixels), destinationWidth);
648-		sectionRectY1 = clamp(0, static_cast<int>(screenPos.y + screenRadiusInPixels), destinationHeight);
649-	}
650-
651-	sectionRectWidth = sectionRectX1 - sectionRectX0;
652-	sectionRectHeight = sectionRectY1 - sectionRectY0;
653-
654-	/*
655-
656-	//-- squash rects for visualization
657-	sectionRectX0 += sectionRectWidth / 4;
658-	sectionRectX1 -= sectionRectWidth / 4;
659-	sectionRectY0 += sectionRectHeight / 4;
660-	sectionRectY1 -= sectionRectHeight / 4;
661-
662-	sectionRectWidth = sectionRectX1 - sectionRectX0;
663-	sectionRectHeight = sectionRectY1 - sectionRectY0;
664-*/
665-
666-	if (sectionRectWidth == 0 || sectionRectHeight == 0)
667-		return false;		
668-
669-	if (sectionRectWidth * sectionRectHeight < s_minimumCompositeArea)
670-		return false;
671-	
672:	//-- setup the heat buffer render
673-	Graphics::setRenderTarget(heatBuffer, CF_none, 0);
674-	Graphics::setViewport(0, 0, destinationWidth, destinationHeight, 0.0f, 1.0f);
675-	
676-	Graphics::setScissorRect(true, sectionRectX0, sectionRectY0, sectionRectWidth, sectionRectHeight);
677-	Graphics::setViewport(sectionRectX0, sectionRectY0, sectionRectWidth, sectionRectHeight, 0.0f, 1.0f);
678-	Graphics::clearViewport(true, 0, false, 1.0f, false, 0);
679-	Graphics::setViewport(0, 0, destinationWidth, destinationHeight, 0.0f, 1.0f);
680-	
681:	//-- don't use alpha fade when rendering heat objects
682-	Graphics::setAlphaFadeOpacity(false, 1.0f);
683-
684-	return true;
685-}
