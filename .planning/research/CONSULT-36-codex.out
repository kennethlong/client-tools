1176-		}
1177-	}
1178-	const int transformDataSize = numberOfExtraTransformWeightPairs * sizeof(TransformData);
1179-	alloc_size += transformDataSize;
1180-	/////////////////////////////////////////////////////////////////////////////////////////
1181-
1182-	/////////////////////////////////////////////////////////////////////////////////////////
1183-	// alloc data block and partition
