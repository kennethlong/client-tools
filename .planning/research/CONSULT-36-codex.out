3273-/**
3274- * Draw an indexed line strip.
3275- *
3276- * baseIndex lets you slide the indices around within a VB without touching all the indices.  This
3277- * value is effectively added to all vertex indices before they are used.
3278- *
3279- * minimumVertexIndex and numberOfVertices specifies the span of vertices in the vertex
3280- * buffer that may be used while drawing.  The actual usable vertices from the vertex buffer
3281- * are from [baseIndex + minimumVertexIndex] to [baseIndex + minimumVertexIndex + numberOfVertices - 1] inclusive.
3282- *
3283- * @param baseIndex           The value to add to all indices before selecting the vertex.
3284- * @param minimumVertexIndex  The minimum index specified in the index list.
3285- * @param numberOfVertices    The range of vertices that may be referenced.
3286- * @param startIndex          The first index in the index buffer to render with.
3287- * @param primitiveCount      The number of primitives to draw.
3288- */
3289-
3290-void Graphics::drawIndexedLineStrip(int baseIndex, int minimumVertexIndex, int numberOfVertices, int startIndex, int primitiveCount)
3291-{
3292-	predrawCheck();
3293-	if (ms_shaderValidated)
3294-		ms_api->drawPartialIndexedLineStrip(baseIndex, minimumVertexIndex, numberOfVertices, startIndex, primitiveCount);
3295-}
