960-void SoftwareBlendSkeletalShaderPrimitive::calculateSkinnedGeometryNow()
961-{
962-	//-- Get skeleton transform data.
963-	const Skeleton        &skeleton                 = m_appearance.getSkeleton(m_lodIndex);
964-	const PoseModelTransform *const transformArray  = skeleton.getBindPoseModelToRootTransforms();
965-	NOT_NULL(transformArray);
966-	const int              transformCount     = skeleton.getTransformCount();
967-
968-	const TransformData *transformData        = m_transformData;
969-
970-	UNREF(transformCount);
971-
972-	//-- fill xyz and normal
973-	for (int i = 0; i < m_vertexCount; ++i)
974-	{
975-		const SourceVertex  &sourceVertex   = m_sourceVectors[i];
976-		const Vector        &sourcePosition = sourceVertex.m_position;
977-
978-		// initialize first position and vector
979-		const TransformData &firstTransformData = sourceVertex.m_firstTransformData;
980-		VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, firstTransformData.m_transformIndex, transformCount);
981-		const PoseModelTransform  &firstTransform = transformArray[firstTransformData.m_transformIndex];
982-
983-		Vector blendPosition = firstTransform.rotateTranslate_l2p(sourcePosition) * firstTransformData.m_transformWeight;
984-
985-		// apply remaining transforms
986-		for (int j=sourceVertex.m_extraTransformDataCount;j>0;j--, transformData++)
987-		{
988-			// get transform data
989-			VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformData->m_transformIndex, transformCount);
990-
991-			// apply it
992-			const PoseModelTransform &transform = transformArray[transformData->m_transformIndex];
993-			blendPosition += transform.rotateTranslate_l2p(sourcePosition) * transformData->m_transformWeight;
994-		}
995-	}
