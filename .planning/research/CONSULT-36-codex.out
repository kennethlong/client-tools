1110-
1111:void ShaderPrimitiveSorter::disableLight(const Light &light)
1112-{
1113-	DEBUG_FATAL(ms_popped, ("Disabling a light after cell popped"));
1114-
1115-	const int index = light.getShaderPrimitiveSorterLightIndex();
1116-	if (index >= 0)
1117-	{
1118-		DEBUG_FATAL(index >= static_cast<int>(ms_lightList.size() - ms_lightListStackOffset.back()), ("Light index out of range"));
1119-		ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting.reset(static_cast<size_t>(index));
1120-		ms_lightsAffectingShadersWithPrecalculatedVertexLighting.reset(static_cast<size_t>(index));
1121-	}
1122-	else
1123-	{
1124-		DEBUG_FATAL(!ms_lightListOverflow, ("Disabling a light that was never enabled"));
1125-	}
1126-}
