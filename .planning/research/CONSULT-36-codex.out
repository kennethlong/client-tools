502-
503:void ShaderPrimitiveSorter::finishCompositing(int sectionRectX0, int sectionRectY0, int sectionRectX1, int sectionRectY1, StaticShader & compositingShader)
504-{
505-	Graphics::setScissorRect(false, sectionRectX0, sectionRectY0, sectionRectX1 - sectionRectX0, sectionRectY1 - sectionRectY0);
506-
507-	Texture * const primaryBuffer = PostProcessingEffectsManager::getPrimaryBuffer();
508-	Texture * const secondaryBuffer = PostProcessingEffectsManager::getSecondaryBuffer();
509-	Texture * const heatBuffer = PostProcessingEffectsManager::getTertiaryBuffer();
510-
511-	if (ms_showDebugHeatShaders || ms_debugDisableHeatShaders || !ms_heatShadersEnabled || !heatBuffer || !primaryBuffer)
512-		return;
513-
514-	int const sectionRectWidth = sectionRectX1 - sectionRectX0;
515-	int const sectionRectHeight = sectionRectY1 - sectionRectY0;
516-
517-	ms_pixelsCompositedThisFrame += sectionRectWidth * sectionRectHeight;
518-	++ms_compositePasses;
519-
520-	//-- create vertex buffer used for compositing
521-	VertexBufferFormat format;
522-	format.setPosition ();
523-	format.setTransformed ();
524-	format.setNumberOfTextureCoordinateSets(1);
525-	format.setTextureCoordinateSetDimension(0, 2);
526-	DynamicVertexBuffer vertexBuffer (format);
527-	
528-	int const destinationWidth = primaryBuffer->getWidth();
529-	int const destinationHeight = primaryBuffer->getHeight();
530-	float const fWidth = static_cast<float>(destinationWidth);
531-	float const fHeight = static_cast<float>(destinationHeight);
532-	
533-	Rectangle2d const rect(static_cast<float>(sectionRectX0), static_cast<float>(sectionRectY0), static_cast<float>(sectionRectX1), static_cast<float>(sectionRectY1));
534-	Rectangle2d const uvs(rect.x0 / fWidth, rect.y0 / fHeight, rect.x1 / fWidth, rect.y1 / fHeight);
535-	
536-	vertexBuffer.lock (4);
537-	{
538-		VertexBufferWriteIterator v = vertexBuffer.begin ();
539-		
540-		v.setPosition (Vector (rect.x0 - 0.5f, rect.y0 - 0.5f, 1.f));
541-		v.setOoz (1.f);
542-		v.setTextureCoordinates(0, uvs.x0, uvs.y0);
543-		++v;
544-		
545-		v.setPosition (Vector (rect.x1 - 0.5f, rect.y0 - 0.5f, 1.f));
546-		v.setOoz (1.f);
547-		v.setTextureCoordinates(0, uvs.x1, uvs.y0);
548-		++v;
549-		
550-		v.setPosition (Vector (rect.x1 - 0.5f, rect.y1 - 0.5f, 1.f));
551-		v.setOoz (1.f);
552-		v.setTextureCoordinates(0, uvs.x1, uvs.y1);
553-		++v;
554-		
555-		v.setPosition (Vector (rect.x0 - 0.5f, rect.y1 - 0.5f, 1.f));
556-		v.setOoz (1.f);
557-		v.setTextureCoordinates(0, uvs.x0, uvs.y1);
558-	}
559-	vertexBuffer.unlock ();
560-	
561-	//-- temporarily disable FOG
562-	bool fogEnabled = false;
563-	float fogDensity = 0.0f;
564-	PackedArgb fogColor;
565-	Graphics::getFog(fogEnabled, fogDensity, fogColor);
566-	Graphics::setFog(false, fogDensity, fogColor);
567-
568-	//-- copy the original region
569-	secondaryBuffer->copyFrom(0, *primaryBuffer, 
570-		sectionRectX0, sectionRectY0, sectionRectWidth, sectionRectHeight, 
571-		sectionRectX0, sectionRectY0, sectionRectWidth, sectionRectHeight);
572-
573-	Graphics::setRenderTarget(primaryBuffer, CF_none, 0);
574-	compositingShader.setTexture(TAG(M,A,I,N), *secondaryBuffer);
575-	compositingShader.setTexture(TAG(H,E,A,T), *heatBuffer);
576-	Graphics::setStaticShader(compositingShader);
577-	VectorRgba const pixelShaderUserConstants(ms_elapsedTime, ms_showDebugHeatShaderRects ? 1.0f : 0.0f, 0.0f, 0.0f);
578-	Graphics::setPixelShaderUserConstants(&pixelShaderUserConstants, 1);
579-	Graphics::setObjectToWorldTransformAndScale(Transform::identity, Vector::xyz111);
580-	Graphics::setVertexBuffer(vertexBuffer);
581-
582-	Graphics::drawTriangleFan();
583-			
584-	//-- re-enable the fog
585-	Graphics::setFog(fogEnabled, fogDensity, fogColor);
586-	
587-}
