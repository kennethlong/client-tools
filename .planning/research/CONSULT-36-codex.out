604-			// Compute and fill the system vertex buffer with skinned data.  The system vertex buffer
605-			// also stores any non-skinned (static) data (e.g. UVs, color).
606-			VertexBufferWriteIterator  writeIterator = m_systemStream->beginWriteOnly();
607-			skinData(transformCount, transformArray, writeIterator);
608-
609-			// Copy the system vertex buffer in one chunk into the dynamic vertex buffer that we render with.
610-			// This is how the geometry gets into a buffer readable by the GPU.  We can't render out of system
611-			// VBs, we don't want to store a GPU-renderable VB for every shader prim, and we do want a fast
612-			// single mem copy into the destination dynamic VB.  This is the solution: tradeoff memory by using
613-			// a fixed system VB for each shader prim.
614-			m_dynamicStream->lock(m_vertexCount);
615-			{
616-				VertexBufferWriteIterator outIt = m_dynamicStream->begin();
617-				outIt.copy(m_systemStream->beginReadOnly(), m_systemStream->getNumberOfVertices());
618-			}
619-			m_dynamicStream->unlock();
620-		}
621-	}
