1080:void ShaderPrimitiveSorter::enableLight(const Light &light)
1081-{
1082-	DEBUG_FATAL(ms_popped, ("Enabling a light after cell popped"));
1083-
1084-	int index = light.getShaderPrimitiveSorterLightIndex();
1085-	if (index < 0)
1086-	{
1087-		index = static_cast<int>(ms_lightList.size() - ms_lightListStackOffset.back());
1088-		if (index >= MAX_NUMBER_OF_LIGHTS)
1089-		{
1090-#ifdef _DEBUG
1091-			WARNING(!ms_lightListOverflow, ("too many lights"));
1092-			ms_lightListOverflow = true;
1093-#endif
1094-			return;
1095-		}
1096-		
1097-		ms_lightList.push_back(&light);
1098-		light.setShaderPrimitiveSorterLightIndex(index);
1099-	}
1100-
1101-	DEBUG_FATAL(index >= static_cast<int>(ms_lightList.size() - ms_lightListStackOffset.back()), ("Light index out of range"));
1102-
1103-	if (light.affectsShadersWithoutPrecalculatedVertexLighting())
1104-		ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting.set(static_cast<size_t>(index));
1105-	if (light.affectsShadersWithPrecalculatedVertexLighting())
1106-		ms_lightsAffectingShadersWithPrecalculatedVertexLighting.set(static_cast<size_t>(index));
1107-}
1108-
