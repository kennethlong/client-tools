1148-/**
1149- * Add a primitive to its appropriate phase.
1150- *
1151- * @param shaderPrimitive The primitive to be added.
1152- */
1153-
1154:void ShaderPrimitiveSorter::add(const ShaderPrimitive &shaderPrimitive)
1155-{
1156-	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple");
1157-
1158-	DEBUG_FATAL(ms_popped, ("Adding primitives after cell popped"));
1159-	const StaticShader &staticShader = ms_prepareToViewFunction(shaderPrimitive);
1160-
1161-	// this may be true when the shader has failed validation because of a lost device
1162-	if (!staticShader.isValid())
1163-		return;
1164-
1165-	if (ms_useClipRectangle)
1166-	{
1167-		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple test clipRectangle");
1168-
1169-		Vector const & pos_w = shaderPrimitive.getPosition_w();
1170-		float const radius = shaderPrimitive.getRadius();
1171-
1172-		if (radius > 0.0f)
1173-		{
1174-			Rectangle2d const shaderPrimitiveRectangle(pos_w.x - radius, pos_w.z - radius, pos_w.x + radius, pos_w.z + radius);
1175-			if (!ms_clipRectangle.intersects(shaderPrimitiveRectangle))
1176-			{
1177-				return;
1178-			}
1179-		}
1180-	}
1181-
1182-	int phase = staticShader.getPhase();
1183-	DEBUG_FATAL(phase < 0 || phase >= static_cast<int>(ms_phase.size()), ("Invalid phase %d/%d", phase, ms_phase.size()));
1184-
1185-	//-- see if the primitive is supposed to be affected by water
1186-	if (ms_useWaterTests && phase == ms_belowTransparentWaterTestPhase && ms_belowTransparentWaterFunction)
1187-	{
1188-		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple test below water");
1189-		if (ms_belowTransparentWaterFunction (shaderPrimitive.getPosition_w()))
1190-			phase = ms_belowTransparentWaterPhase;
1191-		else
1192-			phase = ms_aboveWaterPhase;
1193-	}
1194-
1195-	{
1196-		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add simple insertion");
1197-
1198-		if (staticShader.containsPrecalculatedVertexLighting())
1199-			ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1200-		else
1201-			ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1202-	}
1203-}
1204-
1205-// ----------------------------------------------------------------------
1206-/**
1207- * Add a primitive to a specific phase.
1208- *
1209- * @param shaderPrimitive The primitive to be added.
1210- * @param phase The phase index
1211- */
1212-
1213:void ShaderPrimitiveSorter::add(const ShaderPrimitive &shaderPrimitive, const int phase)
1214-{
1215-	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add");
1216-
1217-	if (ms_useClipRectangle)
1218-	{
1219-		Vector const & pos_w = shaderPrimitive.getPosition_w();
1220-		float const radius = shaderPrimitive.getRadius();
1221-
1222-		if (radius > 0.0f)
1223-		{
1224-			Rectangle2d const shaderPrimitiveRectangle(pos_w.x - radius, pos_w.z - radius, pos_w.x + radius, pos_w.z + radius);
1225-			if (!ms_clipRectangle.intersects(shaderPrimitiveRectangle))
1226-			{
1227-				return;
1228-			}
1229-		}
1230-	}
1231-
1232-	DEBUG_FATAL(ms_popped, ("Adding primitives after cell popped"));
1233-	StaticShader const & staticShader = ms_prepareToViewFunction(shaderPrimitive);
1234-	DEBUG_FATAL(phase < 0 || phase >= static_cast<int>(ms_phase.size()), ("Invalid phase %d/%d", phase, ms_phase.size()));
1235-
1236-	if (staticShader.containsPrecalculatedVertexLighting())
1237-		ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1238-	else
1239-		ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1240-}
1241-
1242-// ----------------------------------------------------------------------
1243-/**
1244- * Add a primitive to its appropriate phase.
1245- *
1246- * @param shaderPrimitive The primitive to be added.
1247- */
1248-
1249:void ShaderPrimitiveSorter::addWithAlphaFadeOpacity(const ShaderPrimitive &shaderPrimitive, bool opaqueEnable, float opaqueAlpha, bool alphaEnable, float alphaAlpha)
1250-{
1251-	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add alphaflags");
1252-
1253-	UNREF(alphaAlpha);
1254-
1255-	DEBUG_FATAL(ms_popped, ("Adding primitives after cell popped"));
1256-	StaticShader const & staticShader = ms_prepareToViewFunction(shaderPrimitive);
1257-
1258-	// this may be true when the shader has failed validation because of a lost device
1259-	if (!staticShader.isValid())
1260-		return;
1261-
1262-	int phase = staticShader.getPhase();
1263-	DEBUG_FATAL(phase < 0 || phase >= static_cast<int>(ms_phase.size()), ("Invalid phase %d/%d", phase, ms_phase.size()));
1264-
1265-	float alphaFadeOpacity = 1.0f;
1266-	if (phase == 3) // Main phase
1267-	{
1268-		if (!opaqueEnable)
1269-		{
1270-			if (staticShader.containsPrecalculatedVertexLighting())
1271-				ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1272-			else
1273-				ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1274-			return;
1275-		}
1276-
1277-		alphaFadeOpacity = opaqueAlpha;
1278-		phase = 6;
1279-	}
1280-	else
1281-		if (phase == 5 || phase == 6) // Alpha/Blend/PreAlpha phases.
1282-		{
1283-			if (!alphaEnable)
1284-			{
1285-				if (staticShader.containsPrecalculatedVertexLighting())
1286-					ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1287-				else
1288-					ms_phase[phase].add(shaderPrimitive, staticShader, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1289-				return;
1290-			}
1291-
1292-			alphaFadeOpacity = alphaAlpha;
1293-		}
1294-
1295-	//-- see if the primitive is supposed to be affected by water
1296-	if (ms_useWaterTests && ms_belowTransparentWaterFunction && phase == ms_belowTransparentWaterTestPhase)
1297-	{
1298-		NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add alphaflags test below water");
1299-		
1300-		if (ms_belowTransparentWaterFunction(shaderPrimitive.getPosition_w()))
1301-			phase = ms_belowTransparentWaterPhase;
1302-		else
1303-			phase = ms_aboveWaterPhase;
1304-	}
1305-
1306-	if (staticShader.containsPrecalculatedVertexLighting())
1307-		ms_phase[phase].addWithAlphaFadeOpacity(shaderPrimitive, staticShader, alphaFadeOpacity, ms_lightsAffectingShadersWithPrecalculatedVertexLighting);
1308-	else
1309-		ms_phase[phase].addWithAlphaFadeOpacity(shaderPrimitive, staticShader, alphaFadeOpacity, ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting);
1310-}
1311-
1312-// ----------------------------------------------------------------------
1313-/**
1314- * Add a primitive with a specific set of active lights to its appropriate phase.
1315- *
1316- * @param shaderPrimitive The primitive to be added.
1317- * @param lightBitSet     The set of active lights for this primitive.
1318- */
1319-
1320:void ShaderPrimitiveSorter::add(const ShaderPrimitive &shaderPrimitive, const LightBitSet &lightBitSet)
1321-{
1322-	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::add lightbitset");
1323-	
1324-	DEBUG_FATAL(ms_popped, ("Adding primitives after cell popped"));
1325-	StaticShader const & staticShader = ms_prepareToViewFunction(shaderPrimitive);
1326-	const int phase = staticShader.getPhase();
1327-	DEBUG_FATAL(phase < 0 || phase >= static_cast<int>(ms_phase.size()), ("Invalid phase %d/%d", phase, ms_phase.size()));
1328-
1329-	ms_phase[phase].add(shaderPrimitive, staticShader, lightBitSet);
1330-}
1331-
1332-// ----------------------------------------------------------------------
1333-
1334:void ShaderPrimitiveSorter::pushCell(CellProperty const * cellProperty, Texture const * environmentTexture, bool fogEnabled, float fogDensity, PackedArgb const & fogColor)
1335-{
1336-	NP_PROFILER_AUTO_BLOCK_DEFINE("ShaderPrimitiveSorter::pushCell");
1337-
1338-#ifdef _DEBUG
1339-	{
1340-		const int count = static_cast<int>(ms_phase.size());
1341-		for (int i = 0; i < count; ++i)
1342-			if (ms_phase[i].getDrawEnable() != ms_debugPhase[i].enabled)
1343-				ms_phase[i].setDrawEnable(ms_debugPhase[i].enabled);
1344-	}
1345-#endif
1346-
1347-	ms_pixelsCompositedThisFrame = 0;
1348-	ms_compositePasses = 0;
1349-
1350-	if (!ms_popped && !ms_cellPropertyStack.empty() && ms_cellPropertyStack.back())
1351-		ms_cellPropertyStack.back()->callPreDrawRenderHookFunctions();
1352-
1353-	// tell all the phases we're pushing
1354-	{
1355-		const int count = static_cast<int>(ms_phase.size());
1356-		for (int i = 0; i < count; ++i)
1357-			ms_phase[i].pushCell();
1358-	}
1359-
1360-	ms_environmentTextures.push_back(environmentTexture ? environmentTexture : ms_defaultEnvironmentTexture);
1361-	ms_fogStack.push_back(FogData(fogEnabled, fogDensity, fogColor));
1362-
1363-	Graphics::setGlobalTexture(TAG_ENVM, *ms_environmentTextures.back());
1364-	Graphics::setFog(fogEnabled, fogDensity, fogColor);
1365-
1366-	// preserve all the lights in the current cell
1367-	ms_lightListStackOffset.push_back(ms_lightList.size());
1368-
1369-	// empty out the light bits for the new cell
1370-	ms_lightsAffectingShadersWithoutPrecalculatedVertexLighting.reset();
1371-	ms_lightsAffectingShadersWithPrecalculatedVertexLighting.reset();
1372-
1373-	ms_cellPropertyStack.push_back(cellProperty);
1374-	if (cellProperty)
1375-		cellProperty->callEnterRenderHookFunctions();
1376-
1377-	ms_popped = false;
1378-
1379-#ifdef _DEBUG
1380-	ms_lightListOverflow = false;
1381-#endif
1382-}
