1454-		Graphics::optimizeIndexBuffer((WORD *)m_indexBuffer->begin(), m_indexBuffer->getNumberOfIndices());
1455-	}
1456-	*/
1457-
1458-	m_indexBuffer->unlock();
1459-	
1460-}
