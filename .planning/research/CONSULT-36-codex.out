356:void ShaderPrimitiveSorter::Phase::setSort(Sort sort)
357-{
358-	// store a pointer to the sort routine to avoid switching within sort()
359-	switch (sort)
360-	{
361-		case S_unknown:
362:			m_sort = &Phase::sort_unknown;
363-			m_getSortKeys = getSortKeys_unknown;
364-			break;
365-
366-		case S_fifo:
367:			m_sort = &Phase::sort_fifo;
368-			m_getSortKeys = getSortKeys_none;
369-			break;
370-
371-		case S_performance:
372-			m_sort = ms_sortPerformance;
373-			m_getSortKeys = getSortKeys_shaderImplementation_shaderTemplate_texture_vertexBuffer;
374-			break;
375-
376-		case S_painters:
377:			m_sort = &Phase::sort_z;
378-			m_getSortKeys = getSortKeys_depth;
379-			break;
380-
381-		default:
382-			DEBUG_FATAL(true, ("Invalid sort"));
383-			break;
384-	}
385-}
