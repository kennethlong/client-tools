116:void Bloom::enable()
117:{
118:	if (!ms_enabled)
119:	{
120:		if (Bloom::isSupported())
121:		{
122:			Graphics::addDeviceLostCallback(BloomNamespace::deviceLost);
123:			Graphics::addDeviceRestoredCallback(BloomNamespace::deviceRestored);
124:			Graphics::setBloomEnabled(true);
125:			deviceRestored();
126:			ms_enabled = true;
127:		}
128:		else
129:		{
130:			ms_enable = false;
131:			ms_enabled = false;
132:		}
133:	}
134:}
