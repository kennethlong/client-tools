137:
138:void Bloom::disable()
139:{
140:	if (ms_enabled)
141:	{
142:		deviceLost();
143:		Graphics::removeDeviceLostCallback(deviceLost);
144:		Graphics::removeDeviceRestoredCallback(deviceRestored);
145:		Graphics::setBloomEnabled(false);
146:
147:		ms_enable = false;
148:		ms_enabled = false;
149:	}
150:}
