1021:// ======================================================================
1022:// Plan 11-08 Iter-3a.1: lazy-create + cache the RTV for render-target
1023:// textures. Pre-fix Direct3d11_RenderTarget::setRenderTarget called
1024:// CreateRenderTargetView every bind, producing the ~20,975 per-session
1025:// Create+Destroy RTV churn observed in stage/d3d11-debug.log. Post-fix
1026:// the RTV is created on first bind and persists for the texture's
1027:// lifetime; subsequent binds reuse the cached ComPtr.
1028:
1029:ID3D11RenderTargetView * Direct3d11_TextureData::getOrCreateRenderTargetView(ID3D11Device 
*device) const
1030:{
1031:	if (!m_engineTexture.isRenderTarget())
1032:		return nullptr;
1033:
1034:	if (m_rtv)
1035:		return m_rtv.Get();
1036:
1037:	NOT_NULL(device);
1038:	NOT_NULL(m_texture);
1039:
1040:	// nullptr desc preserves the existing setRenderTarget behavior: the
1041:	// runtime infers the format + full-subresource binding from the
1042:	// underlying ID3D11Texture2D. Cube/mip-specific RTVs would require
1043:	// a populated D3D11_RENDER_TARGET_VIEW_DESC; the existing engine
1044:	// callers do not differentiate and this fix preserves that contract.
1045:	HRESULT const hr = device->CreateRenderTargetView(m_texture.Get(), nullptr, 
m_rtv.GetAddressOf());
1046:	if (FAILED(hr))
1047:	{
1048:		DEBUG_WARNING(true,
1049:			("Direct3d11_TextureData::getOrCreateRenderTargetView: CreateRenderTargetView failed 
(hr=0x%08X); "
1050:			 "callers will see nullptr and may fall back to no-op binding.\n",
1051:			 static_cast<unsigned>(hr)));
1052:		return nullptr;
1053:	}
1054:
1055:	return m_rtv.Get();
1056:}
