138:void Direct3d11_RenderTarget::remove()
139:{
140:	if (!ms_installed)
141:		return;
142:
143:	ms_userRTV.Reset();
144:	ms_renderTargetSrv.Reset();
145:	ms_renderTargetView.Reset();
146:	ms_renderTargetTexture.Reset();
147:
148:	ms_userTexture  = nullptr;
149:	ms_installed    = false;
150:}
