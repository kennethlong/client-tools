1198:
1199:	// Release back-buffer references (required by ResizeBuffers).
1200:	ms_depthStencilDSV.Reset();
1201:	ms_depthStencilTex.Reset();
1202:	ms_backBufferRTV.Reset();
1203:	if (ms_context) ms_context->ClearState();
1204:
1205:	HRESULT hr = ms_swapChain->ResizeBuffers(
1206:		0,                              // BufferCount = preserve existing
1207:		static_cast<UINT>(newWidth),
1208:		static_cast<UINT>(newHeight),
1209:		DXGI_FORMAT_UNKNOWN,            // preserve existing format
1210:		0);
1211:	FATAL_DX_HR("IDXGISwapChain1::ResizeBuffers failed: %s", hr);
1212:
1213:	ms_width  = newWidth;
1214:	ms_height = newHeight;
1215:
1216:	createBackBufferViews(newWidth, newHeight);
