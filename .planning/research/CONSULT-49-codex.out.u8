mips, m_isCubeMap ? 1 : 0, m_isVolumeMap ? 1 : 0));
331:	}
332:
333:	// Walk the engine-supplied runtime-format list in order; first format
334:	// whose DXGI mapping is non-UNKNOWN AND CheckFormatSupport accepts wins.
335:
336:	HRESULT lastResult = E_FAIL;
337:	for (int i = 0; dimsValid && !m_texture && i < numberOfRuntimeFormats; ++i)
338:	{
339:		TextureFormat const candidate = runtimeFormats[i];
340:		DXGI_FORMAT     const native    = translationTable[candidate];
341:		if (native == DXGI_FORMAT_UNKNOWN)
342:			continue;
343:
344:		// Verify the device actually supports this format for the target
345:		// resource type. CheckFormatSupport is the runtime equivalent of
346:		// D3D9's CheckDeviceFormat used in install() above.
347:		UINT support = 0;
348:		if (FAILED(device->CheckFormatSupport(native, &support)))
349:			continue;
350:		if ((support & D3D11_FORMAT_SUPPORT_TEXTURE2D) == 0 && !m_isVolumeMap)
351:			continue;
352:		if (m_isVolumeMap && (support & D3D11_FORMAT_SUPPORT_TEXTURE3D) == 0)
353:			continue;
354:		if (isRenderTarget && (support & D3D11_FORMAT_SUPPORT_RENDER_TARGET) == 0)
355:			continue;
356:
357:		m_destFormat = candidate;
358:
359:		if (m_isVolumeMap)
360:		{
361:			D3D11_TEXTURE3D_DESC desc = {};
362:			desc.Width            = static_cast<UINT>(newEngineTexture.getWidth());
363:			desc.Height           = static_cast<UINT>(newEngineTexture.getHeight());
364:			desc.Depth            = static_cast<UINT>(newEngineTexture.getDepth());
365:			desc.MipLevels        = static_cast<UINT>(newEngineTexture.getMipmapLevelCount());
366:			desc.Format           = native;
367:			desc.Usage            = usage;
368:			desc.BindFlags        = bindFlags;
369:			desc.CPUAccessFlags   = cpuAccessFlags;
370:			desc.MiscFlags        = 0;  // no cube on 3D
371:
372:			ComPtr<ID3D11Texture3D> tex3d;
373:			lastResult = device->CreateTexture3D(&desc, nullptr, &tex3d);
374:			if (SUCCEEDED(lastResult))
375:				m_texture = tex3d;
376:		}
377:		else
378:		{
379:			D3D11_TEXTURE2D_DESC desc = {};
380:			desc.Width              = static_cast<UINT>(newEngineTexture.getWidth());
381:			desc.Height             = static_cast<UINT>(newEngineTexture.getHeight());
382:			desc.MipLevels          = static_cast<UINT>(newEngineTexture.getMipmapLevelCount());
383:			desc.ArraySize          = m_isCubeMap ? 6 : 1;
384:			desc.Format             = native;
385:			desc.SampleDesc.Count   = 1;
386:			desc.SampleDesc.Quality = 0;
387:			desc.Usage              = usage;
388:			desc.BindFlags          = bindFlags;
389:			desc.CPUAccessFlags     = cpuAccessFlags;
390:			desc.MiscFlags          = miscFlags;
391:
392:			ComPtr<ID3D11Texture2D> tex2d;
393:			lastResult = device->CreateTexture2D(&desc, nullptr, &tex2d);
394:			if (SUCCEEDED(lastResult))
395:				m_texture = tex2d;
396:		}
397:	}
398:
399:	if (!m_texture)
400:	{
401:		char buffer[1024] = "";
402:		for (int i = 0; i < numberOfRuntimeFormats; ++i)
403:		{
404:			strcat(buffer, TextureFormatInfo::getInfo(runtimeFormats[i]).name);
405:			strcat(buffer, " ");
406:		}
407:		FATAL(true, ("Direct3d11_TextureData: failed to create texture for any runtime format (%s); 
last HRESULT=%s",
408:		             buffer, Direct3d11Namespace::hresultString(lastResult)));
