41:namespace Direct3d11_RenderTargetNamespace
42:{
43:	int const  cms_bakedTextureMaxDimension = 512;
44:
45:	bool       ms_installed         = false;
46:	bool       ms_primaryTargetSet  = true;
47:
48:	// Persistent 512x512 offscreen RT + paired SRV for the "render to
49:	// baked texture, sample back" flow (used by skin shaders, certain UI
50:	// effects). RTV is for the GPU write side; SRV is for the read-back
51:	// path that fills the user-supplied destination texture on
52:	// copyRenderTargetToNonRenderTargetTexture.
53:
54:	ComPtr<ID3D11Texture2D>        ms_renderTargetTexture;
55:	ComPtr<ID3D11RenderTargetView> ms_renderTargetView;
56:	ComPtr<ID3D11ShaderResourceView> ms_renderTargetSrv;
57:
58:	// User-supplied destination -- ms_userTexture is the engine Texture
59:	// the bake will copy into when copyRenderTargetToNonRenderTargetTexture
60:	// fires. ms_userMip / ms_userCubeFace track the destination subresource.
61:	Texture *  ms_userTexture       = nullptr;
62:	CubeFace   ms_userCubeFace      = CF_none;
63:	int        ms_userMip           = 0;
64:	int        ms_copyWidth         = 0;
65:	int        ms_copyHeight        = 0;
66:
67:	// User-supplied is a render-target Texture itself? Track which RTV
68:	// to bind in setRenderTarget.
69:	ComPtr<ID3D11RenderTargetView> ms_userRTV;
