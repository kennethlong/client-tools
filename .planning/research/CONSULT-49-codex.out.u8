153:
154:void Direct3d11_RenderTarget::setRenderTargetToPrimary()
155:{
156:	DEBUG_FATAL(!ms_installed, ("Direct3d11_RenderTarget not installed"));
157:
158:	if (ms_primaryTargetSet)
159:		return;
160:
161:	// Rebind the back-buffer RTV + DSV. Direct3d11_Device::beginScene
162:	// already encapsulates the rebind logic; reuse it for correctness.
163:	Direct3d11_Device::beginScene();
164:	ms_primaryTargetSet = true;
165:
166:	// Release the user-side resource we held while the secondary target
167:	// was active (if any).
168:	ms_userRTV.Reset();
169:}
