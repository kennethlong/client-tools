formats, sizeof(formats) / sizeof(formats[0]));
166:	ms_blurVerticalTexture = TextureList::fetch(TCF_renderTarget, smallWidth, smallHeight, 1, 
formats, sizeof(formats) / sizeof(formats[0]));
