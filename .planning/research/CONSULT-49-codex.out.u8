311:	s_projectionMatrix.matrix[0][3] = -2.f * float(0) * oodx - 1.f;
312:
313:	const float oody = 1.0f/float(height);
314:	s_projectionMatrix.matrix[1][1] = -2.f * oody;
315:	s_projectionMatrix.matrix[1][3] =  2.f * float(0) * oody + 1.f;

