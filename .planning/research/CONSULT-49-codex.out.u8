173:void Direct3d11_RenderTarget::setRenderTarget(Texture *texture, CubeFace cubeFace, int 
mipmapLevel)
174:{
175:	NOT_NULL(ms_renderTargetTexture);
176:	NOT_NULL(texture);
177:
178:	ID3D11Device *        const device  = Direct3d11_Device::getDevice();
179:	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
180:	NOT_NULL(device);
181:	NOT_NULL(context);
182:
183:	// Save engine destination metadata for the copy on
184:	// copyRenderTargetToNonRenderTargetTexture.
185:	ms_userTexture      = texture;
186:	ms_userCubeFace     = cubeFace;
187:	ms_userMip          = mipmapLevel;
188:	ms_primaryTargetSet = false;
189:
190:	if (!texture->isRenderTarget())
191:	{
192:		// User passed an ordinary texture; we render into the persistent
193:		// 512x512 baked target and copy out on the matching unbind. Cap
194:		// the copy region to the user texture's dimensions at the
195:		// requested mip level.
196:		ms_copyWidth  = (std::max)(1, texture->getWidth()  >> mipmapLevel);
197:		ms_copyHeight = (std::max)(1, texture->getHeight() >> mipmapLevel);
198:
199:		if (ms_copyWidth > cms_bakedTextureMaxDimension || ms_copyHeight > 
cms_bakedTextureMaxDimension)
200:		{
201:			DEBUG_WARNING(true,
202:				("Direct3d11_RenderTarget: requested baked-texture region %dx%d exceeds "
203:				 "%dx%d cap; copy will truncate",
204:				 ms_copyWidth, ms_copyHeight,
205:				 cms_bakedTextureMaxDimension, cms_bakedTextureMaxDimension));
206:			ms_copyWidth  = (std::min)(ms_copyWidth,  cms_bakedTextureMaxDimension);
207:			ms_copyHeight = (std::min)(ms_copyHeight, cms_bakedTextureMaxDimension);
208:		}
209:
210:		// Bind the persistent baked-texture RTV. No depth-stencil (matches
211:		// the D3D9 plugin's SetDepthStencilSurface(NULL) behaviour).
212:		ID3D11RenderTargetView * rtvs[1] = { ms_renderTargetView.Get() };
213:		context->OMSetRenderTargets(1, rtvs, nullptr);
214:	}
215:	else
216:	{
217:		// Texture is itself a render target -- use the RTV cached on
218:		// Direct3d11_TextureData. Plan 11-08 Iter-3a.1: pre-fix every
219:		// bind called CreateRenderTargetView, producing ~20,975
220:		// per-session Create+Destroy RTV cycles in the InfoQueue stream.
221:		// Post-fix the RTV is lazy-created on first bind and persists
222:		// for the texture's lifetime; ms_userRTV holds a per-binding
223:		// reference so setRenderTargetToPrimary's Reset() doesn't tear
224:		// down the master cache on the TextureData.
225:		Direct3d11_TextureData const *texData =
226:			static_cast<Direct3d11_TextureData const *>(texture->getGraphicsData());
227:		NOT_NULL(texData);
228:
229:		ID3D11RenderTargetView * const cachedRTV = texData->getOrCreateRenderTargetView(device);
230:		FATAL(!cachedRTV,
231:		      ("Direct3d11_RenderTarget::setRenderTarget: getOrCreateRenderTargetView returned null; "
232:		       "render-target texture cannot bind"));
233:
234:		ms_userRTV = cachedRTV;   // ComPtr AddRef -- texture retains master ownership
235:
236:		ms_copyWidth  = (std::max)(1, texture->getWidth()  >> mipmapLevel);
237:		ms_copyHeight = (std::max)(1, texture->getHeight() >> mipmapLevel);
238:
239:		// Phase 19 FIX: bind the shared screen depth-stencil when this render
240:		// target is the engine's FULL-SCREEN scene RT (the post-FX baked target
241:		// the entire world renders into). D3D9 parity: Direct3d9_RenderTarget::
242:		// setRenderTarget calls SetDepthStencilSurface(NULL) ONLY for the
243:		// non-render-target user-texture path; for a real (screen-sized) render
244:		// target it leaves the primary depth surface bound, so the world
245:		// depth-tests normally. The pre-fix code bound `nullptr` here too (a
246:		// mis-stated "matches D3D9" comment), so the WHOLE world rendered with NO
247:		// depth buffer -> draws landed in submission order -> overlapping props
248:		// (e.g. ceiling light fixtures) painted over/under each other ("object
249:		// depth out of whack"). RenderDoc capture11: ResourceId::323 took ~480
250:		// ColorTarget draws with no depthTarget bound. Gate on an exact
251:		// screen-dimension match (D3D11 requires RT and DSV dimensions to agree);
252:		// smaller offscreen RTs (cubemaps/water/portraits, cubeFace != CF_none,
253:		// or mip-reduced) keep nullptr -- those 2D/offscreen passes don't use the
254:		// screen depth and a size mismatch would be invalid.
255:		ID3D11DepthStencilView * dsv = nullptr;
256:		if (cubeFace == CF_none
257:			&& ms_copyWidth  == Direct3d11_Device::getWidth()
258:			&& ms_copyHeight == Direct3d11_Device::getHeight())
259:		{
260:			dsv = Direct3d11_Device::getDepthStencilView();
280:bool Direct3d11_RenderTarget::copyRenderTargetToNonRenderTargetTexture()
281:{
282:	// End-of-baking handler. Two paths mirroring setRenderTarget above:
283:	//
284:	//   1. User texture was a render target -> nothing to copy; just
285:	//      release the transient RTV and restore primary.
286:	//
287:	//   2. User texture was an ordinary texture -> copy the baked region
288:	//      out of ms_renderTargetTexture into the engine texture's
289:	//      underlying ID3D11Texture2D. Use CopySubresourceRegion (same-size
290:	//      blit, no format conversion -- mirrors D3D9
291:	//      GetRenderTargetData + D3DXLoadSurfaceFromSurface but cheaper
292:	//      because no system-memory intermediate is needed).
293:
294:	if (!ms_userTexture)
295:	{
296:		// No active bake -- nothing to do.
297:		setRenderTargetToPrimary();
298:		return true;
299:	}
300:
301:	if (!ms_userTexture->isRenderTarget())
302:	{
303:		ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
304:		NOT_NULL(context);
305:
306:		Direct3d11_TextureData const *texData =
307:			static_cast<Direct3d11_TextureData const *>(ms_userTexture->getGraphicsData());
308:		NOT_NULL(texData);
309:
310:		UINT const dstSubresource =
311:			(ms_userCubeFace != CF_none)
312:				? D3D11CalcSubresource(
313:					static_cast<UINT>(ms_userMip),
314:					static_cast<UINT>(ms_userCubeFace),
315:					static_cast<UINT>(ms_userTexture->getMipmapLevelCount()))
316:				: static_cast<UINT>(ms_userMip);
317:
318:		D3D11_BOX srcBox = {};
319:		srcBox.left   = 0;
320:		srcBox.top    = 0;
321:		srcBox.front  = 0;
322:		srcBox.right  = static_cast<UINT>(ms_copyWidth);
323:		srcBox.bottom = static_cast<UINT>(ms_copyHeight);
324:		srcBox.back   = 1;
325:
326:		// Plan 11-09.15 Iter-40 diagnostic: log the dest texture's DXGI
327:		// format on first N copybacks. The persistent source RT is BGRA8
328:		// (see install() above); if a dest texture has a different DXGI
329:		// format AND is not in the same typeless family, the
330:		// CopySubresourceRegion below will fire id=281 "Formats not
331:		// castable" and the copy silently fails. The log tells us whether
332:		// any non-BGRA8 dest formats reach this path, which guides the
333:		// follow-up Iter-40b decision (per-format RT recreation vs the
334:		// current single-format design).
335:		{
336:			static int s_iter40Count = 0;
337:			if (s_iter40Count < 50)
338:			{
339:				ID3D11Resource *const dstRes = texData->getTexture();
340:				ComPtr<ID3D11Texture2D> dstTex2d;
341:				if (dstRes && SUCCEEDED(dstRes->QueryInterface(IID_PPV_ARGS(&dstTex2d))) && dstTex2d)
342:				{
343:					D3D11_TEXTURE2D_DESC dstDesc = {};
344:					dstTex2d->GetDesc(&dstDesc);
345:					if (dstDesc.Format != DXGI_FORMAT_B8G8R8A8_UNORM)
346:					{
347:						++s_iter40Count;
348:						if (ID3D11InfoQueue *iq40 = Direct3d11_Device::getInfoQueue())
349:						{
350:							char const *fn = ms_userTexture ? "<userTex>" : "<null>";
351:							char buf40[384];
352:							_snprintf_s(buf40, sizeof(buf40), _TRUNCATE,
353:								"Plan 11-09.15 Iter-40 BAKE_FMT_MISMATCH#%d dstDXGI=%d srcDXGI=%d "
354:								"dstW=%u dstH=%u mip=%d cubeFace=%d userTex=%s",
355:								s_iter40Count,
356:								static_cast<int>(dstDesc.Format),
357:								static_cast<int>(DXGI_FORMAT_B8G8R8A8_UNORM),
358:								dstDesc.Width, dstDesc.Height,
359:								ms_userMip,
360:								static_cast<int>(ms_userCubeFace),
361:								fn);
362:							iq40->AddApplicationMessage(D3D11_MESSAGE_SEVERITY_WARNING, buf40);
363:						}
364:					}
365:				}
366:			}
367:		}
368:
369:		context->CopySubresourceRegion(
370:			texData->getTexture(),
371:			dstSubresource,
372:			0, 0, 0,
373:			ms_renderTargetTexture.Get(),
374:			0,
375:			&srcBox);
376:	}
377:
378:	// Release transient state and restore the primary target.
379:	ms_userRTV.Reset();
380:	ms_userTexture = nullptr;
381:
382:	setRenderTargetToPrimary();
383:	return true;
384:}
