74:
75:void Direct3d11_RenderTarget::install()
76:{
77:	DEBUG_FATAL(ms_installed, ("Direct3d11_RenderTarget already installed"));
78:
79:	ID3D11Device * const device = Direct3d11_Device::getDevice();
80:	NOT_NULL(device);
81:
82:	// Persistent 512x512 BGRA8 baked-texture target.
83:	// BindFlags = D3D11_BIND_RENDER_TARGET | D3D11_BIND_SHADER_RESOURCE so
84:	// the same texture is writable as RTV AND samplable as SRV (matches
85:	// D3D9's "render to texture then sample" flow but without the
86:	// system-memory intermediate).
87:	//
88:	// Plan 11-09.15 Iter-40: format is DXGI_FORMAT_B8G8R8A8_UNORM (BGRA),
89:	// NOT DXGI_FORMAT_B8G8R8X8_UNORM (BGRX) as the D3D9 sibling uses
90:	// (Direct3d9_RenderTarget.cpp:91 D3DFMT_X8R8G8B8). D3D9's
91:	// D3DXLoadSurfaceFromSurface / StretchRect were format-permissive;
92:	// D3D11's CopySubresourceRegion at copyRenderTargetToNonRenderTargetTexture
93:	// (line 284 below) strict-rejects when source and dest formats differ
94:	// AND are not in the same typeless family. BGRA8 and BGRX8 live in
95:	// SEPARATE typeless families (B8G8R8A8_TYPELESS vs B8G8R8X8_TYPELESS),
96:	// so a BGRX8 source rejects every BGRA8 dest. Engine bake-destination
97:	// textures are predominantly TF_ARGB_8888 -> BGRA8 (TextureRendererTemplate
98:	// singleTextureFormat = TF_ARGB_8888 at TextureRendererTemplate.cpp:74),
99:	// so matching the persistent RT to BGRA8 closes the common case. The
100:	// "X channel" of the D3D9 path was always ignored anyway; reading
101:	// alpha=undef from a BGRA RTV is equivalent. A diagnostic at
102:	// copyRenderTargetToNonRenderTargetTexture logs any non-BGRA dest that
103:	// slips through; if such a case appears, a follow-up Iter-40b handles
104:	// per-dest-format RT recreation.
105:
106:	D3D11_TEXTURE2D_DESC desc = {};
107:	desc.Width              = static_cast<UINT>(cms_bakedTextureMaxDimension);
108:	desc.Height             = static_cast<UINT>(cms_bakedTextureMaxDimension);
109:	desc.MipLevels          = 1;
110:	desc.ArraySize          = 1;
111:	desc.Format             = DXGI_FORMAT_B8G8R8A8_UNORM;
112:	desc.SampleDesc.Count   = 1;
113:	desc.SampleDesc.Quality = 0;
114:	desc.Usage              = D3D11_USAGE_DEFAULT;
115:	desc.BindFlags          = D3D11_BIND_RENDER_TARGET | D3D11_BIND_SHADER_RESOURCE;
116:	desc.CPUAccessFlags     = 0;
117:	desc.MiscFlags          = 0;
118:
119:	HRESULT hr = device->CreateTexture2D(&desc, nullptr, &ms_renderTargetTexture);
120:	FATAL_DX_HR("Direct3d11_RenderTarget: CreateTexture2D (baked) failed: %s", hr);
121:
122:	hr = device->CreateRenderTargetView(ms_renderTargetTexture.Get(), nullptr, 
&ms_renderTargetView);
123:	FATAL_DX_HR("Direct3d11_RenderTarget: CreateRenderTargetView (baked) failed: %s", hr);
124:
125:	hr = device->CreateShaderResourceView(ms_renderTargetTexture.Get(), nullptr, 
&ms_renderTargetSrv);
126:	FATAL_DX_HR("Direct3d11_RenderTarget: CreateShaderResourceView (baked) failed: %s", hr);
127:
128:	ms_installed        = true;
129:	ms_primaryTargetSet = true;
130:
131:	DEBUG_REPORT_LOG_PRINT(true,
132:		("Direct3d11_RenderTarget: baked-texture target %dx%d BGRA8 RTV+SRV created\n",
133:		 cms_bakedTextureMaxDimension, cms_bakedTextureMaxDimension));
134:}
