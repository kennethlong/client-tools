51:// DXGI_FORMAT translation table -- one entry per TextureFormat enum value
52:// (Texture.def TF_ARGB_8888..TF_ABGR_32F + TF_Count + TF_Native sentinels).
53:// Mirrors Direct3d9_TextureData.cpp:33-54 layout. Unsupported / unmappable
54:// formats use DXGI_FORMAT_UNKNOWN; the install-time CheckFeatureSupport
55:// pass below marks those entries unsupported and the engine falls through
56:// to the next runtimeFormat candidate.
57:static const DXGI_FORMAT translationTable[] =
58:{
59:	DXGI_FORMAT_B8G8R8A8_UNORM,     // TF_ARGB_8888
60:	DXGI_FORMAT_B4G4R4A4_UNORM,     // TF_ARGB_4444 (Win8+ only; install probe marks unsupported on 
older)
61:	DXGI_FORMAT_B5G5R5A1_UNORM,     // TF_ARGB_1555
62:	DXGI_FORMAT_B8G8R8X8_UNORM,     // TF_XRGB_8888
63:	DXGI_FORMAT_UNKNOWN,            // TF_RGB_888  -- no 24bpp packed in DXGI; engine promotes via 
runtimeFormats
64:	DXGI_FORMAT_B5G6R5_UNORM,       // TF_RGB_565
65:	DXGI_FORMAT_B5G5R5A1_UNORM,     // TF_RGB_555  -- closest DXGI; alpha bit unused by engine
66:	DXGI_FORMAT_BC1_UNORM,          // TF_DXT1
67:	DXGI_FORMAT_UNKNOWN,            // TF_DXT2     -- premultiplied BC2; no native DXGI variant; 
engine promotes
68:	DXGI_FORMAT_BC2_UNORM,          // TF_DXT3
69:	DXGI_FORMAT_UNKNOWN,            // TF_DXT4     -- premultiplied BC3; no native DXGI variant; 
engine promotes
70:	DXGI_FORMAT_BC3_UNORM,          // TF_DXT5
71:	DXGI_FORMAT_A8_UNORM,           // TF_A_8
72:	DXGI_FORMAT_R8_UNORM,           // TF_L_8      -- sample with .rrr swizzle in HLSL (Plan 11-05 
generators)
73:	DXGI_FORMAT_UNKNOWN,            // TF_P_8      -- palettized normal-map; D3D11 has no P_8; 
engine promotes
74:	DXGI_FORMAT_R16G16B16A16_FLOAT, // TF_ABGR_16F
75:	DXGI_FORMAT_R32G32B32A32_FLOAT, // TF_ABGR_32F
76:	DXGI_FORMAT_UNKNOWN,            // TF_Count (sentinel)
77:	DXGI_FORMAT_UNKNOWN             // TF_Native (sentinel)
78:};
79:
80:// Compile-time check: translation table length must cover TF_Native sentinel
81:// (TF_Native enum value = TF_Count + 1, so table length = TF_Count + 2).
82:static_assert(sizeof(translationTable) / sizeof(translationTable[0]) == (TF_Count + 2),
83:              "translationTable must have one entry per TextureFormat enum value 
(TF_ARGB_8888..TF_Native)");
84:
85:// Identifies the block-compressed DXGI families (BC1..BC7). All BC formats
86:// use a 4x4 pixel block as the indivisible storage unit; D3D11 strict-
87:// rejects USAGE_STAGING CreateTexture2D/CreateTexture3D when Width or
88:// Height is not a multiple of 4 for these formats (D3D9 silently tolerated
89:// the sub-block bottom-of-chain mip levels). Used in lock() to pad the
90:// staging-texture descriptor up to the block boundary; the BC block grid
91:// covers the same data regardless of whether the locked mip's logical
92:// dimensions are sub-block, so RowPitch / engine payload / unlock
93:// CopySubresourceRegion all behave identically.
94://
95:// Range coverage:
96://   BC1_TYPELESS (70) .. BC5_SNORM (84)       -- BC1/BC2/BC3/BC4/BC5
97://   BC6H_TYPELESS (94) .. BC7_UNORM_SRGB (99) -- BC6H/BC7
98:// Values 85..93 are non-BC formats (B5G6R5, BGRA8, etc.) interleaved
99:// between the two BC ranges, so a single >= && <= check is incorrect.
100:static bool isBlockCompressedFormat(DXGI_FORMAT fmt)
101:{
102:	return (fmt >= DXGI_FORMAT_BC1_TYPELESS && fmt <= DXGI_FORMAT_BC5_SNORM)
103:	    || (fmt >= DXGI_FORMAT_BC6H_TYPELESS && fmt <= DXGI_FORMAT_BC7_UNORM_SRGB);
104:}
