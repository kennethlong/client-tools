2448-void Direct3d11_StateCache::setSpecularPower(float power)
2449-{
2450-	// Plan 17-09 (GAP-5): mirror Direct3d9_StateCache::setSpecularPower. The VS
2451-	// object-space specular reads materialSpecularPower from lightData[25].w
2452-	// (dot3.localDirection.w). Store it (composeSlot0Shadow uses it) AND patch the
2453-	// live shadow in place so the next flush is correct regardless of whether
2454-	// composeSlot0Shadow re-runs this draw. Reject 0 / NaN / wild values (they make
2455-	// pow() produce NaN) -- fall back to the D3D9 default of 32.
2456-	float const safe = (power > 0.0f && power < 1.0e6f) ? power : 32.0f;
2457-	Direct3d11_StateCacheNamespace::ms_specularPower = safe;
2458-	// c15.x (material[4].x) is materialSpecularPower -- the register the VS object-
2459-	// space specular actually reads (proven by disasm: `mul r4.w, r4.w, cb0[15].x`).
2460-	// composeSlot0Shadow never fills material[], so without this it is 0 -> at a
2461-	// perpendicular vertex (nDotH==0) the unclamped `log2(0)*0 = -INF*0 = NaN` is
2462-	// selected by the >=0 movc mask -> NaN COLOR0/COLOR1 -> purple/green arms.
2463-	Direct3d11_StateCacheNamespace::s_slot0Shadow.material[4].x = safe;
2464-	// Also mirror D3D9's dot3.localDirection.w (c41.w) for the PS dot3 path.
2465-	Direct3d11_StateCacheNamespace::s_slot0Shadow.lightData[25].w = safe;
2466:	Direct3d11_StateCacheNamespace::s_slot0Dirty = true;
2467-}
