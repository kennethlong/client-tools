2326-		streamCount, kMaxVBStreams));
2327-
2328-	ms_currentVBVectorActive      = (streamCount > 0);
2329-	ms_currentVBVectorStreamCount = streamCount;
2330-	for (int i = 0; i < kMaxVBStreams; ++i)
2331-	{
2332-		ms_currentVBVectorBuffers[i] = (i < streamCount && buffers) ? buffers[i] : nullptr;
2333-		ms_currentVBVectorStrides[i] = (i < streamCount && strides) ? strides[i] : 0;
2334-		ms_currentVBVectorOffsets[i] = (i < streamCount && offsets) ? offsets[i] : 0;
2335-		ms_currentVBVectorFormats[i] = (i < streamCount && formats) ? formats[i] : nullptr;
2336-	}
