void *Direct3d11_DynamicVertexBufferData::lock(int numberOfVertices, bool forceDiscard)
{
	int const vertexSize = m_vertexBufferDescriptor.vertexSize;

	// DEDICATED SOFT-SKIN RING routing. (Count-based `numberOfVertices < 16384` was tried and
	// REVERTED: it broke the whole-ring lockers -- CuiLayer/ShadowVolume/Reticle call
	// getNumberOfLockableDynamicVertices() [vSize-based, returns MAIN] then lock; when that lock
	// was small it routed to SKIN, splitting query from lock -> screen-filling corruption.)
	// Back to the vSize discriminator as the known baseline for the draw-time readback diagnostic.
	bool const           isSkin       = (vertexSize != 28) && (vertexSize != 24);
	int                 &ringUsed     = isSkin ? ms_skinUsed     : ms_used;
	int const            ringSize     = isSkin ? ms_skinSize     : ms_size;
	bool                &ringNewFrame = isSkin ? ms_skinNewFrame : ms_newFrame;
	ID3D11Buffer * const ringBuffer   = isSkin ? ms_d3dSkinRingBuffer.Get() : ms_d3dRingBuffer.Get();

	// CONSULT-32 TEST (diagnostic): force WRITE_DISCARD on every skin-ring lock. The spike is always
	// ring=SKIN discard=0 (an APPENDED slice via WRITE_NO_OVERWRITE). Forcing discard gives each
	// skinned mesh a fresh renamed buffer at offset 0 (no append). If the spike vanishes, the
	// append/offset handling on the skin ring is the bug. Revert after confirming.
	if (isSkin)
		forceDiscard = true;

	// round used up to vertexSize alignment (inlined roundUpUsed for the selected ring)
	ringUsed = ((ringUsed + vertexSize - 1) / vertexSize) * vertexSize;

	int const length = numberOfVertices * vertexSize;

#if P19_THREAD_AUDIT
	if (!Os::isMainThread())
	{
		static int s_offThreadVBLocks = 0;
		++s_offThreadVBLocks;
		char tbuf[160];
		_snprintf_s(tbuf, sizeof(tbuf), _TRUNCATE,
			"[P19THREAD] dynamic VB ring lock OFF MAIN THREAD tid=%lu count=%d numVerts=%d",
			GetCurrentThreadId(), s_offThreadVBLocks, numberOfVertices);
		ID3D11InfoQueue *iq = Direct3d11_Device::getInfoQueue();
		if (iq) iq->AddApplicationMessage(D3D11_MESSAGE_SEVERITY_WARNING, tbuf);
	}
#endif

	++ms_locksSinceBeginFrame;
	++ms_locksSinceResourceCreation;
	++ms_locksEver;

	D3D11_MAP    mapType  = D3D11_MAP_WRITE_NO_OVERWRITE;
	int          discard  = 0;
#if P19_DISCARD_ONLY
	forceDiscard = true;  // diagnostic: rename every lock (kills intra-frame reuse hazard)
#endif
	if (ringNewFrame || forceDiscard || ringUsed + length > ringSize)
	{
		ringNewFrame = false;
		++ms_discardsSinceBeginFrame;
		++ms_discardsSinceResourceCreation;
		++ms_discardsEver;
		discard = 1;

		DEBUG_FATAL(length > ringSize, ("Too many vertices %d/%d", numberOfVertices, ringSize / vertexSize));

		mapType = D3D11_MAP_WRITE_DISCARD;
		ringUsed = 0;
	}

	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
	NOT_NULL(context);

	D3D11_MAPPED_SUBRESOURCE mapped = {};
	HRESULT const hr = context->Map(ringBuffer, 0, mapType, 0, &mapped);
	FATAL(FAILED(hr),
		("Could not lock dynamic vb %d=err %d=discard %d=offset %d=length %d/%d/%d=locks %d/%d/%d=discards",
		 HRESULT_CODE(hr), discard, ringUsed, length,
		 ms_locksSinceBeginFrame, ms_locksSinceResourceCreation, ms_locksEver,
		 ms_discardsSinceBeginFrame, ms_discardsSinceResourceCreation, ms_discardsEver));
	NOT_NULL(mapped.pData);

	// Track this lock's slice. The engine writes into the byte range
	// [m_offset, m_offset + length); after Unmap the GPU sees the writes.
	m_numberOfVertices = numberOfVertices;
	m_offset           = ringUsed / vertexSize;  // VERTEX index (engine sets BaseVertexLocation per draw)
	m_ringBuffer       = ringBuffer;             // bind from THIS ring (main or skin)

	void * const sliceStart = static_cast<char *>(mapped.pData) + ringUsed;

	// CONSULT-32 WHOLE-PATH PROBE C: capture which ring + offset + discard this lock used, so the
	// unlock outlier probe (Probe B) can report the lock context for each spiking dynamic-VB slice.
	s_lastLockIsSkin   = isSkin ? 1 : 0;
	s_lastLockDiscard  = discard;
	s_lastLockOffset   = m_offset;
	s_lastLockRingUsed = ringUsed;

	ringUsed += length;

	// Plan 11-09.15 Iter-4 (Test A): stash for unlock-time snapshot.
	s_lastLockedSliceCPUPtr = sliceStart;

	// CONSULT-32 SENTINEL (skin ring only): fill the slice with 0x7F (~3.4e38) BEFORE the engine
	// writes. Probe B (unlock) checks whether the SPIKE verts still hold the sentinel (= nobody wrote
	// them -> read-past / lock>write) or hold real garbage (= a stray write landed there). Decides the
	// last fork. Skin ring is plenty big; sentinel-filling the locked slice is cheap.
	if (isSkin)
		memset(sliceStart, 0x7F, static_cast<size_t>(length));

	return sliceStart;
}

