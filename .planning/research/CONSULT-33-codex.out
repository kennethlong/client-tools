		// CONSULT-31 DYNAMIC-VB OUTLIER SCAN (DIAGNOSTIC -- remove after). Reads the COPIED dynamic VB
		// (copy output, post systemStream->dynamic). Computes centroid and flags verts flung far from it
		// = spikes. Pairs with the systemStream skin probe (fillVertexBuffer cape-skin-spike.txt): if the
		// SAME spike shows here (dynamic) but NOT in the skin probe (systemStream), the COPY introduced
		// it (Kenny's "after skinning"). If it shows in BOTH, skinning is the source. Logs cape-dynvb-outlier.txt.
		{
			int const olVertexSize = m_vertexBufferDescriptor.vertexSize;
			if (s_lastLockedSliceCPUPtr && numberOfVertices >= 32 && numberOfVertices < 8192 && olVertexSize >= 24)
			{
				uint8_t const *olVb = static_cast<uint8_t const *>(s_lastLockedSliceCPUPtr);
				// SENTINEL-AWARE: classify verts as sentinel (unwritten, |comp|>1e30) vs written.
				// Centroid/outliers computed over WRITTEN verts only.
				double cx = 0, cy = 0, cz = 0; int written = 0;
				int senCount = 0, senFirstIdx = -1;
				for (int v = 0; v < numberOfVertices; ++v)
				{
					float const *p = reinterpret_cast<float const *>(olVb + v * olVertexSize);
					bool const sentinel = (p[0] > 1e30f) || (p[0] < -1e30f) || (p[1] > 1e30f) || (p[2] > 1e30f);
					if (sentinel) { ++senCount; if (senFirstIdx < 0) senFirstIdx = v; }
					else          { cx += p[0]; cy += p[1]; cz += p[2]; ++written; }
				}
				float const fcx = static_cast<float>(cx / (written ? written : 1));
				float const fcy = static_cast<float>(cy / (written ? written : 1));
				float const fcz = static_cast<float>(cz / (written ? written : 1));
				double meanDist = 0;
				for (int v = 0; v < numberOfVertices; ++v)
				{
					float const *p = reinterpret_cast<float const *>(olVb + v * olVertexSize);
					if ((p[0] > 1e30f) || (p[0] < -1e30f) || (p[1] > 1e30f) || (p[2] > 1e30f)) continue;
					float const dx = p[0]-fcx, dy = p[1]-fcy, dz = p[2]-fcz;
					meanDist += sqrt(static_cast<double>(dx*dx + dy*dy + dz*dz));
				}
				meanDist /= (written ? written : 1);
				float const thresh = static_cast<float>(8.0 * meanDist + 50.0);
				int olCount = 0, olFirstIdx = -1; float olFx = 0, olFy = 0, olFz = 0, olMaxD = 0;
				for (int v = 0; v < numberOfVertices; ++v)
				{
					float const *p = reinterpret_cast<float const *>(olVb + v * olVertexSize);
					if ((p[0] > 1e30f) || (p[0] < -1e30f) || (p[1] > 1e30f) || (p[2] > 1e30f)) continue; // skip sentinel (counted separately)
					float const dx = p[0]-fcx, dy = p[1]-fcy, dz = p[2]-fcz;
					float const d = sqrt(dx*dx + dy*dy + dz*dz);
					if (d > thresh)
					{
						if (olFirstIdx < 0) { olFirstIdx = v; olFx = p[0]; olFy = p[1]; olFz = p[2]; }
						++olCount; if (d > olMaxD) olMaxD = d;
					}
				}
				static int s_olLogged = 0;
				if ((olCount > 0 || senCount > 0) && s_olLogged < 15000)
				{
					++s_olLogged;
					static bool s_olFirst = true;
					FILE *olFp = nullptr;
					fopen_s(&olFp, "cape-dynvb-outlier.txt", s_olFirst ? "wb" : "ab");
					s_olFirst = false;
					if (olFp)
					{
						fprintf(olFp,
							"%s numVerts=%d vSize=%d outliers=%d firstIdx=%d firstPos=[%.1f %.1f %.1f] maxD=%.0f UNWRITTEN(sentinel)=%d senFirstIdx=%d centroid=[%.1f %.1f %.1f] offsetVerts=%d ring=%s discard=%d lockOff=%d\n",
							senCount > 0 ? "TAIL-UNWRITTEN" : "OUTLIER",
							numberOfVertices, olVertexSize, olCount, olFirstIdx, olFx, olFy, olFz, olMaxD,
							senCount, senFirstIdx,
							fcx, fcy, fcz, m_offset,
							s_lastLockIsSkin ? "SKIN" : "MAIN", s_lastLockDiscard, s_lastLockOffset);
						fclose(olFp);
					}
				}
			}
		}

		s_lastLockedSliceCPUPtr = nullptr;
	}

	ID3D11DeviceContext * const context = Direct3d11_Device::getContext();
	NOT_NULL(context);

	context->Unmap(m_ringBuffer ? m_ringBuffer : ms_d3dRingBuffer.Get(), 0);

	m_numberOfVertices = numberOfVertices;
	// Note: ms_used was already advanced in lock(); we don't re-adjust
	// here. (D3D9 plugin advances on unlock because Lock takes only an
	// upper-bound length and Unlock takes the actual used length; D3D11
	// Map gets a slice pointer and the actual-used count only affects
	// the draw call, not the buffer accounting.)
}

