void NebulaShellShaderPrimitive::draw() const
{
	NP_PROFILER_AUTO_BLOCK_DEFINE("NebulaShellShaderPrimitive::draw");

	if (m_canDraw)
		Graphics::drawIndexedTriangleList();
}

