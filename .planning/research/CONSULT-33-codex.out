};

// ======================================================================

inline int Direct3d11_DynamicVertexBufferData::getNumberOfVertices() const
{
	return m_numberOfVertices;
}

// ----------------------------------------------------------------------

inline int Direct3d11_DynamicVertexBufferData::getOffset() const
{
	return m_offset;
}

// ----------------------------------------------------------------------

inline ID3D11Buffer *Direct3d11_DynamicVertexBufferData::getRingBuffer() const
{
	// Fall back to the main ring if this instance has never been locked (defensive; a bind
	// without a prior lock would otherwise pass null and skip the draw).
	return m_ringBuffer ? m_ringBuffer : ms_d3dRingBuffer.Get();
}

