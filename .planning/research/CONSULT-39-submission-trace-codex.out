2472-	DirectX::XMFLOAT4 const &diffuse,
2473-	DirectX::XMFLOAT4 const &specular,
2474-	DirectX::XMFLOAT4 const &emissive)
2475-{
2476-	// Plan 17-09 (GAP-5 bump-arm audit): mirror Direct3d9_StaticShaderData.cpp:862
2477-	// `setVertexShaderConstants(VSCR_material, &m_material, 5)` (VSCR_material=11).
2478-	// The VS material struct of Direct3d11_VertexSlot0CB is material[5] @ c11..c15:
2479-	//   material[0] = c11 diffuse, material[1] = c12 ambient, material[2] = c13
2480-	//   specular, material[3] = c14 emissive, material[4].x = c15 specularPower.
2481-	// composeSlot0Shadow never fills c11..c14 and setSpecularPower only fills
2482-	// material[4].x, so the asset VS read cb0[14] (emissive, the diffuse SEED) and
2483-	// cb0[13] (specular tint) as ZERO -> dark diffuse seed + always-black VS
2484-	// specular, diverging from D3D9. We patch the live shadow in place (like
2485-	// setSpecularPower) so the next flush carries them regardless of whether
2486-	// composeSlot0Shadow re-runs. material[1] (c12 ambient) is left untouched:
2487-	// PerPassMaterial carries no ambient and no asset VS in the char-select set
2488-	// reads c12 (the diffuse path seeds from emissive, not material ambient).
2489-	// material[4].x (power) is owned by setSpecularPower -- not touched here.
2490-	Direct3d11_StateCacheNamespace::s_slot0Shadow.material[0] = diffuse;
2491-	Direct3d11_StateCacheNamespace::s_slot0Shadow.material[2] = specular;
2492-	Direct3d11_StateCacheNamespace::s_slot0Shadow.material[3] = emissive;
2493-	Direct3d11_StateCacheNamespace::s_slot0Dirty = true;
2494-}
