  736: 
  737: ThirdPersonStage::ThirdPersonStage(CockpitCamera * const sourceCamera, ShipObject * const 
playerShip)
  738: : HyperspaceIoWin::Stage()
  739: , m_sourceCamera(sourceCamera)
  740: , m_camera(new GameCamera)
  741: , m_playerShip(playerShip)
  742: , m_elapsedTime(0.0f)
  743: {
  744: 	NOT_NULL(sourceCamera);
  745: 	NOT_NULL(playerShip);
