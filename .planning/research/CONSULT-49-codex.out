   33: namespace SpaceEnvironmentNamespace
   34: {
   35: 	float ms_lastAlterTime;
   36: 
   37: 	//-- the planet camera is allowed to 'move' inside a diameter of 100 meters
   38: 	float const s_cameraMovementPlanetRange = 100.0f;
   39: 
   40: 	Watcher<Camera> s_camera;
   41: 
   42: 	SpaceEnvironment * ms_spaceEnvironment = NULL;
