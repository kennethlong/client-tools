   57: 	Tag const TAG_HYPR = TAG(H,Y,P,R);
   58: 	Tag const TAG_STG1 = TAG(S,T,G,1);
   59: 	Tag const TAG_STG2 = TAG(S,T,G,2);
   60: 	Tag const TAG_STG3 = TAG(S,T,G,3);
   61: 
   62: 	char const * const cs_iffHyperspaceFileName = "scene/hyperspace.iff";
   63: 	char const * const cs_cockpitCellNames[] =
   64: 							{
   65: 								"cockpit",
   66: 								"bridge",
   67: 								"bridge66",
   68: 								0
   69: 							};
   70: 
   71: 	// Stage data isn't directly associated with the stages because the data
   72: 	// is read in during install and we want to avoid loading these assets
   73: 	// during the ioWin construction
   74: 
   75: 	struct CockpitStageData
   76: 	{
   77: 		float m_cockpitStageTime;
   78: 		std::string m_particleAppearancePath;
   79: 		std::string m_clientEffectTemplatePath;
   80: 		float m_particleOffset;
   81: 		std::string m_hyperspaceCockpitSoundPath;
   82: 	};
   83: 
   84: 	struct ThirdPersonStageData
   85: 	{
   86: 		float m_thirdPersonStageTime;
   87: 		float m_hyperspaceSpeed;
   88: 		float m_hyperspaceRadianRollsPerSecond;
   89: 		std::string m_hyperspaceSoundPath;
   90: 	};
   91: 
   92: 	CockpitStageData s_enterCockpitStageData;
   93: 	CockpitStageData s_leaveCockpitStageData;
   94: 	ThirdPersonStageData s_thirdPersonStageData;
   95: 
   96: 	typedef std::vector<SoundTemplate const *> CachedSounds;
   97: 	CachedSounds s_cachedSounds;
   98: 
   99: 	bool s_playHyperspaceBeforeSceneChange = false;
  100: 	float s_secondsToDisableOtherObjects = 5.0f;
  101: 	// direction from the ship that the camera is placed for the sling shot
  102: 	Vector const s_cameraOffsetDirection(0.0f, 0.1f, -1.0f);
  103: 	// listener for scene change
  104: 	MessageDispatch::Callback s_callback;
  105: 
  106: 	typedef std::queue<HyperspaceIoWin::Stage *> StageQueue;
  107: 
  108: 	void install();
  109: 	void remove();
  110: 	void load();
  111: 	void load_0000(Iff & iff);
  112: 	HyperspaceIoWin::Stage * popAndGetNextStage(StageQueue & m_stages);
  113: 	HyperspaceIoWin::Stage * getCurrentStage(StageQueue const & m_stages);
  114: 	CellProperty * const findShipCameraCell(ShipObject * shipObject);
  115: 	Object * findTopMostRootObject(Object * object);
  116: 	void deactivateSpaceEnvironmentObjects();
  117: 	void disableOtherObjectsThisFrame(ShipObject * playerShip, GameCamera const * currentCamera);
  118: 	void letterBoxCamera(GameCamera * camera);
  119: }
