 1067: GroundScene::~GroundScene (void)
 1068: {
 1069: 	IGNORE_RETURN (CuiCachedAvatarManager::saveScenePlayer ());
 1070: 
 1071: 	Audio::stopAllSounds ();
 1072: 
 1073: 	GameMusicManager::remove ();
 1074: 
 1075: 	if (m_loading)
 1076: 	{
 1077: 		_onFinishedLoading();
 1078: 	}
 1079: 
 1080: 	if (Game::getScene() == this)
 1081: 	{
 1082: 		Game::_setScene(0);
 1083: 	}
 1084: 
 1085: 	//--
 1086: 	if (m_inputMap)
 1087: 	{
 1088: 		m_inputMap->setMessageQueue        (0);
 1089: 		InputScheme::releaseGroundInputMap (*m_inputMap);
 1090: 		m_inputMap = 0;
 1091: 	}
 1092: 
 1093: 	Object * const player = getPlayer ();
 1094: 	if (player)
 1095: 	{
 1096: 		setPlayer (0);
 1097: 		delete player;
 1098: 	}
 1099: 
 1100: 	//-- delete cameras
 1101: 	ClientWorld::removeCamera(m_cockpitCamera);
 1102: 	delete m_cockpitCamera;
 1103: 	m_cockpitCamera = 0;
 1104: 
 1105: 	ClientWorld::removeCamera(m_shipTurretCamera);
 1106: 	delete m_shipTurretCamera;
 1107: 	m_shipTurretCamera = 0;
 1108: 
 1109: 	ClientWorld::removeCamera (m_freeChaseCamera);
 1110: 	delete m_freeChaseCamera;
 1111: 	m_freeChaseCamera = 0;
 1112: 
 1113: 	ClientWorld::removeCamera (m_freeCamera);
 1114: 	delete m_freeCamera;
 1115: 	m_freeCamera = 0;
 1116: 
 1117: 	ClientWorld::removeCamera (m_debugPortalCamera);
 1118: 	delete m_debugPortalCamera;
 1119: 	m_debugPortalCamera = 0;
 1120: 
 1121: 	ClientWorld::removeCamera (m_structurePlacementCamera);
 1122: 	delete m_structurePlacementCamera;
 1123: 	m_structurePlacementCamera = 0;
 1124: 
 1125: 	ClientWorld::removeCamera(m_flyByCamera);
 1320: 	terrainObject->setDebugName("terrain");
 1321: 	TerrainObject::setUseCache(false);
 1322: 	RenderWorld::addObjectNotifications(*terrainObject);
 1323: 
 1324: 	Appearance * const appearance = AppearanceTemplateList::createAppearance(terrainFileName);
 1325: 	terrainObject->setAppearance(appearance);
 1326: 
 1327: 	ProceduralTerrainAppearance * const proceduralTerrainAppearance = 
dynamic_cast<ProceduralTerrainAppearance *>(appearance);
 1328: 	if (proceduralTerrainAppearance)
 1329: 		
ClientObjectTerrainModificationNotification::setTerrainAppearance(proceduralTerrainAppearance);
 1330: 
 1331: 	terrainObject->addToWorld();
 1332: 
 1333: 	//-- allow override of passed in start time with a normalized start time if requested.
 1334: 
 1335: 	if (!terrainObject->isTimeLocked())
 1336: 	{
 1337: 		float normalizedTime;
 1338: 
 1339: 		if (ConfigClientTerrain::getUseNormalizedTime ())
 1340: 			normalizedTime = fmodf (ConfigClientTerrain::getEnvironmentNormalizedStartTime (), 1.f);
 1341: 		else
 1342: 			normalizedTime = fmodf (timeInSeconds, terrainObject->getEnvironmentCycleTime ()) / 
terrainObject->getEnvironmentCycleTime ();
 1343: 
 1344: 		terrainObject->setTime (normalizedTime, true);
 1345: 	}
 1346: 
 1347: 	m_isTutorial = strstr (terrainFileName, "tutorial") != 0;
 1348: 
 1349: 	bool const isSpace = strstr(terrainFileName, "space_") != 0;
 1350: 
 1351: 		//TODO this belongs in a SpaceScene class, once we make one
 1352: 		
ClientAsteroidManager::setupStaticFields(Game::getSceneIdFromTerrainFilename(terrainFileName));
 1353: 
 1354: 	//-- set camera preferences
 1355: 	int i;
 1356: 	for (i = 0; i < getNumberOfViews (); i++)
 1357: 	{
 1358: 		m_cameras [i]->setNearPlane (ConfigClientGame::getCameraNearPlane ());
 1359: 		m_cameras [i]->setFarPlane  (isTutorial () ? cms_tutorialFarPlaneDistance : (isSpace ? 
ms_cameraFarPlaneSpace : ms_cameraFarPlane));
 1360: 		m_cameras [i]->setHorizontalFieldOfView (convertDegreesToRadians 
(ms_cameraFieldOfViewDegrees));
 1361: 	}
 1362: 
 1363: 	//-- Tell ShaderPrimitiveSetTemplate it doesn't need to create the upward indices
 1364: 	ShaderPrimitiveSetTemplate::setAllowUpwardIndicesCreation(!isSpace);
 1365: 
 1366: #if PRODUCTION == 1
 1367: 	FATAL(isSpace && proceduralTerrainAppearance, ("0xA50MM3R5 unknown error 1"));
 1368: 	FATAL(!isSpace && !proceduralTerrainAppearance, ("0xA50MM3R5 unknown error 2"));
 1369: #endif
 1370: }
