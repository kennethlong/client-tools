  518: 
  519: CockpitStage::~CockpitStage()
  520: {
  521: 	delete m_camera;
  522: 
  523: 	if (m_particleObject != 0)
  524: 	{
  525: 		delete m_particleObject.getPointer();
  526: 		m_particleObject = 0;
  527: 	}
  528: }
