 1179: 			}
 1180: 
 1181: 			if (m_currentView == CI_shipTurret)
 1182: 			{
 1183: 				if (m_inputMap)
 1184: 					m_inputMap->handleInputReset ();
 1185: 			}
 1186: 
 1187: 			if (m_currentView == CI_freeChase)
 1188: 			{
 1189: 				if (m_inputMap)
 1190: 					m_inputMap->handleInputReset ();
 1191: 			}
 1192: 
 1193: 			if (m_currentView == CI_free)
 1194: 			{
 1195: 				if (m_freeCameraInputMap)
 1196: 					m_freeCameraInputMap->handleInputReset ();
 1197: 			}
 1198: 
 1199: 			if (m_currentView == CI_debugPortal)
 1200: 			{
 1201: 				if (m_debugPortalCameraInputMap)
 1202: 					m_debugPortalCameraInputMap->handleInputReset ();
 1203: 			}
 1204: 
 1205: 			if (m_currentView == CI_structurePlacement)
 1206: 			{
 1207: 				if (m_structurePlacementCameraInputMap)
 1208: 					m_structurePlacementCameraInputMap->handleInputReset ();
 1209: 			}
 1210: 
 1211: 			m_cameras [m_currentView]->setActive (false);
 1212: 		}
 1213: 
 1214: 		if (newView == CI_free)
 1215: 		{
 1216: 			NOT_NULL (m_freeCameraInputMap);
 1217: 			m_freeCameraInputMap->beginFrame ();
 1218: 			m_freeCameraInputMap->beginFrame ();
 1219: 		}
 1220: 
 1221: 		if (newView == CI_debugPortal)
 1222: 		{
 1223: 			NOT_NULL (m_debugPortalCameraInputMap);
 1224: 			m_debugPortalCameraInputMap->beginFrame ();
 1225: 			m_debugPortalCameraInputMap->beginFrame ();
 1226: 		}
 1227: 
 1228: 		if (newView == CI_structurePlacement)
 1229: 		{
 1230: 			NOT_NULL (m_structurePlacementCameraInputMap);
 1231: 			m_structurePlacementCameraInputMap->beginFrame ();
 1232: 			m_structurePlacementCameraInputMap->beginFrame ();
 1233: 		}
 1234: 	}
 1235: 
 1236: 	m_currentView = newView;
 1237: 	m_cameras [m_currentView]->setActive (true);
 1238: }
