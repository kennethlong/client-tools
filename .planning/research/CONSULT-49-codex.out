  629: 
  630: void GameNetwork::receiveCmdStartScene (const CmdStartScene &s)
  631: {
  632: 	DEBUG_FATAL(s_instance == 0, ("GameNetwork not installed"));
  633: 	if (m_acceptSceneCommand)
  634: 	{
  635: 		//@todo for now we only support ground scenes.
  636: 		startScene(s.getSceneName(), s.getObjectId(), s.getTemplateName(), s.getStartPosition(), 
s.getStartYaw(), static_cast<float> (s.getTimeSeconds()), s.getDisableWorldSnapshot());
  637: 	}
  638: 	else
  639: 		WARNING (true, ("Discarding CmdStartScene message because we don't want to enter a scene 
right now."));
  640: }
