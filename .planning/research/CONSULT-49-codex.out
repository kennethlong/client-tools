  538: 
  539: bool CockpitStage::hideOtherObjects() const
  540: {
  541: 	return true;
  542: }
  543: 
  544: //-------------------------------------------------------------------
  545: 
  546: void CockpitStage::begin()
  547: {
  548: 	if (m_sourceCamera == 0)
  549: 	{
  550: 		return;
  551: 	}
  552: 
  553: 	if (m_playerShip == 0)
  554: 	{
  555: 		return;
  556: 	}
  557: 
  558: 	IGNORE_RETURN(Audio::playSound(getStageData().m_hyperspaceCockpitSoundPath.c_str()));
  559: 
  560: 	// camera location
  561: 	CellProperty * const targetCellProperty_p = findShipCameraCell(m_playerShip);
  562: 	m_camera->setParentCell(targetCellProperty_p);
  563: 	CellProperty::setPortalTransitionsEnabled(false);
  564: 	m_camera->setTransform_o2p(m_sourceCamera->getHyperspaceCameraOffset());
  565: 	CellProperty::setPortalTransitionsEnabled(true);
  566: 	m_camera->setActive(true);
  567: 
  568: 	SaveCameraParameters s;
  569: 	s.save(m_sourceCamera);
  570: 	s.restore(m_camera);
  571: 
  572: 	ClientWorld::addCamera(m_camera);
  573: 
  574: 	// if non POB, hide the player
  575: 	if (m_playerShip->getPortalProperty() == 0)
  576: 	{
  577: 		m_camera->addExcludedObject(Game::getConstPlayer());
  578: 	}
  579: 
  580: 	{
  581: 		// add the particle to the world
  582: 		Appearance * appearance = 
AppearanceTemplateList::createAppearance(getStageData().m_particleAppearancePath.c_str());
  583: 		if (appearance != 0)
  584: 		{
  585: 			ParticleEffectAppearance * const particleEffectAppearance = 
ParticleEffectAppearance::asParticleEffectAppearance(appearance);
  586: 
  587: 			if (particleEffectAppearance != 0)
  588: 			{
  589: 				m_particleObject = new MemoryBlockManagedObject();
  590: 				m_particleObject->setAppearance(particleEffectAppearance);
  591: 
  592: 				particleEffectAppearance->setEnabled(true);
  593: 
  594: 				RenderWorld::addObjectNotifications(*m_particleObject);
  595: 				SetupClientParticle::addNotifications(*m_particleObject);
  596: 
  597: 				m_particleObject->addToWorld();
  598: 				m_particleObject->scheduleForAlter();
  599: 
  600: 				Transform transform;
  601: 				transform.move_l(Vector(0.0f, 0.0f, getStageData().m_particleOffset));
  602: 				m_particleObject->setTransform_o2p(transform);
  603: 				m_camera->addChildObject_o(m_particleObject);
  604: 			}
  605: 
  606: 			if (particleEffectAppearance == 0)
  607: 			{
  608: 				delete appearance;
  609: 			}
  610: 		}
  611: 	}
  612: 
  613: 	{
  614: 		// add the client effect to the world and play it
  615: 		CrcLowerString const name(getStageData().m_clientEffectTemplatePath.c_str());
  616: 		ClientEffectTemplate const * const clientEffectTemplate = 
ClientEffectTemplateList::fetch(name);
  617: 
  618: 		if (clientEffectTemplate != 0)
  619: 		{
  620: 			Vector const effectPosition_p(m_camera->getPosition_p());
  621: 			ClientEffect * const clientEffect = 
clientEffectTemplate->createClientEffect(targetCellProperty_p, effectPosition_p, Vector::unitY);
  622: 			clientEffect->execute();
  623: 			delete clientEffect;
  624: 			clientEffectTemplate->release();
  625: 		}
  626: 	}
  627: }
  628: 
  629: //-------------------------------------------------------------------
  630: 
  631: void CockpitStage::alter(float time)
  632: {
  633: 	m_elapsedTime += time;
  634: }
  635: 
  636: //-------------------------------------------------------------------
  637: 
  638: void CockpitStage::draw()
  639: {
  640: 	if (m_sourceCamera == 0)
  641: 	{
  642: 		return;
  643: 	}
  644: 
  645: 	if (m_playerShip == 0)
  646: 	{
  647: 		return;
  648: 	}
  649: 
  650: 	if (hideOtherObjects())
  651: 	{
  652: 		if (m_elapsedTime > s_secondsToDisableOtherObjects)
  653: 		{
  654: 			if (!m_deactivatedEnvironment)
  655: 			{
  656: 				deactivateSpaceEnvironmentObjects();
  657: 				m_deactivatedEnvironment = true;
  658: 			}
  659: 			disableOtherObjectsThisFrame(m_playerShip, m_camera);
  660: 		}
  661: 	}
  662: 
  663: 	PostProcessingEffectsManager::preSceneRender();
  664: 	Bloom::preSceneRender();
  665: 
  666: 	// camera location
  667: 	m_camera->setParentCell(findShipCameraCell(m_playerShip));
  668: 	CellProperty::setPortalTransitionsEnabled(false);
  669: 	m_camera->setTransform_o2p(m_sourceCamera->getHyperspaceCameraOffset());
  670: 	CellProperty::setPortalTransitionsEnabled(true);
  671: 	m_camera->setActive(true);
  672: 	
  673: 	// render the scene
  674: 	PackedRgb backgroundColor = PackedRgb::solidBlack;
  675: 
  676: 	Graphics::clearViewport(false, backgroundColor.asUint32(), true, 1.0f, true, 0);
  677: 	ClientWorld::addRenderHookFunctions(m_camera);
  678: 	m_camera->renderScene();
  679: 	ClientWorld::removeRenderHookFunctions();
  680: 
  681: 	// render shadow alpha
  682: 	ShadowVolume::renderShadowAlpha(m_camera);
  683: 
  684: 	Bloom::postSceneRender();
  685: 	PostProcessingEffectsManager::postSceneRender();
