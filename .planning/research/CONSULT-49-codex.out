  980: /** this constructor is called for multi-player mode
  981: *
  982: */
  983: 
  984: GroundScene::GroundScene(
  985: 	const char *const terrainFilename, 
  986: 	const NetworkId & playerOID, 
  987: 	const char *const templateName, 
  988: 	const Vector &    startPosition, 
  989: 	const float       startYaw, 
  990: 	const float       timeInSeconds, 
  991: 	const bool        disableSnapshot
  992: 	)
  993: :	NetworkScene ("GroundScene"),
  994: 	m_inputMap (0),
  995: 	m_debugPortalCameraInputMap (0),
  996: 	m_structurePlacementCameraInputMap (0),
  997: 	m_freeCameraInputMap (0),
  998: 	m_mouseCursor (new MouseCursor (0, MouseCursor::S_relative)),
  999: 	m_lastYawPitchMod (new Vector2d),
 1000: 	m_cockpitCamera(0),
 1001: 	m_shipTurretCamera(0),
 1002: 	m_freeChaseCamera (0),
 1003: 	m_freeCamera (0),
 1004: 	m_debugPortalCamera (0),
 1005: 	m_structurePlacementCamera (0),
 1006: 	m_flyByCamera(NULL),
 1007: 	m_currentView (-1),
 1008: 	m_disableWorldSnapshot(disableSnapshot),
 1009: 	m_usingGodClientCamera(false),
 1010: 	m_usingGodClientInteriorCamera(false),
 1011: 	m_loading (true),
 1012: 	m_sentSceneChannel(false),
 1013: 	m_receivedSceneReady(false),
 1014: 	m_noDraw(false),
 1015: 	m_currentLoadCount (0),
 1016: 	m_debugKeyContext (0),
 1017: 	m_debugKeySubContext (),
 1018: 	m_debugKeyContextWeaponObjectTemplate (0),
 1019: 	m_serverTimeOffset (0),
 1020: 	m_overheadMap (new OverheadMap),
 1021: 	m_modeCallback (0),
 1022: 	m_context (0),
 1023: 	m_currentMode (false),
 1024: 	m_spaceTargetBracketOverlay(new SpaceTargetBracketOverlay),
 1025: 	m_clientPathObject (0),
 1026: 	m_debugPointList (new PointList),
 1027: 	m_debugLineList (new LineList),
 1028: 	m_isTutorial (false),
 1029: 	m_destroyObjectSet(new DestroyObjectSet),
 1030: 	m_destroyObjectTimer(Random::randomReal(0.5f, 1.f))
 1031: {
 1032: 	Audio::setLargePreMixBuffer();
 1033: 	Audio::silenceAllNonBackgroundMusic();
 1034: 
 1035: 	ms_loadingScreenRender = true;
 1036: 	ms_loadingScreenRenderYaw = 0.0f;
 1037: 
 1038: 	//-- Create the player.  Disable asynchronous loading so character
 1039: 	//   is properly loaded and baked at construction time.
 1040: 	bool const wasEnabled = AsynchronousLoader::isEnabled();
 1041: 	AsynchronousLoader::disable();
 1042: 
 1043: 	CreatureObject* player = 
dynamic_cast<CreatureObject*>(ObjectTemplate::createObject(templateName));
 1044: 	FATAL (!player, ("cannot load template %s\n", templateName));
 1045: 
 1046: 	if (wasEnabled)
 1047: 		AsynchronousLoader::enable();
 1048: 
 1049: 	player->setNetworkId(playerOID);
 1050: 	player->yaw_o(startYaw);
 1051: 	player->setPosition_p(startPosition);
 1052: 	RenderWorld::addObjectNotifications(*player);
 1053: 	CellProperty::addPortalCrossingNotification(*player);
 1054: 
 1055: 	CollisionProperty * collision = player->getCollisionProperty();
 1056: 	if(collision)
 1057: 		collision->setPlayer(true);
 1058: 
 1059: 	// TODO: remove this and retrieve the name from the ConnectionManager-alike
 1060: 	player->setDebugName (ConfigClientGame::getPlayerName ());
 1061: 
 1062: 	init (terrainFilename, player, timeInSeconds);
 1063: }
