  754: 
  755: //-------------------------------------------------------------------
  756: 
  757: void ThirdPersonStage::begin()
  758: {
  759: 	if (m_sourceCamera == 0)
  760: 	{
  761: 		return;
  762: 	}
  763: 
  764: 	if (m_playerShip == 0)
  765: 	{
  766: 		return;
  767: 	}
  768: 
  769: 	IGNORE_RETURN(Audio::playSound(s_thirdPersonStageData.m_hyperspaceSoundPath.c_str()));
  770: 
  771: 	float const maximumZoom = m_sourceCamera->getMaximumZoomOutSetting();
  772: 	Vector const offset_p(s_cameraOffsetDirection * maximumZoom);
  773: 
  774: 	CellProperty * const targetCellProperty_p = m_playerShip->getParentCell();
  775: 	Transform targetTransform_p(m_playerShip->getTransform_o2c());
  776: 	targetTransform_p.move_l(offset_p);
  777: 
  778: 	// camera location
  779: 	m_camera->setParentCell(targetCellProperty_p);
  780: 	CellProperty::setPortalTransitionsEnabled(false);
  781: 	m_camera->setTransform_o2p(targetTransform_p);
  782: 	CellProperty::setPortalTransitionsEnabled(true);
  783: 	m_camera->setActive(true);
  784: 
  785: 	SaveCameraParameters s;
  786: 	s.save(m_sourceCamera);
  787: 	s.restore(m_camera);
  788: 
  789: 	ClientWorld::addCamera(m_camera);
  790: 	deactivateSpaceEnvironmentObjects();
  791: }
  792: 
  793: //-------------------------------------------------------------------
  794: 
  795: void ThirdPersonStage::alter(float time)
  796: {
  797: 	if (m_sourceCamera == 0)
  798: 	{
  799: 		return;
  800: 	}
  801: 
  802: 	if (m_playerShip == 0)
  803: 	{
  804: 		return;
  805: 	}
  806: 
  807: 	m_elapsedTime += time;
  808: 
  809: 	float const distanceToMove = s_thirdPersonStageData.m_hyperspaceSpeed * time;
  810: 	float const radiansToRoll = s_thirdPersonStageData.m_hyperspaceRadianRollsPerSecond * time;
  811: 
  812: 	Transform transform_o = m_playerShip->getTransform_o2p();
  813: 	transform_o.move_l(Vector(0.0f, 0.0f, distanceToMove));
  814: 	transform_o.roll_l(radiansToRoll);
  815: 
  816: 	m_playerShip->setTransform_o2p(transform_o);
  817: 
  818: 	ShipController * const controller = safe_cast<ShipController 
*>(m_playerShip->getController());
  819: 	if (controller != 0)
  820: 	{
  821: 		controller->setShipDynamicsModelTransform(transform_o);
  822: 	}
  823: }
  824: 
  825: //-------------------------------------------------------------------
  826: 
  827: void ThirdPersonStage::draw()
  828: {
  829: 	if (m_sourceCamera == 0)
  830: 	{
  831: 		return;
  832: 	}
  833: 
  834: 	if (m_playerShip == 0)
  835: 	{
  836: 		return;
  837: 	}
  838: 
  839: 	disableOtherObjectsThisFrame(m_playerShip, m_camera);
  840: 
  841: 	PostProcessingEffectsManager::preSceneRender();
  842: 	Bloom::preSceneRender();
  843: 
  844: 	CellProperty * const targetCellProperty_p = m_playerShip->getParentCell();
  845: 	Transform targetTransform_p(m_playerShip->getTransform_o2c());
  846: 	targetTransform_p.setPosition_p(m_camera->getTransform_o2c().getPosition_p());
  847: 
  848: 	// camera location
  849: 	m_camera->setParentCell(targetCellProperty_p);
  850: 	CellProperty::setPortalTransitionsEnabled(false);
  851: 	m_camera->setTransform_o2p(targetTransform_p);
  852: 	CellProperty::setPortalTransitionsEnabled(true);
  853: 	m_camera->setActive(true);
  854: 
  855: 	// render the scene
  856: 	PackedRgb backgroundColor = PackedRgb::solidBlack;
  857: 
  858: 	Graphics::clearViewport(false, backgroundColor.asUint32(), true, 1.0f, true, 0);
  859: 	ClientWorld::addRenderHookFunctions(m_camera);
  860: 	m_camera->renderScene();
  861: 	ClientWorld::removeRenderHookFunctions();
  862: 
  863: 	// render shadow alpha
  864: 	ShadowVolume::renderShadowAlpha(m_camera);
  865: 
  866: 	Bloom::postSceneRender();
  867: 	PostProcessingEffectsManager::postSceneRender();
  868: }
