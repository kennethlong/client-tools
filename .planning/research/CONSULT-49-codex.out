  121: //-------------------------------------------------------------------
  122: 
  123: void HyperspaceIoWinNamespace::install()
  124: {
  125: 	load();
  126: }
  127: 
  128: //-------------------------------------------------------------------
  129: 
  130: void HyperspaceIoWinNamespace::load()
  131: {
  132: 	Iff iff;
  133: 	if (iff.open(cs_iffHyperspaceFileName, true))
  134: 	{
  135: 		iff.enterForm(TAG_HYPR);
  136: 
  137: 		switch (iff.getCurrentName())
  138: 		{
  139: 			case TAG_0000:
  140: 				load_0000(iff);
  141: 				break;
  142: 			default:
  143: 				{
  144: 					char tagBuffer [5];
  145: 					ConvertTagToString(iff.getCurrentName(), tagBuffer);
  146: 					char buffer [128];
  147: 					iff.formatLocation(buffer, sizeof(buffer));
  148: 					DEBUG_FATAL(true,("unknown layer type %s/%s", buffer, tagBuffer));
  149: 				}
  150: 				break;
  151: 		}
  152: 
  153: 		iff.exitForm();
  154: 	}
  155: 	else
  156: 	{
  157: 		DEBUG_WARNING(true,("Hyperspace::HyperspaceVisual::load unable to open file %s", 
cs_iffHyperspaceFileName));
  158: 	}
  159: 
  160: 	if (!s_enterCockpitStageData.m_hyperspaceCockpitSoundPath.empty())
  161: 	{
  162: 		s_cachedSounds.push_back(SoundTemplateList::fetch(s_enterCockpitStageData.m_hyperspaceCockpi
tSoundPath.c_str()));
  163: 	}
  164: 
  165: 	if (!s_leaveCockpitStageData.m_hyperspaceCockpitSoundPath.empty())
  166: 	{
  167: 		s_cachedSounds.push_back(SoundTemplateList::fetch(s_leaveCockpitStageData.m_hyperspaceCockpi
tSoundPath.c_str()));
  168: 	}
  169: 
  170: 	if (!s_thirdPersonStageData.m_hyperspaceSoundPath.empty())
  171: 	{
  172: 		s_cachedSounds.push_back(SoundTemplateList::fetch(s_thirdPersonStageData.m_hyperspaceSoundPa
th.c_str()));
  173: 	}
  174: }
  175: 
  176: //-------------------------------------------------------------------
  177: 
  178: void HyperspaceIoWinNamespace::remove()
  179: {
  180: 	CachedSounds::const_iterator ii = s_cachedSounds.begin();
  181: 	CachedSounds::const_iterator iiEnd = s_cachedSounds.end();
  182: 
  183: 	for (; ii != iiEnd; ++ii)
  184: 	{
  185: 		SoundTemplate const * soundTemplate = *ii;
  186: 		if (soundTemplate != 0)
  187: 		{
  188: 			SoundTemplateList::release(soundTemplate);
  189: 		}
  190: 	}
  191: 
  192: 	s_cachedSounds.clear();
  193: }
  194: 
  195: //-------------------------------------------------------------------
  196: 
  197: void HyperspaceIoWinNamespace::load_0000(Iff & iff)
  198: {
  199: 	iff.enterForm(TAG_0000);
  200: 		iff.enterChunk(TAG_DATA);
  201: 			s_secondsToDisableOtherObjects = iff.read_float();
  202: 		iff.exitChunk();
  203: 
  204: 		iff.enterChunk(TAG_STG1);
  205: 			s_enterCockpitStageData.m_cockpitStageTime = iff.read_float();
  206: 			s_enterCockpitStageData.m_particleAppearancePath = iff.read_stdstring();
  207: 			s_enterCockpitStageData.m_clientEffectTemplatePath = iff.read_stdstring();
  208: 			s_enterCockpitStageData.m_particleOffset = iff.read_float();
  209: 			s_enterCockpitStageData.m_hyperspaceCockpitSoundPath = iff.read_stdstring();
  210: 		iff.exitChunk();
  211: 
  212: 		iff.enterChunk(TAG_STG2);
  213: 			s_thirdPersonStageData.m_thirdPersonStageTime = iff.read_float();
  214: 			s_thirdPersonStageData.m_hyperspaceSpeed = iff.read_float();
  215: 			s_thirdPersonStageData.m_hyperspaceRadianRollsPerSecond = iff.read_float();
  216: 			s_thirdPersonStageData.m_hyperspaceSoundPath = iff.read_stdstring();
  217: 		iff.exitChunk();
  218: 
  219: 		iff.enterChunk(TAG_STG3);
  220: 			s_leaveCockpitStageData.m_cockpitStageTime = iff.read_float();
  221: 			s_leaveCockpitStageData.m_particleAppearancePath = iff.read_stdstring();
  222: 			s_leaveCockpitStageData.m_clientEffectTemplatePath = iff.read_stdstring();
  223: 			s_leaveCockpitStageData.m_particleOffset = iff.read_float();
  224: 			s_leaveCockpitStageData.m_hyperspaceCockpitSoundPath = iff.read_stdstring();
  225: 		iff.exitChunk();
  226: 
  227: 	iff.exitForm(TAG_0000);
  228: }
