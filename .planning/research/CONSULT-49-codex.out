  486: 		if (gs != 0)
  487: 		{
  488: 			gs->close ();
  489: 			delete gs;
  490: 			setAcceptSceneCommand(true);
  491: 		}
  492: 	}
  493: 
  494: 	//@todo we ONLY support ground scenes now so let all messages regardless of type go through
  495: 	Game::setScene(
  496: 		false,
  497: 		sceneName.c_str(), 
  498: 		objectId, 
  499: 		templateName.c_str(), 
  500: 		startPosition, 
  501: 		startYaw, 
  502: 		timeInSeconds, 
  503: 		disableSnapshot
  504: 	);
