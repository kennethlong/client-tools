  504: CockpitStage::CockpitStage(CockpitCamera * const sourceCamera, ShipObject * const playerShip)
  505: : HyperspaceIoWin::Stage()
  506: , m_sourceCamera(sourceCamera)
  507: , m_camera(new GameCamera)
  508: , m_playerShip(playerShip)
  509: , m_elapsedTime(0.0f)
  510: , m_particleObject()
  511: , m_deactivatedEnvironment(false)
  512: {
  513: 	NOT_NULL(sourceCamera);
  514: 	NOT_NULL(playerShip);
  515: }
