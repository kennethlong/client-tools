 1099: //-------------------------------------------------------------------
 1100: 
 1101: void HyperspaceIoWin::onSceneChanged(bool const &)
 1102: {
 1103: 	Stage * stage = getCurrentStage(m_stages);
 1104: 
 1105: 	while (stage != 0)
 1106: 	{
 1107: 		stage->finish();
 1108: 		delete stage;
 1109: 
 1110: 		stage = popAndGetNextStage(m_stages);
 1111: 	}
 1112: 
 1113: 	IoWinManager::close(this);
 1114: }
