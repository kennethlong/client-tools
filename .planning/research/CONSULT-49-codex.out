 1380: void GroundScene::postload (void)
 1381: {
 1382: 	FileName fileName (TerrainObject::getConstInstance ()->getAppearance 
()->getAppearanceTemplate ()->getName ());
 1383: 	fileName.stripPathAndExt ();
 1384: 
 1385: 	if (!m_disableWorldSnapshot)
 1386: 	{
 1387: 		WorldSnapshot::load(fileName);
 1388: 	}
 1389: 	else
 1390: 	{
