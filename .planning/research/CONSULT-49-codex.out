  232: HyperspaceIoWin::Stage * HyperspaceIoWinNamespace::popAndGetNextStage(StageQueue & m_stages)
  233: {
  234: 	if (!m_stages.empty())
  235: 	{
  236: 		m_stages.pop();
  237: 		return getCurrentStage(m_stages);
  238: 	}
  239: 	return 0;
  240: }
