 1397: //-------------------------------------------------------------------
 1398: 
 1399: void GroundScene::scanInputMapForSceneMessages (InputMap * inputMap)
 1400: {
 1401: 	NOT_NULL (inputMap);
 1402: 	const MessageQueue* const queue = inputMap->getMessageQueue ();
 1403: 	NOT_NULL (queue);
 1404: 
 1405: 	bool resetInputMap = false;
 1406: 
 1407: 	int i;
 1408: 	for (i = 0; i < queue->getNumberOfMessages (); i++)
 1409: 	{
 1410: 		int  message;
 1411: 		float value;
 1412: 
 1413: 		queue->getMessage (i, &message, &value);
 1414: 
 1415: 		switch (message)
 1416: 		{
 1417: 		case CM_freeChaseCamera:
 1418: 			{
 1419: 				if (m_usingGodClientInteriorCamera)
 1420: 					setView (CI_free);
 1421: 				else
 1422: 				{
 1423: 					int view = CI_freeChase;
 1424: 
 1425: 					CreatureObject const * const player = safe_cast<CreatureObject const *>(getPlayer());
 1426: 					if (player)
 1427: 					{
 1428: 						int const shipStation = player->getShipStation();
 1429: 						if (shipStation == ShipStation::ShipStation_Pilot || shipStation == 
ShipStation::ShipStation_Operations)
 1430: 							view = CI_cockpit;
 1431: 						else if (shipStation >= ShipStation::ShipStation_Gunner_First && shipStation <= 
ShipStation::ShipStation_Gunner_Last)
 1432: 							view = CI_shipTurret;
 1433: 					}
 1434: 					setView(view);
 1435: 				}
 1436: 
 1437: 				resetInputMap = true;
 1438: 			}
 1439: 			break;
 1440: 
 1441: 		case CM_uiGameMenuActivate:
 1442: 			resetInputMap = true;
 1443: 			break;
 1444: 
 1445: 		case CM_radarMap:
 1446: 			m_overheadMap->toggle ();
 1447: 			break;
 1448: 
 1449: 		case CM_radarZoom:
 1450: 			m_overheadMap->zoom (value > 0);
 1451: 			break;
 1452: 
