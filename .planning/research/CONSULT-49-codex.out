 1087: 
 1088: void HyperspaceIoWin::draw() const
 1089: {
 1090: 	if (!CutScene::isRunning())
 1091: 	{
 1092: 		if (m_currentStageToRender != 0)
 1093: 		{
 1094: 			m_currentStageToRender->draw();
 1095: 		}
 1096: 	}
 1097: }
