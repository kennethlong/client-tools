   45: using namespace SpaceEnvironmentNamespace;
   46: 
   47: // ======================================================================
   48: // PUBLIC SpaceEnvironment
   49: // ======================================================================
   50: 
   51: SpaceEnvironment::SpaceEnvironment(ClientSpaceTerrainAppearance const & 
clientSpaceTerrainAppearance) :
   52: 	m_clientSpaceTerrainAppearance(clientSpaceTerrainAppearance),
   53: 	m_clearColor(),
   54: 	m_lightVector(new LightVector),
   55: 	m_parallelLightVector(new LightVector),
   56: 	m_objectVector(new ObjectVector),
   57: 	m_objectsFollowCameraVector(new ObjectVector),
   58: 	m_objectsToDisableForHyperspace(new ObjectVector)
   59: {
   60: 	FATAL(ms_spaceEnvironment, ("SpaceEnvironment already exists"));
   61: 	ms_spaceEnvironment = this;
   62: 
   63: 	RenderWorld::setClearDepthAndStencilBufferAfterRenderingEnvironment(true);
   64: 
   65: 	SpaceTerrainAppearanceTemplate const * const spaceTerrainAppearanceTemplate = 
safe_cast<SpaceTerrainAppearanceTemplate const 
*>(clientSpaceTerrainAppearance.getAppearanceTemplate());
   66: 	NOT_NULL(spaceTerrainAppearanceTemplate);
   67: 
   68: 	//-- Clear color
   69: 	{
   70: 		PackedRgb const & clearColor = spaceTerrainAppearanceTemplate->getClearColor();
   71: 		m_clearColor = clearColor;
   72: 	}
   73: 
   74: 	//-- Lights
   75: 	{
   76: 		VectorArgb const & ambientColor = spaceTerrainAppearanceTemplate->getAmbientColor();
   77: 
   78: 		Light * const light = new Light(Light::T_ambient, VectorArgb::solidBlack);
   79: 		light->setDebugName("ambient light");
   80: 		light->setDiffuseColor(ambientColor);
   81: 		light->addToWorld();
   82: 		RenderWorld::addWorldEnvironmentLight(light);
   83: 
   84: 		m_lightVector->push_back(light);
   85: 	}
   86: 
   87: 	{
   88: 		int const numberOfParallelLights = 
spaceTerrainAppearanceTemplate->getNumberOfParallelLights();
   89: 		for (int i = 0; i < numberOfParallelLights; ++i)
   90: 		{
   91: 			VectorArgb const & diffuseColor = 
spaceTerrainAppearanceTemplate->getParallelLightDiffuseColor(i);
   92: 			VectorArgb const & specularColor = 
spaceTerrainAppearanceTemplate->getParallelLightSpecularColor(i);
   93: 			Vector const & direction_w = 
spaceTerrainAppearanceTemplate->getParallelLightDirection_w(i);
   94: 
   95: 			Light * const light = new Light(Light::T_parallel, VectorArgb::solidBlack);
   96: 
   97: 			char name[128];
   98: 			IGNORE_RETURN(snprintf(name, sizeof(name) - 1, "parallel light %i", i));
   99: 			light->setDebugName(name);
  100: 			light->setDiffuseColor(diffuseColor);
  101: 			light->setSpecularColor(specularColor);
  102: 			light->yaw_o(direction_w.theta());
  103: 			light->pitch_o(direction_w.phi());
  104: 			light->addToWorld();
  105: 			RenderWorld::addWorldEnvironmentLight(light);
  106: 
  107: 			m_lightVector->push_back(light);
  108: 			m_parallelLightVector->push_back(light);
  109: 		}
  110: 	}
  111: 
  112: 	//-- Fog
  113: 	{
  114: 		bool const fogEnabled = spaceTerrainAppearanceTemplate->getFogEnabled();
  115: 		PackedArgb const & fogColor = spaceTerrainAppearanceTemplate->getFogColor();
  116: 		float const fogDensity = spaceTerrainAppearanceTemplate->getFogDensity();
  117: 
  118: 		CellProperty::getWorldCellProperty()->setFogEnabled(fogEnabled);
  119: 		CellProperty::getWorldCellProperty()->setFogColor(fogColor);
  120: 		CellProperty::getWorldCellProperty()->setFogDensity(fogDensity);
  121: 	}
  122: 
  123: 	//-- Environment map texture
  124: 	{
  125: 		CrcString const & textureName = spaceTerrainAppearanceTemplate->getEnvironmentTextureName();
  126: 
  127: 		Texture const * const texture = TextureList::fetch(textureName);
  128: 		CellProperty::getWorldCellProperty()->setEnvironmentTexture(texture);
  129: 		texture->release();
  130: 	}
  131: 
  132: 	//-- SkyBox
  133: 	{
  134: 		bool const cubeMap = spaceTerrainAppearanceTemplate->getSkyBoxCubeMap();
  135: 		CrcString const & textureNameMask = 
spaceTerrainAppearanceTemplate->getSkyBoxTextureNameMask();
  136: 
  137: 		if (*textureNameMask.getString())
  138: 		{
  139: 			Object * const object = new Object;
  140: 			object->setDebugName("skybox");
  141: 
  142: 			if (cubeMap)
  143: 			{
  144: 				Texture const * const texture = TextureList::fetch(textureNameMask.getString());
  145: 				object->setAppearance(new SkyBoxAppearance(texture, 1.f));
  146: 				texture->release();
  147: 			}
  148: 			else
  149: 			{
  150: 				object->setAppearance(new SkyBox6SidedAppearance(textureNameMask.getString()));
  151: 			}
  152: 
  153: 			RenderWorld::addWorldEnvironmentObject(object);
  154: 
  155: 			m_objectVector->push_back(object);
  156: 		}
  157: 	}
  158: 
  159: 	//-- StarAppearance
  160: 	{
  161: 		int const numberOfStars = spaceTerrainAppearanceTemplate->getNumberOfStars();
  162: 		if (numberOfStars > 0)
  163: 		{
  164: 			CrcString const & colorRampName = spaceTerrainAppearanceTemplate->getStarColorRampName();
  165: 
  166: 			Object * const object = new Object;
  167: 			object->setDebugName("stars");
  168: 			object->setAppearance(new StarAppearance(colorRampName.getString(), numberOfStars, false));
  169: 			RenderWorld::addWorldEnvironmentObject(object);
  170: 
  171: 			m_objectVector->push_back(object);
  172: 		}
  173: 	}
  174: 
  175: 	//-- Celestials
  176: 	{
  177: 		int const numberOfCelestials = spaceTerrainAppearanceTemplate->getNumberOfCelestials();
  178: 		for (int i = 0; i < numberOfCelestials; ++i)
  179: 		{
  180: 			CrcString const & frontShaderTemplateName = 
spaceTerrainAppearanceTemplate->getCelestialFrontShaderTemplateName(i);
  181: 			float const frontSize = spaceTerrainAppearanceTemplate->getCelestialFrontSize(i);
  182: 			CrcString const & backShaderTemplateName = 
spaceTerrainAppearanceTemplate->getCelestialBackShaderTemplateName(i);
  183: 			float const backSize = spaceTerrainAppearanceTemplate->getCelestialBackSize(i);
  184: 			Vector const & direction_w = spaceTerrainAppearanceTemplate->getCelestialDirection_w(i);
  185: 
  186: 			CelestialObject * const celestialObject = new 
CelestialObject(backShaderTemplateName.getString(), backSize, frontShaderTemplateName.getString(), 
frontSize, true);
  187: 			celestialObject->setAlpha(1.f);
  188: 			celestialObject->yaw_o(direction_w.theta());
  189: 			celestialObject->pitch_o(direction_w.phi());
  190: 			RenderWorld::addWorldEnvironmentObject(celestialObject);
  191: 
  192: 			m_objectVector->push_back(celestialObject);
  193: 		}
  194: 	}
  195: 
  196: 	//-- DistantAppearances
  197: 	{
  198: 
  199: 		int const numberOfDistantAppearances = 
spaceTerrainAppearanceTemplate->getNumberOfDistantAppearances();
  200: 		for (int i = 0; i < numberOfDistantAppearances; ++i)
  201: 		{
  202: 			CrcString const & appearanceTemplateName = 
spaceTerrainAppearanceTemplate->getDistantAppearanceTemplateName(i);
  203: 			Vector const & direction_w = 
spaceTerrainAppearanceTemplate->getDistantAppearanceDirection_w(i);
  204: 			Vector const & orientation_w = 
spaceTerrainAppearanceTemplate->getDistantAppearanceOrientation_w(i);
  205: 
  206: 			bool const isInfiniteDistance = 
spaceTerrainAppearanceTemplate->isDistantAppearanceInfiniteDistance(i);
  207: 
  208: 			Object * const object = new Object();
  209: 			
object->setAppearance(AppearanceTemplateList::createAppearance(appearanceTemplateName.getString()));
  210: 			object->setPosition_p(direction_w);
  211: 			object->yaw_o(orientation_w.x);
  212: 			object->pitch_o(orientation_w.y);
  213: 			object->roll_o(orientation_w.z);
  214: 
  215: 			PlanetAppearance * const planetAppearance = dynamic_cast<PlanetAppearance 
*>(object->getAppearance());
  216: 			if (planetAppearance)
  217: 			{
  218: 				float const haloRoll = spaceTerrainAppearanceTemplate->getPlanetHaloRoll(i);
  219: 				if (haloRoll > 0.f)
  220: 					planetAppearance->setHaloRoll(haloRoll);
  221: 
  222: 				//-- halo scaling is now handled automagically by the code at runtime
  223: 
  224: 				float const planetFaceDistance = direction_w.magnitude() - 
object->getAppearanceSphereRadius();
  225: 				if (planetFaceDistance < s_cameraMovementPlanetRange * 0.5f)
  226: 				{
  227: 					WARNING(true, ("SpaceEnvironment planet [%s] is too close [%f] to camera.", 
appearanceTemplateName.getString(), planetFaceDistance));
  228: 				}
  229: 
  230: 			}
  231: 
  232: 			Object * const parent = new Object;
  233: 			parent->addChildObject_p(object);
  234: 
  235: 			if (isInfiniteDistance)
  236: 			{
  237: 				RenderWorld::addMoveWithCameraWorldEnvironmentObject(parent);
  238: 			}
  239: 			else
  240: 			{
  241: 				RenderWorld::addWorldEnvironmentObject(parent);
  242: 				m_objectsFollowCameraVector->push_back(parent);
  243: 			}
  244: 
  245: 			m_objectVector->push_back(parent);
  246: 			m_objectsToDisableForHyperspace->push_back(parent);
  247: 		}
  248: 	}
  249: }
  250: 
  251: // ----------------------------------------------------------------------
  252: 
  253: SpaceEnvironment::~SpaceEnvironment()
  254: {
  255: 	FATAL(!ms_spaceEnvironment, ("No SpaceEnvironment"));
  256: 	ms_spaceEnvironment = NULL;
  257: 
  258: 	RenderWorld::setClearDepthAndStencilBufferAfterRenderingEnvironment(false);
  259: 
  260: 	{
  261: 		for (size_t i = 0; i < m_lightVector->size(); ++i)
  262: 		{
  263: 			Light * const light = (*m_lightVector)[i];
  264: 
  265: 			RenderWorld::removeWorldEnvironmentLight(light);
  266: 
  267: 			if (light->isInWorld())
  268: 				light->removeFromWorld();
  269: 
  270: 			delete light;
  271: 		}
  272: 
  273: 		delete m_lightVector;
  274: 	}
  275: 	
  276: 	delete m_parallelLightVector;
  277: 	m_parallelLightVector = NULL;
  278: 
  279: 	{
  280: 		for (size_t i = 0; i < m_objectVector->size(); ++i)
  281: 		{
  282: 			Object * const object = (*m_objectVector)[i];
  283: 
  284: 			RenderWorld::removeWorldEnvironmentObject(object);
  285: 
  286: 			if (object->isInWorld())
  287: 				object->removeFromWorld();
  288: 
  289: 			delete object;
  290: 		}
  291: 
  292: 		delete m_objectVector;
  293: 	}
  294: 
  295: 	delete m_objectsToDisableForHyperspace;
  296: 	delete m_objectsFollowCameraVector;
  297: }
  298: 
  299: // ----------------------------------------------------------------------
  300: 
  301: void SpaceEnvironment::alterInternal(float const elapsedTime)
  302: {
  303: 	if (s_camera.getPointer() != NULL)
  304: 	{
  305: 		float const zoneSize = TerrainObject::getConstInstance()->getMapWidthInMeters();
  306: 		float const cameraMovementPlanetFactor = -(s_cameraMovementPlanetRange / zoneSize);
  307: 		
  308: 		Vector const & cameraPos_w = s_camera->getPosition_w();
  309: 		
  310: 		{
  311: 			for (size_t i = 0; i < m_objectsFollowCameraVector->size(); ++i)
  312: 			{
  313: 				Object * const object = (*m_objectsFollowCameraVector)[i];				
  314: 				Vector const & cameraPosRatio = (cameraPos_w * cameraMovementPlanetFactor);
  315: 				Vector const & pos = cameraPos_w + cameraPosRatio;
  316: 				object->setPosition_p(pos);
  317: 			}
  318: 		}
  319: 	}
  320: 	
  321: 	//---
  322: 
  323: 	for (size_t i = 0; i < m_objectVector->size(); ++i)
  324: 	{
  325: 		Object * const object = (*m_objectVector)[i];
  326: 		object->alter(elapsedTime);			
  327: 	}
  328: 	
  329: 	ms_lastAlterTime = elapsedTime;
  330: }
  331: 
  332: // ----------------------------------------------------------------------
  333: 
  334: void SpaceEnvironment::render() const
  335: {
  336: 	for (size_t i = 0; i < m_objectVector->size(); ++i)
  337: 	{
  338: 		Object * const object = (*m_objectVector)[i];
  339: 
  340: 		CelestialObject * const celestialObject = dynamic_cast<CelestialObject *>(object);
  341: 		if (celestialObject)
  342: 			celestialObject->update(ms_lastAlterTime, ShaderPrimitiveSorter::getCurrentCamera());
  343: 	}
  344: }
