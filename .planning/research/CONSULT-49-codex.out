  509: void GameNetwork::update(void)
  510: {
  511: 	if (!s_instance)
  512: 		return;
  513: 
  514: 	NetworkHandler::update();
  515: 	NetworkHandler::dispatch();
  620: 	memcpy(m_loginToken, t.getToken(), m_loginTokenLength);
  621: 	m_stationId        = static_cast<StationId>(t.getStationId());
  622: 	setUserName         (t.getUsername ());
  623: 
  624: 	snprintf(ms_userName, sizeof(ms_userName), "User: %d %s\n", static_cast<int>(m_stationId), 
t.getUsername().c_str());
  625: 	ms_userName[sizeof(ms_userName)-1] = '\0';
  626: }
