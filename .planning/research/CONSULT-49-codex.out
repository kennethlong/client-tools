 1288: void GroundScene::reloadTerrain ()
 1289: {
 1290: 	TerrainObject* const terrain = TerrainObject::getInstance ();
 1291: 	if (terrain)
 1292: 	{
 1293: 		if (terrain->isInWorld ())
 1294: 			terrain->removeFromWorld ();
 1295: 
 1296: 		NOT_NULL (terrain->getAppearance ());
 1297: 		NOT_NULL (terrain->getAppearance ()->getAppearanceTemplate ());
 1298: 		NOT_NULL (terrain->getAppearance ()->getAppearanceTemplate ()->getName ());
 1299: 
 1300: 		char* const terrainFileName = DuplicateString (terrain->getAppearance 
()->getAppearanceTemplate ()->getName ());
 1301: 		DEBUG_REPORT_LOG(true, ("reloading %s", terrainFileName));
 1302: 
 1303: 		delete TerrainObject::getInstance ();
 1304: 		AppearanceTemplateList::garbageCollect();
 1305: 		load (terrainFileName, ConfigClientTerrain::getEnvironmentStartTime ());
 1306: 
 1307: 		delete [] terrainFileName;
 1308: 	}
 1309: }
