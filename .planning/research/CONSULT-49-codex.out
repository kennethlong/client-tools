 1045: 						if (stage != 0)
 1046: 						{
 1047: 							stage->begin();
 1048: 						}
 1049: 					}
 1050: 				}
 1051: 
 1052: 				m_currentStageToRender = stage;
 1053: 
 1054: 				if (stage != 0)
 1055: 				{
 1056: 					stage->alter(event->arg3);
 1057: 					return IOR_Pass;
 1058: 				}
 1059: 
 1060: 				return IOR_BlockKillMe;
 1061: 			}
 1062: 		case IOET_Character:
 1063: 		case IOET_KeyDown:
 1064: 		case IOET_KeyUp:
 1065: 		case IOET_JoystickMove:
 1066: 		case IOET_JoystickButtonDown:
 1067: 		case IOET_JoystickButtonUp:
 1068: 		case IOET_JoystickPovHat:
 1069: 		case IOET_JoystickSlider:
 1070: 		case IOET_MouseMove:
 1071: 		case IOET_MouseButtonDown:
 1072: 		case IOET_MouseButtonUp:
 1073: 			return IOR_Block;
 1074: 		case IOET_WindowOpen:
 1075: 		case IOET_InputReset:
 1076: 		case IOET_SetSystemMouseCursorPosition:
 1077: 		case IOET_Count:
 1078: 		case IOET_Prepare:
 1079: 		default:
 1080: 			break;
 1081: 	}
 1082: 
 1083: 	return IOR_Pass;
 1084: }
