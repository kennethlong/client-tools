  244: HyperspaceIoWin::Stage * HyperspaceIoWinNamespace::getCurrentStage(StageQueue const & 
m_stages)
  245: {
  246: 	if (!m_stages.empty())
  247: 	{
  248: 		return m_stages.front();
  249: 	}
  250: 	return 0;
  251: }
  252: 
  253: //-------------------------------------------------------------------
  254: 
  255: CellProperty * const HyperspaceIoWinNamespace::findShipCameraCell(ShipObject * const 
shipObject)
  256: {
  257: 	NOT_NULL(shipObject);
  258: 
  259: 	PortalProperty * const portalProperty = shipObject->getPortalProperty();
  260: 	if (portalProperty != 0)
  261: 	{
  262: 		for (int i = 0; cs_cockpitCellNames[i] != 0; ++i)
  263: 		{
  264: 			CellProperty * const cellProperty = portalProperty->getCell(cs_cockpitCellNames[i]);
  265: 			if (cellProperty != 0)
  266: 			{
  267: 				return cellProperty;
  268: 			}
  269: 		}
  270: 	}
  271: 
  272: 	return shipObject->getParentCell();
  273: }
  274: 
  275: //-------------------------------------------------------------------
  276: 
  277: Object * HyperspaceIoWinNamespace::findTopMostRootObject(Object * const object)
  278: {
  279: 	if (object != 0)
  280: 	{
  281: 		Object * topObject = object;
  282: 
  283: 		do
  284: 		{
  285: 			{
  286: 				Object * parentObject = topObject->getParent();
  287: 
  288: 				for (; parentObject != 0; parentObject = topObject->getParent())
  289: 				{
  290: 					topObject = parentObject;
  291: 				}
  292: 			}
  293: 
  294: 			ContainedByProperty * containedByProperty = topObject->getContainedByProperty();
  295: 			while (containedByProperty != 0)
  296: 			{
  297: 				Object * const containerObject = containedByProperty->getContainedBy();
  298: 
  299: 				if (containerObject != 0)
  300: 				{
  301: 					topObject = containerObject;
  302: 
  303: 					containedByProperty = topObject->getContainedByProperty();
  304: 				}
  305: 				else
  306: 				{
  307: 					containedByProperty = 0;
  308: 				}
  309: 			}
  310: 		} while (topObject->getParent() != 0);
  311: 
  312: 		return topObject;
  313: 	}
  314: 
  315: 	return 0;
  316: }
  317: 
  318: //-------------------------------------------------------------------
  319: 
  320: void HyperspaceIoWinNamespace::deactivateSpaceEnvironmentObjects()
  321: {
  322: 	// don't render the distance objects
  323: 	TerrainObject * const terrainObject = TerrainObject::getInstance();
  324: 	Appearance * const appearance = (terrainObject != 0) ? terrainObject->getAppearance() : 0;
  325: 	ClientSpaceTerrainAppearance * const clientSpaceTerrainAppearance = 
dynamic_cast<ClientSpaceTerrainAppearance *>(appearance);
  326: 	if (clientSpaceTerrainAppearance != 0)
  327: 	{
  328: 		SpaceEnvironment & spaceEnvironment = clientSpaceTerrainAppearance->getSpaceEnvironment();
  329: 		spaceEnvironment.disableEnvironmentForHyperspace();
  330: 	}
  331: }
  332: 
  333: //-------------------------------------------------------------------
  334: 
  335: void HyperspaceIoWinNamespace::disableOtherObjectsThisFrame(ShipObject * const playerShip, 
GameCamera const * const currentCamera)
  336: {
  337: 	CellProperty * const targetCellProperty_p = (playerShip != 0) ? 
findShipCameraCell(playerShip) : 0;
  338: 
  339: 	int begin = static_cast<int>(WOL_Tangible);
  340: 	int end = static_cast<int>(WOL_TangibleNotTargetable) + 1;
  341: 	// don't render other obects in the world
  342: 	for (int i = begin; i < end; ++i)
  343: 	{
  344: 		int const numberOf = World::getNumberOfObjects(i);
  345: 
  346: 		for (int j = 0; j < numberOf; ++j)
  347: 		{
  348: 			Object const * const object = findTopMostRootObject(World::getObject(i, j));
  349: 
  350: 			if (object == playerShip)
  351: 			{
  352: 				continue;
  353: 			}
  354: 
  355: 			if (object == currentCamera)
  356: 			{
  357: 				continue;
  358: 			}
  359: 
  360: 			if ((object != 0) && (object->getParentCell() == targetCellProperty_p))
  361: 			{
  362: 				continue;			
  363: 			}
  364: 
  365: 			RenderWorld::recursivelyDisableDpvsObjectsForThisRender(object);
  366: 		}
  367: 	}
  368: }
  369: 
  370: //-------------------------------------------------------------------
  371: 
  372: void HyperspaceIoWinNamespace::letterBoxCamera(GameCamera * const camera)
  373: {
  374: 	// currently not used and sits at the bottom
  375: 	int minimumX = 0, minimumY = 0;
  376: 	int maximumX = 0, maximumY = 0;
  377: 
  378: 	camera->getViewport(minimumX, minimumY, maximumX, maximumY);
  379: 
  380: 	int const originalWidth = maximumY - minimumX;
  381: 	int const originalHeight = maximumY - minimumX;
  382: 
  383: 	int const newHeight = static_cast<int>(static_cast<float>(originalWidth) / 2.35f);
  384: 
  385: 	int const heightDifferenceHalf = ((originalHeight - newHeight) / 2);
  386: 
  387: 	camera->setViewport(minimumX, minimumY + heightDifferenceHalf, maximumX, maximumY - 
heightDifferenceHalf);	
  388: }
