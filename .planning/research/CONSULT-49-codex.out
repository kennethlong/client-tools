  876: /** This constructor is called for single player mode
  877: *
  878: */
  879: GroundScene::GroundScene(
  880: 	const char *const     terrainFilename, 
  881: 	const char *const     playerFilename,
  882: 	CreatureObject *const customizedPlayer
  883: 	)
  884: :	NetworkScene("GroundScene"),
  885: 	m_inputMap (0),
  886: 	m_debugPortalCameraInputMap (0),
  887: 	m_structurePlacementCameraInputMap (0),
  888: 	m_freeCameraInputMap (0),
  889: 	m_mouseCursor (new MouseCursor (0, MouseCursor::S_relative)),
  890: 	m_lastYawPitchMod (new Vector2d),
  891: 	m_cockpitCamera(0),
  892: 	m_shipTurretCamera(0),
  893: 	m_freeChaseCamera (0),
  894: 	m_freeCamera (0),
  895: 	m_debugPortalCamera (0),
  896: 	m_structurePlacementCamera (0),
  897: 	m_flyByCamera(NULL),
  898: 	m_currentView (-1),
  899: 	m_disableWorldSnapshot(ConfigClientGame::getDisableWorldSnapshot()),
  900: 	m_usingGodClientCamera(false),
  901: 	m_usingGodClientInteriorCamera(false),
  902: 	m_loading (true),
  903: 	m_sentSceneChannel(false),
  904: 	m_receivedSceneReady(true), // in single player the server doesn't need to be ready
  905: 	m_noDraw(false),
  906: 	m_currentLoadCount (0),
  907: 	m_debugKeyContext (0),
  908: 	m_debugKeySubContext (),
  909: 	m_debugKeyContextWeaponObjectTemplate (0),
  910: 	m_serverTimeOffset (0),
  911: 	m_overheadMap (new OverheadMap),
  912: 	m_modeCallback (0),
  913: 	m_context (0),
  914: 	m_currentMode (false),
  915: 	m_spaceTargetBracketOverlay(new SpaceTargetBracketOverlay),
  916: 	m_clientPathObject (0),
  917: 	m_debugPointList (new PointList),
  918: 	m_debugLineList (new LineList),
  919: 	m_isTutorial (false),
  920: 	m_destroyObjectSet(new DestroyObjectSet),
  921: 	m_destroyObjectTimer(Random::randomReal(0.5f, 1.f))
  922: {
  923: 	Audio::setLargePreMixBuffer();
  924: 	Audio::silenceAllNonBackgroundMusic();
  925: 
  926: 	ms_loadingScreenRender = true;
  927: 	ms_loadingScreenRenderYaw = 0.0f;
  928: 
  929: 	//-- create the player
  930: 	CreatureObject * player = customizedPlayer;
  931: 
  932: 	if (!player)
  933: 	{
  934: 		// must not have gone through customization screen or customization screen couldn't create 
a valid object.
  935: 		// Note: no customization parameters are present this way.
  936: 
  937: 		// Force player to load synchronously so we have valid mesh generators for the player.
  938: 		bool const wasEnabled = AsynchronousLoader::isEnabled();
  939: 		AsynchronousLoader::disable();
  940: 
  941: 		player = dynamic_cast<CreatureObject*>(ObjectTemplate::createObject(playerFilename));
  942: 		FATAL (!player, ("cannot load template %s\n",playerFilename));
  943: 
  944: 		if (wasEnabled)
  945: 			AsynchronousLoader::enable();
  946: 	}
  947: 
  948: 	player->setPosition_p(ConfigClientGame::getSinglePlayerStartLocation());
  949: 
  950: 	//-- make sure player gets drawn.
  951: 	NOT_NULL(player);
  952: 	RenderWorld::addObjectNotifications(*player);
  953: 	CellProperty::addPortalCrossingNotification(*player);
  954: 
  955: 	player->setObjectName (Unicode::narrowToWide (ConfigClientGame::getPlayerName ()));
  956: 	player->setDebugName  (ConfigClientGame::getPlayerName ());
  957: 
  958: 	//-- make sure the player's animation state reflects items the game may start the player 
with.
  959: 	//   Normally this is handled via the container interface, but in this case the container 
system
  960: 	//   is bypassed.
  961: 	player->setAppearanceHeldItemState ();
  962: 
  963: 	init (terrainFilename, player, ConfigClientTerrain::getEnvironmentStartTime ());
  964: 
  965: 	player->endBaselines ();
  966: 
  967: 	if (!player->isInWorld ())
  968: 		player->addToWorld ();
  969: 
  970: 	CollisionProperty * collision = player->getCollisionProperty();
  971: 	if(collision)
  972: 		collision->setPlayer(true);
  973: 
  974: 	Controller *const controller = player->getController ();
  975: 	NOT_NULL (controller);
  976: 	safe_cast<PlayerCreatureController *>(controller)->setAuthoritative (true);
  977: }
