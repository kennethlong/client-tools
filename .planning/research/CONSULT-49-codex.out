  368: 
  369: void SpaceEnvironment::addEnvironmentObject(Object & obj)
  370: {
  371: 	RenderWorld::addWorldEnvironmentObject(&obj);
  372: 	m_objectVector->push_back(&obj);
  373: }
  374: 
  375: //----------------------------------------------------------------------
  376: 
  377: void SpaceEnvironment::disableEnvironmentForHyperspace()
  378: {
  379: 	NON_NULL(m_objectsToDisableForHyperspace);
  380: 
  381: 	SpaceEnvironment::ObjectVector::const_iterator ii = m_objectsToDisableForHyperspace->begin();
  382: 	SpaceEnvironment::ObjectVector::const_iterator iiEnd = 
m_objectsToDisableForHyperspace->end();
  383: 
  384: 	for (; ii != iiEnd; ++ii)
  385: 	{
  386: 		Object * const object = *ii;
  387: 		if (object != 0)
  388: 		{
  389: 			object->setActive(false);
  390: 		}
  391: 	}
  392: }
  393: 
  394: //----------------------------------------------------------------------
  395: 
  396: void SpaceEnvironment::setCamera(Camera * camera)
  397: {
  398: 	s_camera = camera;
  399: }
  400: 
  401: //----------------------------------------------------------------------
  402: 
  403: void SpaceEnvironment::alter(float elapsedTime)
  404: {
  405: 	if (ms_spaceEnvironment)
  406: 	{
  407: 		ms_spaceEnvironment->alterInternal(elapsedTime);
  408: 	}
  409: }
