  480: void GameNetwork::startScene(const std::string & sceneName, const NetworkId & objectId, const 
std::string & templateName, const Vector & startPosition, const float startYaw, const float 
timeInSeconds, bool disableSnapshot)
  481: {
  482: 	DEBUG_FATAL(s_instance == 0, ("GameNetwork not installed"));
  483: 	//First destroy the old scene if need be.
  484: 	{
