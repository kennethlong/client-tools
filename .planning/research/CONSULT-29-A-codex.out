=== PSRC SOURCE FOR 'pixel_program/a_lava_alpha_ps14.psh' (sourceLen=843) ===
//hlsl ps_1_4

#include "pixel_program/include/pixel_shader_constants.inc"
#include "pixel_program/include/functions.inc"

sampler diffuseMap 	: register(s0);
sampler noiseMap 	: register(s1);
sampler colorRamp 	: register(s2);

#define time userConstants[0].r
#define colorScale materialSpecularColor.r
#define colorBias materialSpecularColor.g

float4 main
(
	in float2 tcs_MAIN   	: TEXCOORD0,
	in float3 noiseTc   	: TEXCOORD1
)
: COLOR 
{
   	float4 result;

	//Sample alpha map
	float alphaMask = tex2D(diffuseMap, tcs_MAIN).a;

  	// Sample the base noise
   	float index = tex3D(noiseMap, noiseTc);
   	index = (index * colorScale) + colorBias;

	//Sample color ramp
   	float4 lava = tex1D(colorRamp, index);
  
   	result.rgb = lava.rgb;
	result.a = alphaMask * alphaFadeOpacity;

return result;
}
=== END ===

=== PSRC SOURCE FOR 'pixel_program/a_bloom_mask_pass_ps20.psh' (sourceLen=645) ===
//hlsl ps_2_0

#include "pixel_program/include/pixel_shader_constants.inc"
#include "pixel_program/include/functions.inc"

sampler diffuseMap : register(s0);

float4 main
(
	in float2 tcs_MAIN	: TEXCOORD0
)
: COLOR
{
	float4 result;
		

	//Sample texture with UV
	float bloomMask = tex2D(diffuseMap, tcs_MAIN).a;

	float bloomStrength = textureFactor.rgb;
	
	result.rgb = 0.0f;
	float totalBloomValue = bloomMask * bloomStrength;

	if (alphaFadeOpacityEnabled > 0.0f)
		result = saturate(alphaFadeOpacity + (1.0f - alphaFadeOpacityEnabled)) * totalBloomValue;
	else
		result = totalBloomValue;	

	return result;
}

=== END ===

