// d3dcompiler_47.dll export (dumpbin /exports): ordinal 1, undecorated name "D3DAssemble".
// d3dcompiler.lib symbol: C++-MANGLED (?D3DAssemble@@YAJ...), so an `extern "C"` decl will NOT
// match the .lib import. RESEARCH recommendation: prefer (b) GetProcAddress on the undecorated
// DLL export â€” it sidesteps the mangling mismatch entirely. Validate this path FIRST.

typedef HRESULT (WINAPI *PFN_D3DAssemble)(
    LPCVOID                  pSrcData,
    SIZE_T                   SrcDataSize,
    LPCSTR                   pSourceName,
    const D3D_SHADER_MACRO  *pDefines,
    ID3DInclude             *pInclude,
    UINT                     Flags,
    ID3DBlob               **ppCode,
    ID3DBlob               **ppErrorMsgs);
