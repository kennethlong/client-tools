1736-// ============================================================================
1737-#if TRY_FOR_SSE
1738-// ============================================================================
1739-//
1740-// Phase 31 (BITS-01, B-GAP-1): the SSE skinning hot path was two __declspec
1741-// inline-__asm blocks (illegal on x64, C4235). They are PEERS of the SseMath /
1742-// Transform _mm_* work in plan 31-02 and are ported here to _mm_* intrinsics.
1743-//
1744-// LAYOUT (resolved via CONSULT-44, codex+cursor concur): `transformArray` is a
1745-// `PoseModelTransform` array, NOT a `Transform` array. PoseModelTransform is a
1746-// SEPARATE __declspec(align(16)) class with `float matrix[4][4]` => 64 bytes
1747-// (matching the asm's `transformIndex << 6` = x64 stride) stored COLUMN-MAJOR
1748-// (the converting ctor transposes the row-major Transform). So `matrix[c]`
1749-// (floats c*4..c*4+3) is column c, and:
1750-//     rotateTranslate_l2p(v).lane = col0*v.x + col1*v.y + col2*v.z + col3
1751-//     rotate_l2p(v).lane          = col0*v.x + col1*v.y + col2*v.z   (no col3)
1752-// which is EXACTLY what the asm computed (its "column N" loads + broadcast +
1753:// mul/add). The scalar peers fill_vb_work::fillVertexBufferHard()/
1754:// fillDot3VertexBufferHard() call PoseModelTransform::rotate{Translate}_l2p on
1755-// the same array -- that is the ground-truth reference the _DEBUG oracle uses.
1756-//
1757-// ALIGNMENT (A1-SSE-ALIGN / D-05): the transform columns are loaded with
1758-// _mm_loadu_ps (UNALIGNED) -- never movaps an arbitrary pointer on x64. The
1759-// PaddedVector min/max/position accumulators ARE __declspec(align(16)) so their
1760-// loads/stores can be aligned. No #ifdef _M_X64 fork (intrinsics compile both
1761-// bitnesses).
1762-//
1763-// ----------------------------------------------------------------------------
1764-
1765-namespace
1766-{
1767-	// Skin one source 3-vector against a 64-byte column-major PoseModelTransform
1768-	// at byte offset (transformIndex<<6) within transformArray. translate==true
1769-	// adds column 3 (rotateTranslate_l2p); translate==false omits it (rotate_l2p).
1770-	// Returns {x,y,z,?} in lanes 0..2; lane 3 is don't-care. Faithful to the asm:
1771-	//   result = col0*x + col1*y + col2*z [+ col3]
1772-	inline __m128 sse_skin_l2p(const float *const transformColumns, const Vector &v, const bool 
translate)
1773-	{
1774-		const __m128 col0 = _mm_loadu_ps(transformColumns +  0);   // column 0
1775-		const __m128 col1 = _mm_loadu_ps(transformColumns +  4);   // column 1
1776-		const __m128 col2 = _mm_loadu_ps(transformColumns +  8);   // column 2
1777-
1778-		const __m128 bx = _mm_set1_ps(v.x);
1779-		const __m128 by = _mm_set1_ps(v.y);
1780-		const __m128 bz = _mm_set1_ps(v.z);
1781-
1782-		__m128 acc = _mm_mul_ps(col0, bx);
1783-		acc = _mm_add_ps(acc, _mm_mul_ps(col1, by));
1784-		if (translate)
1785-		{
1786-			// col2*z + col3, then + (col0*x + col1*y) -- same add order as the asm.
1787-			const __m128 col3 = _mm_loadu_ps(transformColumns + 12);   // column 3 (translate)
1788-			acc = _mm_add_ps(acc, _mm_add_ps(_mm_mul_ps(col2, bz), col3));
1789-		}
1790-		else
1791-		{
1792-			acc = _mm_add_ps(acc, _mm_mul_ps(col2, bz));
1793-		}
1794-		return acc;
1795-	}
1796-
1797-#ifdef _DEBUG
1798-	// Numeric-equivalence oracle (D-05 / review #2): the intrinsic skin result vs
1799-	// the scalar PoseModelTransform reference. A transposed lane or dropped
1800-	// translate is caught at first-skin rather than as silent visual corruption.
1801-	inline void sse_skin_oracle(const PoseModelTransform &xf, const Vector &src, const __m128 
sseResult, const bool translate, const char *const what)
1802-	{
1803-		float lanes[4];
1804-		_mm_storeu_ps(lanes, sseResult);
1805-		const Vector ref = translate ? xf.rotateTranslate_l2p(src) : xf.rotate_l2p(src);
1806-		const float tol = 1e-3f;
1807-		DEBUG_FATAL(
1808-			fabsf(lanes[0] - ref.x) > tol || fabsf(lanes[1] - ref.y) > tol || fabsf(lanes[2] - ref.z) > 
tol,
1809-			("SSE skinning oracle: %s mismatch (sse %g,%g,%g ref %g,%g,%g)", what, lanes[0], lanes[1], 
lanes[2], ref.x, ref.y, ref.z));
1810-	}
1811-#endif
1812-}
1813-
