+			   -0.48f,  0.64f, 0.60f,  0.75f };
+			const float R[12] = {
+				0.60f,  0.00f, -0.80f, 3.10f,
+				0.00f,  1.00f,  0.00f, -1.20f,
+				0.80f,  0.00f,  0.60f, 0.40f };
+
+			float sseOut[12];
+			float refOut[12];
+			sse_xf_matrix_3x4(sseOut, L, R);
+			xf_matrix_3x4(refOut, L, R);
+
+			for (int i = 0; i < 12; ++i)
+			{
+				DEBUG_FATAL(fabsf(sseOut[i] - refOut[i]) >= 1e-4f,
+					("Transform sse_xf_matrix_3x4 oracle: element %d mismatch (sse=%g ref=%g)",
+						i, sseOut[i], refOut[i]));
+			}
+		}
+	};
+
+	SseMatrixSelfTest s_sseMatrixSelfTest;
+}
+#endif
 #endif
 ////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////
 

commit 673efdd2834852028dab995d7e866792d0696fa5
Author: Kenny Long <kenny.alan.long@gmail.com>
Date:   Mon Jun 15 18:44:08 2026 -0500

    feat(31-02): port SseMath CPUID + 4 transform routines + prefetch to _mm_* intrinsics
    
    - canDoSseMath: __asm cpuid -> __cpuid leaf 1, EDX bit25 SSE / bit24 FXSR (live; not deleted)
    - 4 *_l2p routines rewritten register-faithfully with verified per-routine lane semantics: 
rotateTranslateScale w=1/4-lane, rotateScale w=0/3-lane, skin position-4-lane vs normal-3-lane 
asymmetry, Add variant accumulates
    - _mm_loadu_ps for all matrix/vector loads (review #2: movaps on unaligned Transform faults at 
runtime on x64); global sseVariable staging array retired for stack locals (reentrant)
    - SseMath.h prefetch __asm prefetchnta -> _mm_prefetch(_MM_HINT_NTA); include <xmmintrin.h> in 
header
    - _DEBUG numeric-equivalence oracle vs scalar rotate_l2p/rotateTranslate_l2p (1e-4f) exercising 
the 3-lane/4-lane + position/normal asymmetries
    - no #ifdef _M_X64 fork (D-05); 0 C4235; scratch x64 cl /c clean
---
 .../library/sharedMath/src/win32/SseMath.cpp       | 569 ++++++++-------------
 .../shared/library/sharedMath/src/win32/SseMath.h  |  21 +-
 2 files changed, 225 insertions(+), 365 deletions(-)

diff --git a/src/engine/shared/library/sharedMath/src/win32/SseMath.cpp 
b/src/engine/shared/library/sharedMath/src/win32/SseMath.cpp
index 11624aabe..0d676577a 100644
--- a/src/engine/shared/library/sharedMath/src/win32/SseMath.cpp
+++ b/src/engine/shared/library/sharedMath/src/win32/SseMath.cpp
@@ -12,16 +12,66 @@
 #include "sharedMath/Transform.h"
 #include "sharedMath/Vector.h"
 
-// ======================================================================
+#include <intrin.h>     // __cpuid
+#include <xmmintrin.h>  // _mm_* SSE intrinsics
 
-#define SSE_ALIGN  __declspec(align(16))
-#define SSE_VARIABLE_COUNT 5
+#ifdef _DEBUG
+#include <cmath>        // fabsf for the numeric-equivalence oracle
+#endif
 
+// ======================================================================
+//
+// BITS-01 / D-05: this module was 13 inline-asm SSE blocks across 5 functions
+// (a CPUID feature check + 4 matrix-transform routines). x64 forbids inline
+// asm (always error C4235), so it is rewritten as register-faithful _mm_*
+// intrinsics. Intrinsics compile on BOTH x86 and x64 -- there is NO #ifdef
+// fork (D-05); the committed 32-bit build inherits the same code.
+//
+// ALIGNMENT (review #2): the `Transform` argument is an embedded plain member
+// with no alignas(16); a movaps / _mm_load_ps on it would FAULT at runtime on
+// x64 (a fault the compile-only harness is structurally blind to). All loads
+// from the matrix/vector pointer arguments therefore use _mm_loadu_ps
+// (UNALIGNED). The old global non-reentrant staging array (sse-scratch[5][4])
+// is RETIRED in favor of stack locals (review #2).
+//
+// USAGE-AUDIT (D-05 / Pitfall 4): all of these are LIVE -- canDoSseMath drives
+// Transform::install's selector (Transform.cpp:76-78) and s_useSSE in the
+// skinning hot path (SoftwareBlendSkeletalShaderPrimitive.cpp:365/1569/1592).
+// Nothing is dead; nothing is deleted.
+//
 // ======================================================================
 
 namespace
 {
-	SSE_ALIGN float sseVariable[SSE_VARIABLE_COUNT][4];
+	// Horizontal sum of all 4 lanes of a __m128 (lane0+lane1+lane2+lane3).
+	inline float hsum4(__m128 v)
+	{
+		// {x,y,z,w} + {y,x,w,z} = {x+y, y+x, z+w, w+z}
+		__m128 shuf = _mm_shuffle_ps(v, v, _MM_SHUFFLE(2, 3, 0, 1));
+		__m128 sums = _mm_add_ps(v, shuf);
+		// + {z+w, ., ., x+y} -> lane0 = x+y+z+w
+		shuf = _mm_movehl_ps(shuf, sums);
+		sums = _mm_add_ss(sums, shuf);
+		return _mm_cvtss_f32(sums);
+	}
+
+	// Horizontal sum of only the low 3 lanes (lane0+lane1+lane2); lane3 ignored.
+	inline float hsum3(__m128 v)
+	{
+		float tmp[4];
+		_mm_storeu_ps(tmp, v);
+		return tmp[0] + tmp[1] + tmp[2];
+	}
+
+	// Load the 3 rows of a 3x4 row-major Transform from an UNALIGNED pointer
+	// (review #2 -- never movaps an embedded Transform).
+	inline void loadMatrixRows(const Transform &transform, __m128 &row0, __m128 &row1, __m128 &row2)
+	{
+		const float *m = reinterpret_cast<const float *>(&transform);
+		row0 = _mm_loadu_ps(m + 0);   // a1 a2 a3 a4
+		row1 = _mm_loadu_ps(m + 4);   // b1 b2 b3 b4
+		row2 = _mm_loadu_ps(m + 8);   // c1 c2 c3 c4
+	}
 }
 
