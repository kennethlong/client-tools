688-/**
689- * Calculate the bounding box coordinates for this blended mesh.
690- *
691- * Since this instance represents a mesh that is modified by transforms,
692- * the bounding box will necessarily change when the transforms change.
693- * Therefore, it makes no sense for this instance to try to cache this
694- * data internally.  Users of this class that want a cheap bounding box
695- * calculation will need to be smart about (1) how accurate the bounding
696- * box must be and (2) how often they need to run over this data to
697- * caculate it.
698- *
699- * Performance side-effects: this function will force the skeleton to evaluate 
700- * its transforms if that event hasn't already happened.
701- *
702: * @param minVector  the minimum x, y and z value for the bounding box
703- *                   are returned in this vector.
704: * @param maxVector  the maximum x, y and z value for the bounding box
705- *                   are returned in this vector.
706- */
707-
708:void SoftwareBlendSkeletalShaderPrimitive::calculateBoundingBox(Vector &minVector, Vector 
&maxVector) const
709-{
710-	//-- initialize min and max value
711:	minVector.set(std::numeric_limits<float>::max(), std::numeric_limits<float>::max(), 
std::numeric_limits<float>::max());
712:	maxVector.set(-std::numeric_limits<float>::max(), -std::numeric_limits<float>::max(), 
-std::numeric_limits<float>::max());
713-
714-	//-- get the current transform data from the appearance
715-	const Skeleton &skeleton = m_appearance.getSkeleton(m_lodIndex);
716-
717-#ifdef _DEBUG
718-	const int              transformCount = skeleton.getTransformCount();
719-#endif
720-	const PoseModelTransform *const transformArray = skeleton.getBindPoseModelToRootTransforms();
721-	NOT_NULL(transformArray);
722-
723-	const TransformData *transformData = m_transformData;
724-
725-	//-- calculate transformed xyz, track min and max
726-	for (int vertexIndex = 0; vertexIndex < m_vertexCount; ++vertexIndex)
727-	{
728-		const SourceVertex &sourceVertex = m_sourceVectors[vertexIndex];
729-		const Vector &sourcePosition     = sourceVertex.m_position;
730-
731-		//-- initialize first position with first influencing transform
732-		const TransformData &firstTransformData = sourceVertex.m_firstTransformData;
733-		VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, firstTransformData.m_transformIndex, transformCount);
734-
735-		const PoseModelTransform &firstTransform = transformArray[firstTransformData.m_transformIndex];
736-
737-		Vector blendPosition = firstTransform.rotateTranslate_l2p(sourcePosition) * 
firstTransformData.m_transformWeight;
738-
739-		//-- apply remaining transforms
740-		for (int j=sourceVertex.m_extraTransformDataCount;j>0;j--, transformData++)
741-		{
742-			// get transform data
743-			VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformData->m_transformIndex, transformCount);
744-
745-			// apply it
746-			const PoseModelTransform &transform = transformArray[transformData->m_transformIndex];
747-
748-			blendPosition += transform.rotateTranslate_l2p(sourcePosition) * 
transformData->m_transformWeight;
749-		}
750-
751-		//-- apply blended position to min/max
752:		minVector.set(std::min(minVector.x, blendPosition.x), std::min(minVector.y, blendPosition.y), 
std::min(minVector.z, blendPosition.z));
753:		maxVector.set(std::max(maxVector.x, blendPosition.x), std::max(maxVector.y, blendPosition.y), 
std::max(maxVector.z, blendPosition.z));
754-	}
755-}
