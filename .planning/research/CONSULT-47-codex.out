766:/*
767:* handle enqueued lightning events
768:*/
769:
770:void NebulaManagerClient::handleEnqueuedLightningEvents()
771:{
772:	s_numLightningsSpawnedThisFrame = 0;
773:
774:	PROFILER_AUTO_BLOCK_DEFINE("NebulaManagerClient::handleEnqueuedLightningEvents");
775:
776:	Camera const * const camera = Game::getCamera();
777:	Vector const & cameraPos_w = camera != NULL ? camera->getPosition_w() : Vector::zero;
778:
779:	uint32 const syncStamp = Game::getSinglePlayer () ? static_cast<uint32>(Game::getElapsedTime() 
* 1000.0f) : GameNetwork::getServerSyncStampLong();
780:
781:	for (LightningObjectVector::iterator it = s_lightningObjectVector.begin(); it != 
s_lightningObjectVector.end();)
782:	{
783:		NebulaLightningData const & nebulaLightningData = (*it).first;
784:		ObjectWatcher & objectWatcher = (*it).second;
785:
786:		Nebula const * const nebula = NebulaManager::getNebulaById(nebulaLightningData.nebulaId);
787:		if (nebula == NULL)
788:		{
789:			it = s_lightningObjectVector.erase(it);
790:			continue;
791:		}
792:
793:		std::string const & lightningAppearanceName = nebula->getLightningAppearance();
794:
795:		if (lightningAppearanceName.empty())
796:		{
797:			it = s_lightningObjectVector.erase(it);
798:			continue;
799:		}
800:
801:		//-- lightning occurs now or in the past
802:		if (nebulaLightningData.syncStampStart <= syncStamp)
803:		{
804:			//-- lightning is finished
805:			if (nebulaLightningData.syncStampEnd < syncStamp)
806:			{
807:				Object * const lightning = (*it).second;
808:
809:				if (lightning != NULL)
810:				{
811:					Audio::detachSound(*lightning, 1.0f);
812:					delete lightning;
813:				}
814:
815:				//-- see if the lightning lifetime is expired
816:				//-- we keep lightning data around a bit after it is finished so that
817:				//-- we can respond properly to server notifications concerning this lightning hitting ships
818:
819:				if ((syncStamp - nebulaLightningData.syncStampEnd) > s_lightningLifetime)
820:				{
821:					it = s_lightningObjectVector.erase(it);
822:				}
823:				else
824:					++it;
825:
826:				continue;
827:			}
828:
829:			LightningAppearance * lightningAppearance = NULL;
830:
831:			//-- lightning must be created
832:			if (objectWatcher.getPointer() == NULL)
833:			{
834:				lightningAppearance = 
LightningAppearance::asLightningAppearance(AppearanceTemplateList::createAppearance 
(lightningAppearanceName.c_str()));
835:
836:				if (lightningAppearance == NULL)
837:				{
838:					WARNING(true, ("NebulaManagerClient unable to create lightning appearance [%s]", 
lightningAppearanceName.c_str()));
839:					//-- the lightning appearance could not be created (missing/wrong-type asset); drop this
840:					//-- entry instead of falling through to dereference the still-null objectWatcher below
841:					//-- (NOT_NULL at the deref is a no-op in Release). Mirrors the erase+continue skip used
842:					//-- for the missing-nebula and empty-appearance-name cases above.

