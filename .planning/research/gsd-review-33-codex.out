typedef HRESULT (WINAPI *PFN_D3DAssemble)(
    LPCVOID pSrcData, SIZE_T SrcDataSize, LPCSTR pSourceName,
    const D3D_SHADER_MACRO *pDefines, ID3DInclude *pInclude, UINT Flags,
