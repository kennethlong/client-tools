93:/**
94: * Install the AppearanceTemplateList.
95: */
96:void AppearanceTemplateList::install(bool useTimedTemplates, bool ensureDefaultAppearanceExists)
97:{
98:	DEBUG_FATAL(ms_installed, ("double install"));
99:	ms_installed = true;
100:
101:	DebugFlags::registerFlag(ms_debugReport, "SharedObject/AppearanceTemplateList", "debugReport", 
debugReport);
102:	DebugFlags::registerFlag(ms_debugReportTimedTemplates, "SharedObject/AppearanceTemplateList", 
"reportTimedTemplates", debugReportTimedTemplates);
103:	DebugFlags::registerFlag(ms_debugReportVerbose, "SharedObject/AppearanceTemplateList", 
"debugReportVerbose", debugReportVerbose);
104:	DebugFlags::registerFlag(ms_useTimedTemplates, "SharedObject/AppearanceTemplateList", 
"useTimedTemplates");
105:	DebugFlags::registerFlag(ms_logCreate, "SharedObject/AppearanceTemplateList", "logCreate");
106:	DebugFlags::registerFlag(ms_logFetch, "SharedObject/AppearanceTemplateList", "logFetch");
107:
108:	ms_useTimedTemplates = useTimedTemplates;
109:	ms_keepTime          = ConfigSharedObject::getAppearanceTemplateListKeepTime();
110:	ms_keepEpsilon       = ConfigSharedObject::getAppearanceTemplateListKeepEpsilon();
111:
112:	//-- verify the default appearance exists
113:	if (ensureDefaultAppearanceExists)
114:		FATAL(!TreeFile::exists(getDefaultAppearanceTemplateName()), ("%s could not be found. Are your 
paths set up correctly?", getDefaultAppearanceTemplateName()));
115:
116:	if (TreeFile::isLoggingFiles())
117:		delete TreeFile::open(getDefaultAppearanceTemplateName(), AbstractFile::PriorityData, true);
118:
119:	ExitChain::add(AppearanceTemplateListNamespace::remove, "AppearanceTemplateList::remove", 0, 
false);
120:}
