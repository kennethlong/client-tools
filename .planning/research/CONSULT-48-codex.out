123:/**
124: * Assign a binding between a Tag and a CreateFunction.
125: * 
203:const AppearanceTemplate *AppearanceTemplateList::fetch(const char *const fileName)
204:{
205:	bool found = false;
206:	return fetch(fileName, found);
207:}
208:
209://----------------------------------------------------------------------
210:
211:const AppearanceTemplate *AppearanceTemplateList::fetch(const char *const fileName, bool & found)
212:{
213:	DEBUG_FATAL(!ms_installed, ("not installed"));
214:	NOT_NULL(fileName);
215:
216:	DEBUG_REPORT_LOG(ms_logFetch, ("[fetch] AppearanceTemplateList::fetch: %s\n", fileName));
217:	
218:	found = false;
219:	char const * actualFileName = fileName;
220:	if (!fileName)
221:	{
222:		DEBUG_WARNING(true, ("AppearanceTemplateList::fetch passed NULL fileName, using default"));
223:		actualFileName = getDefaultAppearanceTemplateName();
224:	}
225:	else if (!*fileName)
226:	{
227:		DEBUG_WARNING(true, ("AppearanceTemplateList::fetch passed empty fileName, using default"));
228:		actualFileName = getDefaultAppearanceTemplateName();
229:	}
230:	else if (!TreeFile::exists(fileName))
231:	{
232:		DEBUG_WARNING(true, ("AppearanceTemplateList::fetch could not open '%s', using default", 
fileName));
233:		actualFileName = getDefaultAppearanceTemplateName();
234:	}
235:	else
236:		found = true;
237:
238:	//-- search for the appearance
239:	AppearanceTemplate *const appearanceTemplate = create(actualFileName);
240:
388:Appearance *AppearanceTemplateList::createAppearance(const char *const fileName)
389:{
390:	DEBUG_FATAL(!ms_installed, ("not installed"));
391:
392:#ifdef _DEBUG
393:	DataLint::pushAsset(fileName);
394:#endif
395:
396:	//-- get the appearance template
397:	const AppearanceTemplate *const appearanceTemplate = fetch(fileName);
398:
399:	//-- creating the appearance will increment the reference count
400:	Appearance *const appearance = appearanceTemplate->createAppearance();
401:
402:#ifdef _DEBUG
403:	DataLint::popAsset();
404:#endif // _DEBUG
405:
406:	//-- release the appearance template, since the appearance now holds a ref count for it
407:	release(appearanceTemplate);
408:
409:	return appearance;
410:}
