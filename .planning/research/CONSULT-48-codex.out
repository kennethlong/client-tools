# Generated by CMake from src/cmake/config/client.cfg.in via configure_file(@ONLY).
# DO NOT edit the staged copy in bin/<config>/client.cfg -- re-run cmake to regenerate.
# Source-of-truth template lives in the repo; SWG_INSTALL_DIR is substituted at configure time.
#
# Phase 6 decisions encoded:
#   D-01 single source of truth (this template)
#   D-02 D:/Code/SWGSource Client v3.0 placeholder for machine-specific TRE/TOC paths
#   D-03 LoginServer hardcoded to loopback 127.0.0.1:44453 (swg-main VM)
#   D-04 Full SWGSource TRE/TOC inventory (sku0..sku3 + swgsource overlay + snow disable)
#   D-05 [Station] session key is INTENTIONALLY ABSENT (would activate dead SOE Station SSO)
#   D-06 / CONFIG-03 dead-service disable keys (Bink intro skipped, G15 LCD disabled)
#   D-09 [SharedDebug/InstallTimer] enabled=true (verified key; NOT the boot doc typo)

[SharedFile]
	maxSearchPriority=12
	# TOCTreePath: directory prefix prepended to .tre filenames listed inside .toc files.
	# Must have trailing slash. Quoted to survive ConfigFile space-splitting on paths with spaces.
	TOCTreePath="D:/Code/SWGSource Client v3.0/"
	searchTOC_00_0="D:/Code/SWGSource Client v3.0/sku0_client.toc"
	searchTOC_01_1="D:/Code/SWGSource Client v3.0/sku1_client.toc"
	searchTOC_02_2="D:/Code/SWGSource Client v3.0/sku2_client.toc"
	searchTOC_03_3="D:/Code/SWGSource Client v3.0/sku3_client.toc"
	searchTree_00_7="D:/Code/SWGSource Client v3.0/disable_wayfar_dearic_snow.tre"
	searchTree_00_8="D:/Code/SWGSource Client v3.0/swgsource_3.0.tre"
	# Loose-file override layer shipped WITH the SWGSource client install (priority 9 > TREs 7/8).
	# The install root carries retail-final loose ui/ overrides (ui_root.ui, ui_hud_space.inc with the
	# GU21 enterSpaceButton, ui_options, ground_hud, etc.) + loose appearance/clientdata that the
	# stock client expects on the searchPath. Our cfg had omitted it, so the older pre-GU21 ui copy
	# baked into swgsource_3.0.tre was winning -> space-HUD FATAL on buttonEnterSpace. (CONSULT-47.)
	searchPath_00_9="D:/Code/SWGSource Client v3.0/"
	# Phase 19: loose override dir (priority 10 > TREs 7/8) for reauthored //hlsl
	# shaders (tfcl/tfcsl family) while iterating; repack into a TRE when final.
	searchPath_00_10="D:/Code/swg-client-v2/stage/override"

[Station]
	# CONFIG-01 / D-05: The SOE Station SSO key is INTENTIONALLY OMITTED.
	# Adding it activates LoginConnection's dead SOE Station SSO branch.
	# CONFIG-02: gameFeatures bits = Base + JTL + RotW + ToOW (15 = 0b1111)
	gameFeatures=15
	subscriptionFeatures=1

