254:
255:bool NebulaManager::hasSceneData(std::string const & sceneId)
256:{
257:	NebulasByScene::const_iterator ii = s_nebulasByScene.find(sceneId);
258:
259:	if (ii != s_nebulasByScene.end())
260:	{
261:		NebulaVector const & currentNebulaVector = ii->second;
262:		return !currentNebulaVector.empty();
263:	}
264:
265:	return false;
266:}
