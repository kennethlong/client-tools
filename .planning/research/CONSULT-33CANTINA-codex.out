void SetWarningStrictFatal(bool strict)
{
	ms_strict = strict;
}

// ----------------------------------------------------------------------

bool GetWarningStrictFatal()
{
	return ms_strict;
}

// ----------------------------------------------------------------------

void WarningStrictFatal(const char *format, ...)
{
	va_list va;
	va_start(va, format);

		if (ms_strict)
			InternalFatal(format, va);
		else
			InternalWarning(format, 0, va);

	va_end(va);
}

