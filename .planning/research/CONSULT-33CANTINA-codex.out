SkeletalMeshGenerator::SkeletalMeshGenerator(const SkeletalMeshGeneratorTemplate 
*meshGeneratorTemplate) :
	MeshGenerator(meshGeneratorTemplate),
	m_customizationData(0),
	m_blendValues(0)
{
