1069-bool SoftwareBlendSkeletalShaderPrimitive::collide(const Vector &start_o, const Vector &end_o, CollisionInfo &result) const
1070-{
1071-	bool found = false;
1072-
1073-	result.setPoint(end_o);
1074-
1075-	NOT_NULL(m_shader);
1076-	if (m_shader->getShaderTemplate().isCollidable() && m_boxExtent.intersect(start_o, result.getPoint()))
1077-	{
1078:		if (!m_systemStream)
1079-			return false;
1080-
1081-		//-- Defensive guard against a freed/reused system stream (debug session
1082-		//   c0000005-async-mgn-crash).  Under the D3D11 single-stream branch
1083-		//   (ms_useMultiStreamVertexBuffers == false), an intervening
1084-		//   SkeletalAppearance2::unloadUnusedResources / rebuildMesh on the same
1085-		//   main thread can free this primitive's SystemVertexBuffer between an
1086-		//   alter() pass and this HUD targeting collide().  When that happens the
1087-		//   VertexBufferReadIterator copied from begin() holds garbage backing
1088-		//   pointers and getPosition() dereferences an unmapped address.  The
1089-		//   primitive's own m_vertexCount is fixed at build time and never mutated,
1090-		//   so a live, matching stream must report the same vertex count; a
1091-		//   mismatch means the stream is no longer the one we built.  Bail the
1092-		//   collide cleanly (report no-hit) rather than dereferencing freed memory.
1093:		if (m_systemStream->getNumberOfVertices() != m_vertexCount)
1094-			return false;
1095-
1096-		NOT_NULL(m_indexBuffer);
1097-		m_indexBuffer->lock();
1098-
1099-			const Index *indices       = m_indexBuffer->beginReadOnly();
1100-			const int    numberOfFaces = m_indexBuffer->getNumberOfIndices() / 3;
1101-			const Vector dir           = end_o - start_o;
1102-
1103-			Vector normal;
1104-			Plane  plane;
1105-			Vector intersection;
1106-
1107:			NOT_NULL(m_systemStream);
1108:			VertexBufferReadIterator readIt = m_systemStream->begin();
1109-
1110-			int i;
1111-			for (i = 0; i < numberOfFaces; i++)
1112-			{
1113-				//-- Bound every index against the trusted vertex count so a stale or
