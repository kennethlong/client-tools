942-/**
943- * Calculate the bounding box coordinates for this blended mesh.
944- *
945- * Since this instance represents a mesh that is modified by transforms,
946- * the bounding box will necessarily change when the transforms change.
--
972-	const int              transformCount = skeleton.getTransformCount();
973-#endif
974-	const PoseModelTransform *const transformArray = skeleton.getBindPoseModelToRootTransforms();
975-	NOT_NULL(transformArray);
976-
977-	const TransformData *transformData = m_transformData;
978-
979-	//-- calculate transformed xyz, track min and max
980-	for (int vertexIndex = 0; vertexIndex < m_vertexCount; ++vertexIndex)
981-	{
982-		const SourceVertex &sourceVertex = m_sourceVectors[vertexIndex];
983-		const Vector &sourcePosition     = sourceVertex.m_position;
984-
985-		//-- initialize first position with first influencing transform
986-		const TransformData &firstTransformData = sourceVertex.m_firstTransformData;
987-		VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, firstTransformData.m_transformIndex, transformCount);
988-
989-		const PoseModelTransform &firstTransform = transformArray[firstTransformData.m_transformIndex];
990-
991-		Vector blendPosition = firstTransform.rotateTranslate_l2p(sourcePosition) * firstTransformData.m_transformWeight;
992-
993-		//-- apply remaining transforms
994-		for (int j=sourceVertex.m_extraTransformDataCount;j>0;j--, transformData++)
995-		{
996-			// get transform data
997-			VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformData->m_transformIndex, transformCount);
998-
999-			// apply it
1000-			const PoseModelTransform &transform = transformArray[transformData->m_transformIndex];
1001-
1002-			blendPosition += transform.rotateTranslate_l2p(sourcePosition) * transformData->m_transformWeight;
1003-		}
1004-
1005-		//-- apply blended position to min/max
1006-		minVector.set(std::min(minVector.x, blendPosition.x), std::min(minVector.y, blendPosition.y), std::min(minVector.z, blendPosition.z));
1007-		maxVector.set(std::max(maxVector.x, blendPosition.x), std::max(maxVector.y, blendPosition.y), std::max(maxVector.z, blendPosition.z));
1008-	}
1009-}
