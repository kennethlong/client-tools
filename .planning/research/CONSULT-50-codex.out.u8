363:	// allow gl ms_api to release itself
364:	if (ms_api && ms_api->remove)
365:		ms_api->remove();
366:	ms_api = NULL;
367:
368:	if (ms_dll)
369:	{
370:		// keep the graphics library around when fataling so the call stack is trackable
371:		if (!ExitChain::isFataling())
372:		{
373:			const BOOL result = FreeLibrary(ms_dll);
374:			UNREF(result);
375:			DEBUG_FATAL(!result, ("FreeLibrary failed"));
376:		}
377:		ms_dll = NULL;
378:	}
