342:/**
343: * Remove the Graphics Layer subsystem.
344: *
345: * This routine will be automatically called by the ExitChain and should
346: * not be directly called by the user.
347: *
348: * @see Graphics::install()
349: */
350:
351:void GraphicsNamespace::remove(void)
352:{
353:	// unconstrain the mouse cursor
354:	ms_allowMouseCursorConstrained = false;
355:	ClipCursor(NULL);
356:
357:#if PRODUCTION == 0
358:	Os::setIsGdiVisibleHookFunction(NULL);
359:#endif
360:	Os::setGetOtherAdapterRectsHookFunction(NULL);
361:	Os::setDisplayModeChangedHookFunction(NULL);
