125:
126:	static void _saveSeenCutScenesFile(const char *fileName, const std::set<std::string> &scenes)
127:	{
128:		FILE *file = fopen(fileName, "wb");
129:		if (file)
130:		{
131:			const std::set<std::string>::const_iterator siend=scenes.end();
132:			for (std::set<std::string>::const_iterator si=scenes.begin();si!=siend;++si)
133:			{
134:				fprintf(file, "%s\r\n", si->c_str());
135:			}
136:			fclose(file);
137:			file=0;
138:		}
139:	}
