93:	static void _loadSeenCutScenesFile(std::set<std::string> &o_scenes, const char *fileName)
94:	{
95:		FILE *file = fopen(fileName, "rb");
96:		if (file)
97:		{
98:			char line[_MAX_PATH];
99:
100:			line[sizeof(line)-1]=0;
101:			while (fgets(line, sizeof(line)-1, file))
102:			{
103:				for (char *iter=line;*iter;iter++)
104:				{
105:					if (*iter=='\r' || *iter=='\n')
106:					{
107:						*iter=0;
108:						break;
109:					}
110:				}
111:
112:				if (*line)
113:				{
114:					_strlwr(line);
115:					o_scenes.insert(std::string(line));
116:				}
117:			}
118:
119:			fclose(file);
120:			file=0;
120:			file=0;
121:		}
122:	}
