1516:bool Game::_startCutScene(const char *fileName, bool doReplayCheck)
1517:{
1518:	if (ConfigClientGame::getDisableCutScenes())
1519:	{
1520:		return false;
1521:	}
1522:
1523:	if (ms_cutScene)
1524:	{
1525:		return false;
1526:	}
1527:
1528:	if (!Game::isClient())
1529:	{
1530:		return false;
1531:	}
1532:
1533:	//-----------------------------------------------------------
1534:	bool alreadySeen=false;
1535:	std::string playerBaseFileName;
1536:	if (doReplayCheck)
1537:	{
1538:		std::string loginId;
1539:		std::string clusterName;
1540:		NetworkId id;
1541:
1542:		Game::getLastPlayerInfo(loginId, clusterName, id);
1543:
1544:		// - - - - - - - - - - - - - - - - - - - - - - 
1545:		loginId = GameNetwork::getUserName ();
1546:		if (loginId.empty ())
1547:			loginId = "default_temporary";
1548:		// - - - - - - - - - - - - - - - - - - - - - - 
1549:
1550:		// - - - - - - - - - - - - - - - - - - - - - - 
1551:		if (Game::getSinglePlayer())
1552:		{
1553:			clusterName = "single_player";
1554:		}
1555:		else
1556:		{
1557:			std::string networkCluster = GameNetwork::getCentralServerName();
1558:			if (!networkCluster.empty())
1559:			{
1560:				clusterName = networkCluster;
1561:			}
1562:		}
1563:		// - - - - - - - - - - - - - - - - - - - - - - 
1564:
1565:		// - - - - - - - - - - - - - - - - - - - - - - 
1566:		const ClientObject * const clientPlayer = Game::getClientPlayer();
1567:		if (clientPlayer)
1568:		{
1569:			id = clientPlayer->getNetworkId ();
1570:		}
1571:		else if (ms_nextScene)
1572:		{
1573:			id = ms_nextScene->getPlayerNetworkId();
1574:		}
1575:		// - - - - - - - - - - - - - - - - - - - - - - 
1576:		
1577:		static const std::string prefix = "profiles/";
1578:		static const std::string slash = "/";
1579:
1580:		playerBaseFileName = prefix + loginId + slash + clusterName + slash + id.getValueString();
1581:
1582:		alreadySeen = CutScene::getCutSceneSeen(fileName, playerBaseFileName.c_str());
1583:	}
1584:
1585:	//-----------------------------------------------------------
1586:
1587:	if (  alreadySeen
1588:		&& !ConfigClientGame::getReplayCutScenes()
1589:		)
1590:	{
1591:		return false;
1592:	}
1593:
1594:	//-----------------------------------------------------------
1595:
1596:	const bool isPremier = doReplayCheck && !alreadySeen;
1597:
1598:	if (!CutScene::start(fileName, isPremier))
1599:	{
1600:		return false;
1601:	}
1602:
1603:	ms_endCutScene=false;
1604:	ms_cutScene=true;
1605:

