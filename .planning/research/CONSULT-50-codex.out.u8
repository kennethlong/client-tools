994:
995:void Graphics::beginScene()
996:{
997:	// gl11 embed-resize deferral: apply a pending resize at a frame boundary, but
998:	// only once the first present has happened (render state established). This is
999:	// the safe point for the resize/device-restored fan-out; an early embed
1000:	// WM_SIZE (Utinni reparent during startup) is queued by displayModeChanged
1001:	// and lands here on the next frame after the first present. beginScene runs
1002:	// only from the game loop (the install-time clear uses the plugin's beginScene
1003:	// directly), so this never runs mid-init.
1004:	if (ms_resizePending && ms_firstPresentDone)
1005:	{
1006:		ms_resizePending = false;
1007:		if (ms_pendingResizeWidth > 0 && ms_pendingResizeHeight > 0
1008:			&& (ms_pendingResizeWidth != ms_currentRenderTargetWidth || ms_pendingResizeHeight != 
ms_currentRenderTargetHeight))
1009:		{
1010:			static bool s_loggedResizeApply = false;
1011:			WARNING(!s_loggedResizeApply,
1012:				("Graphics::beginScene: applying deferred gl11 resize w=%d h=%d", ms_pendingResizeWidth, 
ms_pendingResizeHeight));
1013:			s_loggedResizeApply = true;
1014:
1015:			Graphics::resize(ms_pendingResizeWidth, ms_pendingResizeHeight);
1016:		}
1017:	}
1018:
1019:#ifdef _DEBUG
1020:	ms_haveBegin = true;
1021:#endif
1022:
1023:	NOT_NULL(ms_api->beginScene);
1024:	ms_api->beginScene();
1025:}
