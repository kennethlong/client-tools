386:
387:void GraphicsNamespace::displayModeChanged()
388:{
389:	// D3D11 (gl11): a WM_SIZE / display change means the window client rect
390:	// changed. Drive the engine's full resize -- Graphics::resize updates the
391:	// render-target dimension globals AND calls ms_api->resize, which resizes the
392:	// swap-chain back-buffer and fires the device-restored callbacks so the
393:	// offscreen scene render target(s) (PostProcessingEffectsManager / Bloom) +
394:	// the per-frame camera viewport/projection (GroundScene re-reads
395:	// getCurrentRenderTarget* every frame) all track the new size. Without this
396:	// only the back-buffer resized while the scene viewport/RT/projection stayed
397:	// at the creation size, so the embedded scene rendered cropped to the
398:	// top-left of a resized back-buffer.
399:	//
400:	// D3D9 keeps its legacy deferred path (ms_api->displayModeChanged sets a flag
401:	// handled by checkDisplayMode) -- the embedded D3D9 case relies on
402:	// render-target-space stretch and must not be rerouted through a device reset.
403:	if (ms_rasterMajor == 11 && ms_api && ms_api->resize)
404:	{
405:		HWND const window = Os::getWindow();
406:		if (window)
407:		{
408:			RECT rc;
409:			if (GetClientRect(window, &rc))
410:			{
411:				int const newWidth  = rc.right - rc.left;
412:				int const newHeight = rc.bottom - rc.top;
413:				if (newWidth > 0 && newHeight > 0)
414:				{
415:					// DEFER -- never resize synchronously here. Under Utinni
416:					// injection the window is reparented + SetWindowPos-resized
417:					// during startup, delivering WM_SIZE before the first frame.
418:					// Doing the resize/device-restored fan-out before the first
419:					// present (device/RTs/callback targets not yet established)
420:					// regressed the injected render path (no render). Record the
421:					// latest requested size; Graphics::beginScene applies it once
422:					// ms_firstPresentDone -- i.e. the latest size wins, applied at
423:					// a frame boundary after render state exists. Standalone is
424:					// unaffected (it gets no early embed resize).
425:					ms_pendingResizeWidth  = newWidth;
426:					ms_pendingResizeHeight = newHeight;
427:					ms_resizePending       = true;
428:
429:					static bool s_loggedResizeRequest = false;
430:					WARNING(!s_loggedResizeRequest,
431:						("Graphics::displayModeChanged(gl11): resize request w=%d h=%d rasterMajor=%d 
firstPresentDone=%d -> %s",
432:						 newWidth, newHeight, ms_rasterMajor, ms_firstPresentDone ? 1 : 0,
433:						 ms_firstPresentDone ? "apply next beginScene" : "DEFERRED until first present"));
434:					s_loggedResizeRequest = true;
435:				}
436:			}
437:		}
438:		return;
439:	}
440:
441:	if (ms_api && ms_api->displayModeChanged)
442:		ms_api->displayModeChanged();
443:}
