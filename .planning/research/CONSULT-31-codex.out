1712:void SoftwareBlendSkeletalShaderPrimitive::skinData(int transformCount, const PoseModelTransform *transformArray, VertexBufferWriteIterator &iterator) const
1713:{
1714:	//-- Initialize doSkinning to true only on the first render.
1715:	bool doSkinning = true;
1716:
1717:	if (m_hasBeenSkinned && m_everyOtherFrameSkinningEnabled)	
1718:	{
1719:		// We're doing every other frame skinning.  Figure out if 
1720:		// we should skin for this appearance this frame.
1721:
1722:		//-- If last bit of object id and frame number both are even 
1723:		//   or both are odd, do the skinning.
1724:		Object *const owner = m_appearance.getOwner();
1725:		if (owner)
1726:		{
1727:			uint32 const ownerId     = static_cast<uint32>(owner->getNetworkId().getValue());
1728:			uint32 const frameNumber =  static_cast<uint32>(Os::getNumberOfUpdates());
1729:
1730:			doSkinning = (((ownerId & 0x01) ^ (frameNumber & 0x01)) == 0);
1731:		}
1732:	}
1733:
1734:	if (!doSkinning)
1735:	{
1736:		return;
1737:	}
1738:
1739:	if (m_skinningMode==SM_noSkinning && m_hasBeenSkinned)
1740:	{
1741:		return;
1742:	}
1743:
1744:	//-- Handle skinning if we're going to do it.
1745:	switch (m_skinningMode)
1746:	{
1747:		case SM_softSkinning:
1748:		{
1749:			fillVertexBuffer(transformCount, transformArray, iterator);
1750:		} break;
1751:
1752:		case SM_hardSkinning:
1753:		case SM_noSkinning:
1754:		{
1755:			const VertexBufferDescriptor *vbi = iterator.getDescriptor();
1756:			DEBUG_FATAL(!vbi, ("Vertex buffer iterator has no descriptor"));
1757:		#ifdef _DEBUG
1758:			DEBUG_FATAL(vbi->offsetPosition!=0, ("Vertex buffer has an unsupported format."));
1759:			DEBUG_FATAL(vbi->offsetNormal!=12, ("Vertex buffer has an unsupported format."));
1760:		#endif
1761:			const int vertexSize = vbi->vertexSize;
1762:			byte *viter = (byte *)iterator.getDataPointer();
1763:
1764:			fill_vb_work *w = (fill_vb_work *)STACK_ALLOC_ALIGN_16(sizeof(fill_vb_work));
1765:			memset(w, 0, sizeof(*w));
1766:
1767:			if (m_hasDot3Vector)
1768:			{
1769:				NOT_NULL(m_sourceDot3Vectors);
1770:				const int dot3Offset = vbi->offsetTextureCoordinateSet[m_dot3TextureCoordinateSetIndex];
1771:				DEBUG_FATAL(dot3Offset<=0, ("Vertex buffer has an unsupported format."));
1772:
1773:				w->construct(
1774:					m_vertexCount, 
1775:					m_sourceVectors, 
1776:					m_sourceDot3Vectors, 
1777:					transformArray, 
1778:					vertexSize, 
1779:					viter, 
1780:					viter + dot3Offset
1781:				);
1782:
1783:			#if TRY_FOR_SSE
1784:				if (s_useSSE)
1785:				{
1786:					w->fillDot3VertexBufferHard_sse();
1787:				}
1788:				else
1789:			#endif
1790:				{
1791:					w->fillDot3VertexBufferHard();
1792:				}
1793:			}
1794:			else
1795:			{
1796:				w->construct(
1797:					m_vertexCount, 
1798:					m_sourceVectors, 
1799:					0, 
1800:					transformArray, 
1801:					vertexSize, 
1802:					viter, 
1803:					0
1804:				);
1805:
1806:			#if TRY_FOR_SSE
1807:				if (s_useSSE)
1808:				{
1809:					w->fillVertexBufferHard_sse();
1810:				}
1811:				else
1812:			#endif
1813:				{
1814:					w->fillVertexBufferHard();
1815:				}
1816:			}
1817:
1818:			const Vector &minVector=w->minVector;
1819:			const Vector &maxVector=w->maxVector;
1820:			m_boxExtent.set(minVector, maxVector, (maxVector + minVector) * 0.5f, (maxVector - minVector).magnitude() * 0.5f);
1821:		} break;
1822:	}
1823:
1824:	m_hasBeenSkinned = true;
1825:}
