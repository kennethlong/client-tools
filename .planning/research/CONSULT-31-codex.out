366:inline int Skeleton::Segment::transformCountAccumulate(int sumSoFar, const Segment *segment)
367:{
368:	NOT_NULL(segment);
369:
370:	const int jointCount     = segment->m_skeletonTemplate.getJointCount();
371:	const int hardpointCount = (segment->m_hardpoints ? static_cast<int>(segment->m_hardpoints->size()) : 0);
372:
373:	return sumSoFar + jointCount + hardpointCount;
374:}
