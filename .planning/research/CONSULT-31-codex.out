1338:void Skeleton::calculateJointToRootTransforms() const
1339:{
1340:	NOT_NULL(m_skeletonSegments);
1341:	NOT_NULL(m_jointToRootTransforms);
1342:
1343:	NP_PROFILER_AUTO_BLOCK_DEFINE("Skeleton::calculateJointToRootTransforms");
1344:
1345:	const int frameNumber = Os::getNumberOfUpdates();
1346:	if (m_frameLastJointToRootCalculate == frameNumber)
1347:	{
1348:		// we've already calculated this
1349:		return;
1350:	}
1351:
1352:#if PRODUCTION == 0
1353:	++s_calculateJointToRootTransformsEvalCount;
1354:#endif
1355:
1356:	//-- Get alter's elapsed time.  Needed for transform modifiers.
1357:	float const elapsedTime = getAnimationResolver().getMostRecentAlterElapsedTime();
1358:
1359:	Quaternion  animationResolverRotation;
1360:	Vector      animationResolverTranslation;
1361:
1362:	//-- sweep through the skeleton segments
1363:	const size_t segmentCount = m_skeletonSegments->size();
1364:	for (size_t segmentIndex = 0; segmentIndex < segmentCount; ++segmentIndex)
1365:	{
1366:		const Segment *const segment = (*m_skeletonSegments)[segmentIndex];
1367:		NOT_NULL(segment);
1368:
1369:		const std::vector<int> &jointIndexMap = segment->getTransformResolverJointIndexMap();
1370:
1371:		//-- handle segment skeleton joints
1372:		const BasicSkeletonTemplate &skeletonTemplate = segment->getSkeletonTemplate();
1373:		const int                    jointCount       = skeletonTemplate.getJointCount();
1374:
1375:		const int        *localParentIndexArray  = NON_NULL(skeletonTemplate.getJointParentIndexArray());
1376:		const Quaternion *preMultiplyRotations   = NON_NULL(skeletonTemplate.getPreMultiplyRotations());
1377:		const Quaternion *postMultiplyRotations  = NON_NULL(skeletonTemplate.getPostMultiplyRotations());
1378:
1379:		const Vector     *bindPoseTranslations   = NON_NULL(skeletonTemplate.getBindPoseTranslations());
1380:		const Quaternion *bindPoseRotations      = NON_NULL(skeletonTemplate.getBindPoseRotations());
1381:
1382:		//-- Setup transform modifier application during main loop.
1383:		TransformModifierMap::iterator  modifierEndIt;
1384:		TransformModifierMap::iterator  modifierIt;
1385:		TransformModifierMap::iterator *modifierItPtr;
1386:
1387:		if (m_transformModifierMap && !m_transformModifierMap->empty())
1388:		{
1389:			modifierEndIt = m_transformModifierMap->end();
1390:			modifierIt    = m_transformModifierMap->begin();
1391:			modifierItPtr = &modifierIt;
1392:		}
1393:		else
1394:		{
1395:			// No modifiers.
1396:			modifierItPtr = 0;
1397:		}
1398:
1399:		for (int localJointIndex = 0; localJointIndex < jointCount; ++localJointIndex)
1400:		{
1401:			const int globalTransformIndex = localJointIndex + segment->getFirstTransformIndex();
1402:
1403:			//-- Get animation resolver's transform components for this joint.
1404:			const int animationResolverTransformIndex = jointIndexMap[static_cast<std::vector<int>::size_type>(localJointIndex)];
1405:			if (animationResolverTransformIndex < 0)
1406:			{
1407:				// Somehow we've got an asset that thinks a specified transform is needed but the skeleton template doesn't provide it.
1408:				// Skip this transform and hope for the best.
1409:				// @todo detect what is causing this and generate a warning at load time of the other asset.
1410:				DEBUG_WARNING(true, ("animation resolver has no entry for appearance [%s],joint [%s], skeleton transform count [%d].", m_animationResolver.getSkeletalAppearanceTemplate().getName(), segment->getTransformName(localJointIndex).getString(), m_transformCount));
1411:				continue;
1412:			}
1413:
1414:			m_animationResolver.getTransformComponents(animationResolverTransformIndex, animationResolverRotation, animationResolverTranslation);
1415:
1416:			//-- Build the jointToParent transform.
1417:
1418:			// animations are relative to bind pose.  calculate absolute animated rotation and translation
1419:			const Quaternion animatedRotation      = animationResolverRotation * bindPoseRotations[localJointIndex];
1420:			const Vector localToParentTranslation  = bindPoseTranslations[localJointIndex] + animationResolverTranslation;
1421:
1422:			// apply pre-animated and post-animated rotations
1423:			// -TRF- quat multiply is expensive: since many joints have identity pre-multiplies, should check for this at export time and flag them
1424:			const Quaternion localToParentRotation = postMultiplyRotations[localJointIndex] * (animatedRotation * preMultiplyRotations[localJointIndex]);
1425:
1426:			// construct the transform
1427:			Transform jointToParentTransform(Transform::IF_none);
1428:
1429:			localToParentRotation.getTransformPreserveTranslation(&jointToParentTransform);
1430:			jointToParentTransform.setPosition_p(localToParentTranslation);
1431:
1432:			//-- build jointToRoot through parentToRoot * jointToParent
1433:			// get dest transform location
1434:			Transform &destTransform = m_jointToRootTransforms[globalTransformIndex];
1435:
1436:			// get parent transform index
1437:			const int localParentIndex = localParentIndexArray[localJointIndex];
1438:			DEBUG_FATAL(localParentIndex >= localJointIndex, ("invalid: skeleton template has child transform existing before parent transform [%d/%d]", localParentIndex, localJointIndex));
1439:
1440:			Transform const *parentToRootTransform = 0;
1441:
1442:			if (localParentIndex < 0)
1443:			{
1444:				// this is the root joint for this skeleton template
1445:				if (segment->getParentGlobalTransformIndex() < 0)
1446:				{
1447:					// this is the root of the entire skeleton. no parentToRoot
1448:					parentToRootTransform = m_scaleTransform;
1449:				}
1450:				else
1451:				{
1452:					// link root of this skeleton segment to joint of parent skeleton
1453:					parentToRootTransform = &(m_jointToRootTransforms[segment->getParentGlobalTransformIndex()]);
1454:				}
1455:			}
1456:			else
1457:			{
1458:				// this is a typical non-root joint for the skeleton template
1459:				size_t const parentTransformIndex  = static_cast<size_t>(segment->getFirstTransformIndex() + localParentIndex);
1460:				parentToRootTransform = &(m_jointToRootTransforms[parentTransformIndex]);
1461:			}
1462:
1463:			// build the joint to root (i.e. joint to object) transform.
1464:			NOT_NULL(parentToRootTransform);
1465:			destTransform.multiply(*parentToRootTransform, jointToParentTransform);
1466:
1467:			//-- Apply transform modifiers.
1468:			while (modifierItPtr && ((*modifierItPtr)->first == globalTransformIndex))
1469:			{
1470:				// Get modifier.
1471:				TransformModifier *const modifier = (*modifierItPtr)->second;
1472:				NOT_NULL(modifier);
1473:
1474:				// Apply modifier.
1475:				bool const transformModified = modifier->modifyTransform(elapsedTime, *this, skeletonTemplate.getJointName(localJointIndex), *parentToRootTransform, jointToParentTransform, destTransform);
1476:				UNREF(transformModified);
1477:
1478:				// Move to next modifier.
1479:				++modifierIt;
1480:				if (modifierIt == modifierEndIt)
1481:				{
1482:					// Clear the modifier pointer so we know we're done.
1483:					modifierItPtr = 0;
1484:				}
1485:			}
1486:		}
1487:
1488:		//-- handle segment hardpoints
1489:		segment->calculateHardpointToRootTransforms(segment->getFirstTransformIndex(), m_jointToRootTransforms);
1490:	}
1491:
1492:	//-- remember that we calculated this for this frame
1493:	m_frameLastJointToRootCalculate = frameNumber;
1494:}
