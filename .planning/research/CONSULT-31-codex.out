702:					else
703:					{
704:						capeCurRun = 1;
705:						capeCurStart = capeVi;
706:					}
707:					capePrev = capeCur;
708:				}
709:
710:				if (capeLongRun >= 16)
711:				{
712:					++s_capeProbeCount;
713:					int const capeFirstXform = m_sourceVectors[capeLongStart].m_firstTransformData.m_transformIndex;
714:					float capeRotMag = -1.0f;
715:					if (capeFirstXform >= 0 && capeFirstXform < transformCount)
