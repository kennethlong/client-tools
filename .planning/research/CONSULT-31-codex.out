227:bool TransformAnimationResolver::SkeletonTemplateData::isSkeletonTemplate(const SkeletonTemplate &skeletonTemplate) const
228:{
229:	//-- Check this skeleton template against the first detail level of the given skeletonTemplate.
230:	const BasicSkeletonTemplate *testSkeletonTemplate = skeletonTemplate.fetchBasicSkeletonTemplate(0);
231:	const bool                   result = (testSkeletonTemplate == m_skeletonTemplate);
232:
233:	//-- Release local reference.
234:	testSkeletonTemplate->release();
235:
236:	return result;
237:}
