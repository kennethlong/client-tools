1135:void TransformAnimationResolver::recreateAnimationControllers(bool destroyExistingControllerFirst)
1136:{
1137:	//-- Recreate animation controllers.
1138:	if (!m_skeletonTemplateDataVector)
1139:		return;
1140:
1141:	const SkeletonTemplateDataVector::iterator endIt = m_skeletonTemplateDataVector->end();
1142:	for (SkeletonTemplateDataVector::iterator it = m_skeletonTemplateDataVector->begin(); it != endIt; ++it)
1143:	{
1144:		NOT_NULL(*it);
1145:		(*it)->recreateAnimationController(m_appearanceTemplate, m_appearance, destroyExistingControllerFirst, m_mostRecentAnimationStatePath);
1146:	}
1147:
1148:	//-- Reset evaluation flags.
1149:	if (m_transformEvaluatedFlags)
1150:	{
1151:		memset(m_transformEvaluatedFlags, 0, static_cast<size_t>(m_transformCount));
1152:	}
1153:
1154:	//-- Alter the appearance so the bind pose is not used on the next frame.
1155:	IGNORE_RETURN(m_appearance.alter(0.05f));
1156:}
