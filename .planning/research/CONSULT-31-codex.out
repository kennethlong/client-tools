852:/**
853: * Calculate the bounding box coordinates for this blended mesh.
854: *
855: * Since this instance represents a mesh that is modified by transforms,
856: * the bounding box will necessarily change when the transforms change.
857: * Therefore, it makes no sense for this instance to try to cache this
858: * data internally.  Users of this class that want a cheap bounding box
859: * calculation will need to be smart about (1) how accurate the bounding
860: * box must be and (2) how often they need to run over this data to
861: * caculate it.
862: *
863: * Performance side-effects: this function will force the skeleton to evaluate 
864: * its transforms if that event hasn't already happened.
865: *
866: * @param minVector  the minimum x, y and z value for the bounding box
867: *                   are returned in this vector.
868: * @param maxVector  the maximum x, y and z value for the bounding box
869: *                   are returned in this vector.
870: */
871:
872:void SoftwareBlendSkeletalShaderPrimitive::calculateBoundingBox(Vector &minVector, Vector &maxVector) const
873:{
874:	//-- initialize min and max value
875:	minVector.set(std::numeric_limits<float>::max(), std::numeric_limits<float>::max(), std::numeric_limits<float>::max());
876:	maxVector.set(-std::numeric_limits<float>::max(), -std::numeric_limits<float>::max(), -std::numeric_limits<float>::max());
877:
878:	//-- get the current transform data from the appearance
879:	const Skeleton &skeleton = m_appearance.getSkeleton(m_lodIndex);
880:
881:#ifdef _DEBUG
882:	const int              transformCount = skeleton.getTransformCount();
883:#endif
884:	const PoseModelTransform *const transformArray = skeleton.getBindPoseModelToRootTransforms();
885:	NOT_NULL(transformArray);
886:
887:	const TransformData *transformData = m_transformData;
888:
889:	//-- calculate transformed xyz, track min and max
890:	for (int vertexIndex = 0; vertexIndex < m_vertexCount; ++vertexIndex)
891:	{
892:		const SourceVertex &sourceVertex = m_sourceVectors[vertexIndex];
893:		const Vector &sourcePosition     = sourceVertex.m_position;
894:
895:		//-- initialize first position with first influencing transform
896:		const TransformData &firstTransformData = sourceVertex.m_firstTransformData;
897:		VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, firstTransformData.m_transformIndex, transformCount);
898:
899:		const PoseModelTransform &firstTransform = transformArray[firstTransformData.m_transformIndex];
900:
901:		Vector blendPosition = firstTransform.rotateTranslate_l2p(sourcePosition) * firstTransformData.m_transformWeight;
902:
903:		//-- apply remaining transforms
904:		for (int j=sourceVertex.m_extraTransformDataCount;j>0;j--, transformData++)
905:		{
906:			// get transform data
907:			VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformData->m_transformIndex, transformCount);
908:
909:			// apply it
910:			const PoseModelTransform &transform = transformArray[transformData->m_transformIndex];
911:
912:			blendPosition += transform.rotateTranslate_l2p(sourcePosition) * transformData->m_transformWeight;
913:		}
914:
915:		//-- apply blended position to min/max
916:		minVector.set(std::min(minVector.x, blendPosition.x), std::min(minVector.y, blendPosition.y), std::min(minVector.z, blendPosition.z));
917:		maxVector.set(std::max(maxVector.x, blendPosition.x), std::max(maxVector.y, blendPosition.y), std::max(maxVector.z, blendPosition.z));
918:	}
919:}
