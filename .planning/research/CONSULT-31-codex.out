530:void Skeleton::Segment::addHardpoint(CrcString const &hardpointName, int localParentIndex, const Transform &hardpointToParent)
531:{
532:	if (!m_hardpoints || !m_hardpointNameToLocalIndexMap)
533:	{
534:		DEBUG_FATAL(m_hardpoints, ("expecting null m_hardpoints"));
535:		m_hardpoints = new HardpointVector();
536:
537:		DEBUG_FATAL(m_hardpointNameToLocalIndexMap, ("expecting null m_hardpointNameToLocalIndexMap"));
538:		m_hardpointNameToLocalIndexMap = new HardpointNameMap();
539:	}
540:
541:	//-- find insertion point for hardpoint name
542:	HardpointNameMap::iterator itLowerBound = m_hardpointNameToLocalIndexMap->lower_bound(&hardpointName);
543:	
544:	// check if hardpoint already exists
545:	if ((itLowerBound != m_hardpointNameToLocalIndexMap->end()) && !(m_hardpointNameToLocalIndexMap->key_comp()(&hardpointName, itLowerBound->first)))
546:	{
547:		// this hardpoint is in the list already
548:		DEBUG_WARNING(true, ("trying to add hardpoint [%s] to same skeleton segment multiple times", hardpointName.getString()));
549:		return; //lint !e527 // unreachable // not in release
550:	}
551:
552:	//-- create the hardpoint
553:	const int hardpointLocalIndex = m_skeletonTemplate.getJointCount() + static_cast<int>(m_hardpoints->size());
554:	m_hardpoints->push_back(new Hardpoint(hardpointName, hardpointToParent, localParentIndex));
555:
556:	//-- add to name map
557:	IGNORE_RETURN(m_hardpointNameToLocalIndexMap->insert(itLowerBound, HardpointNameMap::value_type(&(m_hardpoints->back()->getName()), hardpointLocalIndex)));
558:}
