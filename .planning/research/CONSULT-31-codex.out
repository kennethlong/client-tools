784:// ----------------------------------------------------------------------
785:
786:void TransformAnimationResolver::alter(float deltaTime)
787:{
788:	NP_PROFILER_AUTO_BLOCK_DEFINE("TransformAnimationResolver::alter");
789:
790:	//-- Set all transforms to be unevaluated.  All transforms need to be
791:	//   re-evaluated after the animation controllers are altered because
792:	//   new animation has (potentially) taken place.  The artifact: calls
793:	//   to TransformAnimationResolver::getRotation()/getTranslation()
794:	//   prior to alter will return different values than post-alter during
795:	//   any given frame.
796:	if (m_transformEvaluatedFlags)
797:	{
798:		// Reset all evaluation flags.
799:		memset(m_transformEvaluatedFlags, 0, static_cast<size_t>(m_transformCount));
800:	}
801:
802:	//-- Alter all animation controllers.  Each SkeletonTemplate associated
803:	//   with this resolver may have its own animation controller.
804:	if (m_skeletonTemplateDataVector)
805:	{
806:		const SkeletonTemplateDataVector::iterator endIt = m_skeletonTemplateDataVector->end();
807:		for (SkeletonTemplateDataVector::iterator it = m_skeletonTemplateDataVector->begin(); it != endIt; ++it)
808:		{
809:			NOT_NULL(*it);
810:			(*it)->alter(deltaTime);
811:		}
812:	}
813:
814:	//-- Save the most recent alter elapsed time so other entities (e.g. skeleton) can learn about it.
815:	m_mostRecentAlterElapsedTime = deltaTime;
816:}
