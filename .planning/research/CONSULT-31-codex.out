1865:void Skeleton::allocateTransformArrays(int transformCount)
1866:{
1867:	//-- Free existing storage.
1868:	if (m_jointToRootTransformBackingStore)
1869:	{
1870:		delete [] m_jointToRootTransformBackingStore;
1871:		m_jointToRootTransformBackingStore = 0;
1872:		m_jointToRootTransforms            = 0;
1873:	}
1874:
1875:	if (m_bindPoseModelToRootTransformBackingStore)
1876:	{
1877:		delete [] m_bindPoseModelToRootTransformBackingStore;
1878:		m_bindPoseModelToRootTransformBackingStore = 0;
1879:		m_bindPoseModelToRootTransforms            = 0;
1880:	}
1881:
1882:	//-------------------------------------------------------
1883:	//-- Create new storage, aligned to 32 bytes.
1884:	// jointToRoot
1885:	const size_t dataSize = static_cast<size_t>(transformCount) * sizeof(Transform) + 31;
1886:	m_jointToRootTransformBackingStore = new uint8[dataSize];
1887:
1888:	m_jointToRootTransforms = reinterpret_cast<Transform*>(POINTER_ALIGN_32(m_jointToRootTransformBackingStore));
1889:
1890:	//-------------------------------------------------------
1891:	// bindPoseModelToRoot
1892:	const size_t poseDataSize = static_cast<size_t>(transformCount) * sizeof(PoseModelTransform) + 31;
1893:	m_bindPoseModelToRootTransformBackingStore = new uint8[poseDataSize];
1894:
1895:	m_bindPoseModelToRootTransforms = reinterpret_cast<PoseModelTransform*>(POINTER_ALIGN_32(m_bindPoseModelToRootTransformBackingStore));
1896:	//-------------------------------------------------------

