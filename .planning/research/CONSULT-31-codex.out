915:// ----------------------------------------------------------------------
916:
917:void Skeleton::removeSkeletonSegment(int skeletonSegmentId)
941:void Skeleton::findSegmentLocalTransformIndex(CrcString const &transformName, int &segmentIndex, int &segmentLocalTransformIndex, bool &foundIt) const
942:{
943:	foundIt = false;
944:
945:	//-- scan for the transform name in all skeleton segments
946:	segmentIndex = 0;
947:
948:	const SegmentVector::const_iterator itEnd = m_skeletonSegments->end();
949:	for (SegmentVector::const_iterator it = m_skeletonSegments->begin(); it != itEnd; ++it, ++segmentIndex)
950:	{
951:		(*it)->findLocalTransformIndex(transformName, segmentLocalTransformIndex, foundIt);
952:
953:		if (foundIt)
954:			return;
955:	}
956:
957:	foundIt = false;
958:}
959:
960:// ----------------------------------------------------------------------
961:
962:void Skeleton::findTransformIndex(CrcString const &name, int *transformIndex, bool *found) const
963:{
964:	NP_PROFILER_AUTO_BLOCK_DEFINE("Skeleton::findTransformIndex");
965:
966:	NOT_NULL(transformIndex);
967:	NOT_NULL(found);
968:
969:	DEBUG_FATAL(m_modifyingSkeleton, ("invalid to call between beginSkeletonModification()/endSkeletonModification() call"));
970:
971:	int  segmentIndex               = -1;
972:	int  segmentLocalTransformIndex = -1;
973:	
974:	findSegmentLocalTransformIndex(name, segmentIndex, segmentLocalTransformIndex, *found);
975:
976:	if (*found)
977:	{
978:		DEBUG_FATAL(segmentIndex < 0, ("bad segmentIndex %d", segmentIndex));
979:		DEBUG_FATAL(segmentLocalTransformIndex < 0, ("bad index %d", segmentLocalTransformIndex));
980:
981:		// convert local transform index to global transform index
982:		*transformIndex = (*m_skeletonSegments)[static_cast<size_t>(segmentIndex)]->getFirstTransformIndex() + segmentLocalTransformIndex;
983:	}
984:}
985:
986:// ----------------------------------------------------------------------
987:
988:int Skeleton::getTransformIndex(CrcString const &name) const
989:{
990:	bool found          = false;
991:	int  transformIndex = -1;
992:
993:	findTransformIndex(name, &transformIndex, &found);
994:
995:	FATAL(!found, ("failed to find transform named [%s]", name.getString()));
996:	return transformIndex; //lint !e527 // unreachable // yes, for MSVC
997:}
