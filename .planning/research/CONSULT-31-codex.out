277:void SkeletalAppearanceTemplate::createSkeletonLods(SkeletonVector &skeletons, TransformAnimationResolver &animationResolver) const
278:{
279:	//-- trivially reject routine if there's not skeleton templates
280:	if (m_skeletonTemplateInfo->empty())
281:	{
282:		skeletons.resize(0);
283:		return;
284:	}
285:
286:	//-- retrieve all the SkeletonTemplate instances
287:
288:	//   Implementation note: I don't store skeleton templates directly as pointers
289:	//   internally because the creation of SkeletalAppearanceTemplate instances uses
290:	//   a filename interface when adding and removing items.  Consider reworking this
291:	//   to simply this function.
292:	const size_t skeletonTemplateCount = m_skeletonTemplateInfo->size();
293:	std::vector<const SkeletonTemplate*>  skeletonTemplates(skeletonTemplateCount);
294:
295:	for (size_t i = 0; i < skeletonTemplateCount; ++i)
296:	{
297:		skeletonTemplates[i] = SkeletonTemplateList::fetch((*m_skeletonTemplateInfo)[i].m_skeletonTemplateName);
298:		NOT_NULL(skeletonTemplates[i]);
299:	}
300:
301:	//-- prepare the return array: size to # of LODs in first SkeletonTemplate.
302:	const int skeletonDetailCount = skeletonTemplates[0]->getDetailCount();
303:	DEBUG_FATAL(skeletonDetailCount < 1, ("skeleton template has not detail levels.\n"));
304:
305:	skeletons.resize(static_cast<size_t>(skeletonDetailCount));
306:
307:	//-- create each skeleton LOD
308:	for (int detailIndex = 0; detailIndex < skeletonDetailCount; ++detailIndex)
309:	{
310:		//-- build Skeleton instance for this LOD by creating the base skeleton and attaching all required attachments.
311:		for (size_t templateIndex = 0; templateIndex < skeletonTemplateCount; ++templateIndex)
312:		{
313:			//-- fetch the basic skeleton template associated with this LOD level
314:			const SkeletonTemplate *skeletonTemplate = skeletonTemplates[templateIndex];
315:			NOT_NULL(skeletonTemplate);
316:
317:			// determine which LOD to use (I'll allow a constituent skeleton template to have fewer LODs than the root skeleton).
318:			const int detailIndexUsed = std::min(detailIndex, skeletonTemplate->getDetailCount() - 1);
319:
320:			// fetch it
321:			const BasicSkeletonTemplate *const basicSkeletonTemplate = skeletonTemplate->fetchBasicSkeletonTemplate(detailIndexUsed);
322:			NOT_NULL(basicSkeletonTemplate);
323:
324:			if (templateIndex == 0)
325:			{
326:				// create the skeleton with the root skeleton template
327:				skeletons[static_cast<size_t>(detailIndex)] = basicSkeletonTemplate->createSkeleton(animationResolver);
328:				NOT_NULL(skeletons[static_cast<size_t>(detailIndex)]);
329:
330:				skeletons[static_cast<size_t>(detailIndex)]->beginSkeletonModification();
331:			}
332:			else
333:			{
334:				//-- attach skeleton template to the skeleton
335:				NOT_NULL(skeletons[static_cast<size_t>(detailIndex)]);
336:				IGNORE_RETURN(skeletons[static_cast<size_t>(detailIndex)]->attachSkeletonSegment(*basicSkeletonTemplate, (*m_skeletonTemplateInfo)[templateIndex].m_attachmentTransformName));
