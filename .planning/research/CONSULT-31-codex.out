908:	//-- create new segment
909:	const int newSegmentIndex = static_cast<int>(m_skeletonSegments->size());
910:	m_skeletonSegments->push_back(new Segment(skeletonTemplate, parentSegment, parentLocalTransformIndex));
911:
912:	return newSegmentIndex; //lint !e429 // custodial pointer segment not freed or returned
913:}
