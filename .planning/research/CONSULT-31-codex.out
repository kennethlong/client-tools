1145:void SoftwareBlendSkeletalShaderPrimitive::_initialize(const MeshConstructionHelper &mesh, int shaderIndex, bool multiStream)
1146:{
1147:	/*
1148:		NOTES
1149:
1150:		In multi stream rendering, the skinned components (position, normal,
1151:		dot3 if present) are skinned directly into a dynamic vertex buffer.  The
1152:		non-skinned, constant components (color and non-dot3 texture coordinates)
1153:		are stored in a per-instance static buffer.
1154:
1155:		In single stream rendering, the skinned components (position, normal,
1156:		dot3 if present) are skinned in a common system vertex buffer.  The
1157:		non-skinned, constant components (color and non-dot3 texture coordinates) are
1158:		stored in an instance system buffer.  The dynamic vertex buffer
1159:		contains the full set of vertex information and is constructed by
1160:		merging skinned common system vertex buffer with the constant component
1161:		system vertex buffer.
1162:	*/
1163:
1164:	/////////////////////////////////////////////////////////////////////////////////////////
1165:	//-- Setup index buffer and render commands.
1166:	buildIndexBufferAndRenderCommands(mesh, shaderIndex);
1167:
1168:	/////////////////////////////////////////////////////////////////////////////////////////
1169:	//-- Retrieve some common values from the mesh.
1170:	const MeshConstructionHelper::PerShaderData *const meshPerShaderData = mesh.getPerShaderData(shaderIndex);
1171:	const uint inputFormat = mesh.getVertexFormat(meshPerShaderData);
1172:	const bool hasArgb     = (inputFormat & MeshConstructionHelper::SVF_argb) != 0;
1173:	const int  tcSetCount  = mesh.getTextureCoordinateSets(meshPerShaderData);
1174:
1175:	/////////////////////////////////////////////////////////////////////////////////////////
1176:	//-- Create the shader.
1177:	m_shader = ShaderTemplateList::fetchModifiableShader(mesh.getShaderTemplateName(meshPerShaderData));
1178:
1179:	/////////////////////////////////////////////////////////////////////////////////////////
1180:	//-- some debug checks
1181:	DEBUG_FATAL((inputFormat & MeshConstructionHelper::SVF_xyz) == 0, ("input mesh does not include xyz data"));
1182:	DEBUG_FATAL((inputFormat & MeshConstructionHelper::SVF_normal) == 0, ("support for non-normal skeletal meshes has been removed, re-export data with normals."));
1183:	UNREF(inputFormat);
1184:
1185:	/////////////////////////////////////////////////////////////////////////////////////////
1186:	//-- get # vertices
1187:	m_vertexCount = mesh.getVertexCount(meshPerShaderData);
1188:	DEBUG_FATAL(m_vertexCount < 1, ("there are no vertices!"));
1189:
1190:	/////////////////////////////////////////////////////////////////////////////////////////
1191:	//-- Construct the constant static vertex buffer.  This format will contain
1192:	//   color and non-dot3 texture coordinates.
1193:	VertexBufferFormat  constantFormat;
1194:	if (multiStream)
1195:	{
1196:		constantFormat.setColor0(hasArgb);
1197:	}
1198:	/////////////////////////////////////////////////////////////////////////////////////////
1199:
1200:	/////////////////////////////////////////////////////////////////////////////////////////
1201:	// Setup dot3 texture coordinate set info and stuff constant texture coordinate set info
1202:	// into constantFormat.
1203:	//
1204:	// Count # non-dot3 texture coordinate sets.
1205:	int constantTcSetCount = 0;
1206:	for (int i = 0; i < tcSetCount; ++i)
1207:	{
1208:		const int dimensionality = mesh.getTextureCoordinateDimensionality(meshPerShaderData, i);
1209:		if (dimensionality != 4)
1210:		{
1211:			++constantTcSetCount;
1212:		}
1213:		else
1214:		{
1215:			// This tc set is the dot3 vector.
1216:			DEBUG_FATAL(m_hasDot3Vector, ("2 sets of 4d texture coordinates are not supported, detected at tc set index [%d] and [%d].", m_dot3TextureCoordinateSetIndex, i));
1217:			DEBUG_FATAL(i != tcSetCount - 1, ("dot3 4d texture coordinates are only supported as the last texture coordinate set, but it is [%d] of [%d].", i + 1, tcSetCount));
1218:
1219:			m_hasDot3Vector                 = true;
1220:			m_dot3TextureCoordinateSetIndex = ms_useMultiStreamVertexBuffers ? 0 : i;
1221:		}
1222:	}
1223:
1224:	// Set constant texture coordinate set info in the vertex buffer.
1225:	if (constantTcSetCount > 0)
1226:	{
1227:		constantFormat.setNumberOfTextureCoordinateSets(constantTcSetCount);
1228:
1229:		int constantTcIndex = 0;
1230:		for (int j = 0; j < tcSetCount; ++j)
1231:		{
1232:			// Retrieve dimensionality.
1233:			const int dimensionality = mesh.getTextureCoordinateDimensionality(meshPerShaderData, j);
1234:			if (dimensionality != 4)
1235:			{
1236:				// Set this non-dot3 texture set into the constant VB format.
1237:				constantFormat.setTextureCoordinateSetDimension(constantTcIndex, dimensionality);
1238:				++constantTcIndex;
1239:			}
1240:		}
1241:	}
1242:	/////////////////////////////////////////////////////////////////////////////////////////
1243:
1244:	/////////////////////////////////////////////////////////////////////////////////////////
1245:	//-- Construct the dynamic vertex buffer.
