538:
539:void TransformAnimationResolver::specifySkeletonTemplates(const SkeletonTemplateVector &skeletonTemplates)
540:{
541:	const SkeletonTemplateVector::size_type  newSkeletonTemplateCount = skeletonTemplates.size();
542:
543:	VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, static_cast<int>(newSkeletonTemplateCount), cms_maxSkeletonTemplateCount);
544:
545:	//-- Walk through existing SkeletonTemplateData entries, removing any that are not present in the newly specified set of skeleton templates.
546:	//   Also take note of which ones already exist so I don't need to recreate them.
547:
548:	// Default all skeletonTemplate entries to require addition.
549:	int8  addSkeletonTemplateFlags[cms_maxSkeletonTemplateCount];
550:	memset(addSkeletonTemplateFlags, 1, newSkeletonTemplateCount);
551:
552:	if (!m_skeletonTemplateDataVector)
553:	{
554:		//-- SkeletonTemplateDataVector doesn't exist, create it.
555:		m_skeletonTemplateDataVector = new SkeletonTemplateDataVector();
556:	}
557:	else
558:	{
559:		//-- SkeletonTemplateDataVector already existed, check desired SkeletonTemplate instances vs. what is already present.
560:		bool deleteDataEntry;
561:
562:		SkeletonTemplateDataVector::iterator endIt = m_skeletonTemplateDataVector->end();
563:		for (SkeletonTemplateDataVector::iterator it = m_skeletonTemplateDataVector->begin(); it != endIt;)
564:		{
565:			//-- Check this SkeletonTemplateData vector against all new skeletonTemplates.
566:			deleteDataEntry = true;
567:
568:			for (SkeletonTemplateVector::size_type i = 0; i < newSkeletonTemplateCount; ++i)
569:			{
570:				if ((*it)->isSkeletonTemplate(*NON_NULL(skeletonTemplates[i])))
571:				{
572:					//-- The existing SkeletonTemplateData entry refers to a SkeletonTemplate that should be present
573:					//   (and therefore preserved --- don't delete it --- animation controller will not require a reset).
574:					deleteDataEntry = false;
575:
576:					//-- Don't need to create an entry for this skeleton template --- one already exists, I'll just use that one.
577:					addSkeletonTemplateFlags[i] = 0;
578:					break;
579:				}
580:			}
581:
582:			//-- Delete data entry as necessary.  Increment it as appropriate.
583:			if (deleteDataEntry)
584:			{
585:				it    = m_skeletonTemplateDataVector->erase(it);
586:				endIt = m_skeletonTemplateDataVector->end();
587:			}
588:			else
589:				++it;
590:		}
591:	}
592:
593:	//-- Create SkeletonTemplateData entries for all SkeletonTemplate instances for which a SkeletonTemplateData
594:	//   is not already in existence.
595:	m_skeletonTemplateDataVector->reserve(newSkeletonTemplateCount);
596:
597:	for (SkeletonTemplateVector::size_type i = 0; i < newSkeletonTemplateCount; ++i)
598:	{
599:		if (addSkeletonTemplateFlags[i])
600:		{
601:			const SkeletonTemplate *skeletonTemplate = skeletonTemplates[i];
602:			NOT_NULL(skeletonTemplate);
603:
604:			int const channel = static_cast<int>(m_skeletonTemplateDataVector->size());
605:			m_skeletonTemplateDataVector->push_back(new SkeletonTemplateData(m_appearanceTemplate, *skeletonTemplate, m_appearance.getAnimationEnvironment(), &m_appearance, channel, m_mostRecentAnimationStatePath, m_callbackInfoVector));
606:		}
607:	}
608:
609:	//-- Assign the starting global transform index for each SkeletonTemplateData.
610:	int startingGlobalTransformIndex = 0;
611:
612:	const SkeletonTemplateDataVector::iterator endIt = m_skeletonTemplateDataVector->end();
613:	for (SkeletonTemplateDataVector::iterator it = m_skeletonTemplateDataVector->begin(); it != endIt; ++it)
614:	{
615:		startingGlobalTransformIndex = (*it)->setFirstGlobalTransformIndex(startingGlobalTransformIndex);
616:	}
617:
618:	//-- Keep track of transform count.
619:	const bool sizeChanged = (startingGlobalTransformIndex != m_transformCount);
620:	m_transformCount       = startingGlobalTransformIndex;
621:
622:	//-- Resize data arrays for transform count.
623:	if (sizeChanged)
624:	{
625:		//-- Create/resize rotation array.
626:		if (!m_rotations)
627:			m_rotations = new QuaternionVector(static_cast<QuaternionVector::size_type>(m_transformCount), Quaternion::identity);
628:		else
629:			m_rotations->resize(static_cast<QuaternionVector::size_type>(m_transformCount));
630:
631:		//-- Create/resize translation array.
632:		if (!m_translations)
633:			m_translations = new VectorVector(static_cast<VectorVector::size_type>(m_transformCount), Vector::zero);
634:		else
635:			m_translations->resize(static_cast<VectorVector::size_type>(m_transformCount));
636:
637:		//-- Recreate transform evaluation flags, set to not-evaluated.
638:		delete [] m_transformEvaluatedFlags;
639:
640:		m_transformEvaluatedFlags = new int8[static_cast<size_t>(m_transformCount)];
641:		NOT_NULL(m_transformEvaluatedFlags);
642:
643:		memset(m_transformEvaluatedFlags, 0, static_cast<size_t>(m_transformCount));
644:	}
645:}
