669:{
670:	NP_PROFILER_AUTO_BLOCK_DEFINE("TransformAnimationResolver::getTransformComponents");
671:
672:	//-- Check for no animation controller situation (e.g. for a wearable).
673:	if (!m_rotations || !m_translations)
674:	{
675:		// Must be no animation controllers.  Return no delta from bind pose.
676:		rotation    = Quaternion::identity;
677:		translation = Vector::zero;
678:
679:		return;
680:	}
681:
682:	//-- Check if the transform's rotation needs to be evaluated.
683:	VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformIndex, m_transformCount);
684:
685:	//-- Evaluate transform data if necessary.
686:	NOT_NULL(m_transformEvaluatedFlags);
687:	if (!m_transformEvaluatedFlags[transformIndex])
688:	{
689:		// Get the associated skeleton template data.
690:		SkeletonTemplateData *stData = 0;
691:
692:		getSkeletonTemplateData(transformIndex, stData);
693:		NOT_NULL(stData);
694:
695:		// Evaluate the transform components.
696:		stData->evaluateTransformComponents(transformIndex, (*m_rotations)[static_cast<QuaternionVector::size_type>(transformIndex)], (*m_translations)[static_cast<VectorVector::size_type>(transformIndex)]);
697:
698:		// Mark transform as evaluated since last alter.
699:		m_transformEvaluatedFlags[transformIndex] = 1;
700:	}
701:
702:	//-- Return evaluated components.
703:	rotation    = (*m_rotations)[static_cast<QuaternionVector::size_type>(transformIndex)];
704:	translation = (*m_translations)[static_cast<VectorVector::size_type>(transformIndex)];
705:}
