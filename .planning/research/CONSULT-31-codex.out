1829: * Soft.
1830: */
1831:
1832:void SoftwareBlendSkeletalShaderPrimitive::fillVertexBuffer(int transformCount, const PoseModelTransform *transformArray, VertexBufferWriteIterator &destVertexIt) const
1833:{
1834:	bool const updateExtentsThisFrame = (m_appearance.getRenderedFrameNumber() & 1) != 0;
1835:
1836:	//-- We will be updating m_boxExtent every frame in fillDynamicVertexBuffer*.  
1837:	//   m_boxExtent will be used to help speed up collision.
1838:	if (updateExtentsThisFrame)
1839:	{
1840:		m_boxExtent.setNegative();
1841:	}
1842:
1843:	UNREF(transformCount);
1844:
1845:	const SourceVertex *sourceVectors = m_sourceVectors;
1846:	const TransformData *transformData = m_transformData;
1847:
1848:	if (m_hasDot3Vector)
1849:	{
1850:		NOT_NULL(m_sourceDot3Vectors);
1851:
1852:		const Dot3Vector *sourceDot3Vectors = m_sourceDot3Vectors;
1853:
1854:		//-- Skin position, normal and dot3 vector.
1855:		for (int i = 0; i < m_vertexCount; ++i, ++destVertexIt, sourceVectors++)
1856:		{
1857:			const Vector        &sourcePosition = sourceVectors->m_position;
1858:			const Vector        &sourceNormal   = sourceVectors->m_normal;
1859:			const Dot3Vector    &sourceDot3     = sourceDot3Vectors[i];
1860:
1861:			// initialize first position and vector
1862:			const TransformData &firstTransformData = sourceVectors->m_firstTransformData;
1863:			VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, firstTransformData.m_transformIndex, transformCount);
1864:			const PoseModelTransform     &firstTransform = transformArray[firstTransformData.m_transformIndex];
1865:
1866:			Vector blendPosition = firstTransform.rotateTranslate_l2p(sourcePosition) * firstTransformData.m_transformWeight;
1867:			Vector blendNormal   = firstTransform.rotate_l2p(sourceNormal)            * firstTransformData.m_transformWeight;
1868:			Vector blendDot3     = firstTransform.rotate_l2p(sourceDot3.m_dot3Vector) * firstTransformData.m_transformWeight;
1869:
1870:			// apply remaining transforms
1871:			for (int j=sourceVectors->m_extraTransformDataCount;j>0;j--, transformData++)
1872:			{
1873:				// get transform data
1874:				VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformData->m_transformIndex, transformCount);
1875:
1876:				// apply it
1877:				const PoseModelTransform &transform = transformArray[transformData->m_transformIndex];
1878:
1879:				blendPosition += transform.rotateTranslate_l2p(sourcePosition) * transformData->m_transformWeight;
1880:				blendNormal   += transform.rotate_l2p(sourceNormal)            * transformData->m_transformWeight;
1881:				blendDot3     += transform.rotate_l2p(sourceDot3.m_dot3Vector) * transformData->m_transformWeight;
1882:			}
1883:
1884:			//-- Write out render geometry.
1885:			destVertexIt.setPosition(blendPosition);
1886:			destVertexIt.setNormal(blendNormal);
1887:			destVertexIt.setTextureCoordinates(m_dot3TextureCoordinateSetIndex, blendDot3.x, blendDot3.y, blendDot3.z, sourceDot3.m_flipState);
1888:
1889:#ifdef _DEBUG
1890:			if (GraphicsDebugFlags::renderVertexMatrices)
1891:			{
1892:				_renderVertexMatrices(blendPosition, blendNormal, blendDot3, sourceDot3.m_flipState);
1893:			}
1894:#endif
1895:
1896:			if (updateExtentsThisFrame && ((i & 1) != 0))
1897:			{
1898:				m_boxExtent.updateMinAndMax(blendPosition);
1899:			}
1900:		}
1901:	}
1902:	else
1903:	{
1904:		//-- Skin position and normal.
1905:		for (int i = 0; i < m_vertexCount; ++i, ++destVertexIt, sourceVectors++)
1906:		{
1907:			const Vector        &sourcePosition = sourceVectors->m_position;
1908:			const Vector        &sourceNormal   = sourceVectors->m_normal;
1909:
1910:			// CONSULT-30 PROBE+GUARD (DIAGNOSTIC -- remove after). The release build makes
1911:			// VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE a no-op, so an out-of-range m_transformIndex reads
1912:			// transformArray[] OOB -> garbage bone -> spike. Count any OOB index this vertex hits and
1913:			// clamp it (prevents the spike; a clamped vert mis-skins to the last bone, far better than
1914:			// reading random memory). Log offenders for big meshes via the file-static counters below.
1915:			int olBadCount = 0;
1916:
1917:			// initialize first position and vector
1918:			const TransformData &firstTransformData = sourceVectors->m_firstTransformData;
1919:			int fti = firstTransformData.m_transformIndex;
1920:			if (fti < 0 || fti >= transformCount) { ++olBadCount; fti = (transformCount > 0) ? transformCount - 1 : 0; }
1921:			const PoseModelTransform     &firstTransform = transformArray[fti];
1922:
1923:			Vector blendPosition = firstTransform.rotateTranslate_l2p(sourcePosition) * firstTransformData.m_transformWeight;
1924:			Vector blendNormal   = firstTransform.rotate_l2p(sourceNormal)            * firstTransformData.m_transformWeight;
1925:
1926:			// apply remaining transforms
1927:			for (int j=sourceVectors->m_extraTransformDataCount;j>0;j--, transformData++)
1928:			{
1929:				// get transform data
1930:				int xti = transformData->m_transformIndex;
1931:				if (xti < 0 || xti >= transformCount) { ++olBadCount; xti = (transformCount > 0) ? transformCount - 1 : 0; }
1932:
1933:				// apply it
1934:				const PoseModelTransform &transform = transformArray[xti];
1935:				blendPosition += transform.rotateTranslate_l2p(sourcePosition) * transformData->m_transformWeight;
1936:				blendNormal   += transform.rotate_l2p(sourceNormal)            * transformData->m_transformWeight;
1937:			}
1938:
1939:			// CONSULT-30 TAIL PROBE (DIAGNOSTIC). Indices are IN RANGE (clamp logged nothing) yet spikes
1940:			// persist -> the garbage is in the transform VALUE or the weight, not the index. Log tail
1941:			// verts of big meshes UNCONDITIONALLY: bone idx, weight, the bone's own translation
1942:			// (firstTransform applied to origin), and the resulting blendPosition. Garbage boneTrans =>
1943:			// stale/uninitialized pose at a valid index in transformArray; garbage firstW => weight bug.
1944:			if (m_vertexCount > 1000 && i >= m_vertexCount - 40)
1945:			{
1946:				static int s_skLogged = 0;
1947:				if (s_skLogged < 1500)
1948:				{
1949:					++s_skLogged;
1950:					Vector const ftTrans = firstTransform.rotateTranslate_l2p(Vector::zero);
1951:					static bool s_skFirst = true;
1952:					FILE *skFp = nullptr;
1953:					fopen_s(&skFp, "cape-skin-spike.txt", s_skFirst ? "wb" : "ab");
1954:					s_skFirst = false;
1955:					if (skFp)
1956:					{
1957:						fprintf(skFp,
1958:							"vtx=%d/%d firstIdx=%d wasOOB=%d extra=%d tc=%d firstW=%.3f boneTrans=[%.1f %.1f %.1f] blendPos=[%.1f %.1f %.1f]\n",
1959:							i, m_vertexCount, firstTransformData.m_transformIndex, olBadCount,
1960:							sourceVectors->m_extraTransformDataCount, transformCount, firstTransformData.m_transformWeight,
1961:							ftTrans.x, ftTrans.y, ftTrans.z, blendPosition.x, blendPosition.y, blendPosition.z);
1962:						fclose(skFp);
1963:					}
1964:				}
1965:			}

