1336:
1337:	/////////////////////////////////////////////////////////////////////////////////////////
1338:	//-- copy positions, weights and normals
1339:	TransformData *destTransformData = m_transformData;
1340:	for (vertexIndex = 0; vertexIndex < m_vertexCount; ++vertexIndex)
1341:	{
1342:		const MeshConstructionHelper::VertexData &vertexData = mesh.getVertexData(meshPerShaderData, vertexIndex);
1343:
1344:		SourceVertex &sourceVertex = m_sourceVectors[vertexIndex];
1345:
1346:		// grab position
1347:		sourceVertex.m_position = mesh.getPosition(vertexData);
1348:
1349:		// grab normal
1350:		sourceVertex.m_normal = mesh.getNormal(vertexData);
1351:
1352:		// grab # transforms affecting vertex
1353:		const int localVertexTransformCount = mesh.getVertexTransformCount(vertexData);
1354:		DEBUG_WARNING(localVertexTransformCount < 1, ("invalid local vertex transform count [%d], appearance=[%s], object=[%s]", 
1355:			localVertexTransformCount, 
1356:			m_appearance.getAppearanceTemplateName() ? m_appearance.getAppearanceTemplateName() : "<NULL appearance template name>",
1357:			(m_appearance.getOwner() && m_appearance.getOwner()->getObjectTemplateName()) ? m_appearance.getOwner()->getObjectTemplateName() : "<NULL object template name>"));
1358:
1359:		if (localVertexTransformCount<1)
1360:		{
1361:			sourceVertex.m_firstTransformData.m_transformIndex = 0;
1362:			sourceVertex.m_firstTransformData.m_transformWeight = 0;
