424:void Skeleton::Segment::findLocalTransformIndex(CrcString const &name, int &localTransformIndex, bool &foundIt) const
425:{
426:	foundIt = false;
427:
428:	//-- check if name is a joint
429:	m_skeletonTemplate.findJointIndex(name, &localTransformIndex, &foundIt);
430:
431:	if (!foundIt && m_hardpointNameToLocalIndexMap)
432:	{
433:		//-- check if it is one of our hardpoints
434:		const HardpointNameMap::const_iterator findIt = m_hardpointNameToLocalIndexMap->find(&name);
435:		if (findIt != m_hardpointNameToLocalIndexMap->end())
436:		{
437:			foundIt             = true;
438:			localTransformIndex = findIt->second;
439:		}
440:	}
441:}
