1270:		}
1271:		
1272:	}
1273:	// Construct the dynamic vertex buffer.
1274:	m_dynamicStream = new DynamicVertexBuffer(dynamicFormat);
1275:	/////////////////////////////////////////////////////////////////////////////////////////
1276:
1277:	/////////////////////////////////////////////////////////////////////////////////////////
1278:	// compute data block size
1279:	int alloc_size=0;
1280:
1281:	// account for source vectors (position, normal)
