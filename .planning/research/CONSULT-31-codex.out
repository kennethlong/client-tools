499:TransformAnimationResolver::TransformAnimationResolver(const SkeletalAppearanceTemplate &appearanceTemplate, SkeletalAppearance2 &appearance) :
500:	m_appearanceTemplate(appearanceTemplate),
501:	m_appearance(appearance),
502:	m_transformCount(0),
503:	m_skeletonTemplateDataVector(0),
504:	m_rotations(0),
505:	m_translations(0),
506:	m_transformEvaluatedFlags(0),
507:	m_mostRecentAlterElapsedTime(0.0f),
508:	m_mostRecentAnimationStatePath(),
509:	m_callbackInfoVector()
510:{
511:	//-- Initialize most recent animation state path to root (standing, non combat).
512:	m_mostRecentAnimationStatePath.clearPath();
513:	m_mostRecentAnimationStatePath.appendState(AnimationStateNameIdManager::getRootId());
514:
515:	//-- Keep local reference.
516:	IGNORE_RETURN(AppearanceTemplateList::fetch(&m_appearanceTemplate));
517:}
