708:/**
709: * Override the rotation and translation value for a given transform
710: * for this frame only.
711: *
712: * This function will override the the transform's rotation and translation
713: * for this frame.
714: *
715: * @param transformIndex  the 0-based index of the transform to modify.
716: * @param rotation        the rotational component for this transform this frame.
717: * @param translation     the translational component for this transform this frame.
718: */
719:
720:void TransformAnimationResolver::overrideTransformUntilNextAlter(int transformIndex, const Quaternion &rotation, const Vector &translation)
721:{
722:	VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, transformIndex, m_transformCount);
723:
724:	if (!m_rotations || !m_translations)
725:	{
726:		DEBUG_WARNING(true, ("Tried to override a transform on an appearance that doesn't have any animation controllers and (thus) doesn't have any transforms to override."));
727:		return;
728:	}
729:
730:	//-- Override the values.  The values will remain overridden until the next alter() call.
731:	(*m_rotations)[static_cast<QuaternionVector::size_type>(transformIndex)] = rotation;
732:	(*m_translations)[static_cast<VectorVector::size_type>(transformIndex)]  = translation;
733:
734:	//-- Set the evaluated flag to true.
735:	NOT_NULL(m_transformEvaluatedFlags);
780:		}
781:	}
782:}
