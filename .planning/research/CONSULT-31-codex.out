443:// ----------------------------------------------------------------------
444:
445:void Skeleton::Segment::findParentIndex(int childSegmentLocalIndex, const Segment *&parentSegment, int &parentSegmentLocalIndex, bool &foundParentIndex) const
446:{
447:	DEBUG_FATAL(childSegmentLocalIndex < 0, ("bad childSegmentLocalIndex %d", childSegmentLocalIndex));
448:
449:	foundParentIndex = false;
450:
451:	if (childSegmentLocalIndex < m_skeletonTemplate.getJointCount())
452:	{
453:		// this is a joint
454:		const int localParentIndex = m_skeletonTemplate.getJointParentIndexArray()[childSegmentLocalIndex];
455:		if (localParentIndex >= 0)
456:		{
457:			//-- this joint has a local parent (i.e. its not the root)
458:			foundParentIndex        = true;
459:			parentSegment           = this;
460:			parentSegmentLocalIndex = localParentIndex;
461:			return;
462:		}
463:		else
464:		{
465:			//-- this joint is the root of the local segment.  If the segment is attached, the parent
466:			//   will be a transform in the parent segment.
467:			if (m_parentSegment)
468:			{
469:				foundParentIndex        = true;
470:				parentSegment           = m_parentSegment;
471:				parentSegmentLocalIndex = m_parentLocalTransformIndex;
472:			}
473:			else
474:			{
475:				//-- no parent
476:				return;
477:			}
478:		}
479:	}
480:	else
481:	{
482:		// this is a hardpoint
483:		if (!m_hardpoints)
484:			return;
485:
486:		const int hardpointIndex = childSegmentLocalIndex - m_skeletonTemplate.getJointCount();
487:		VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, hardpointIndex, static_cast<int>(m_hardpoints->size()));
488:
489:		foundParentIndex        = true;
490:		parentSegment           = this;
491:		parentSegmentLocalIndex = (*m_hardpoints)[static_cast<size_t>(hardpointIndex)]->getParentLocalTransformIndex();
492:
493:		return;
494:	}
495:}
