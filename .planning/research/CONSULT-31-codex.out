1257:			for (int i = 0; i < tcSetCount; ++i)
1258:			{
1259:				const int dimensionality = mesh.getTextureCoordinateDimensionality(meshPerShaderData, i);
1260:				dynamicFormat.setTextureCoordinateSetDimension(i, dimensionality);
1261:			}
1262:		}
1263:	}
1264:	else
1265:	{
1266:		if (m_hasDot3Vector)
1267:		{
1268:			dynamicFormat.setNumberOfTextureCoordinateSets(1);
