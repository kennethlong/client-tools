536:					"row2=[%.3f %.3f %.3f %.3f] vertCount=%d\n",
537:					s_iter36dCount, s_iter36dCallNum,
538:					static_cast<float>(pos.x), static_cast<float>(pos.y),
539:					static_cast<float>(pos.z),
540:					static_cast<float>(transform_apw.getMatrix()[0][0]),
541:					static_cast<float>(transform_apw.getMatrix()[0][1]),
542:					static_cast<float>(transform_apw.getMatrix()[0][2]),
543:					static_cast<float>(transform_apw.getMatrix()[0][3]),
544:					static_cast<float>(transform_apw.getMatrix()[1][0]),
545:					static_cast<float>(transform_apw.getMatrix()[1][1]),
546:					static_cast<float>(transform_apw.getMatrix()[1][2]),
547:					static_cast<float>(transform_apw.getMatrix()[1][3]),
548:					static_cast<float>(transform_apw.getMatrix()[2][0]),
549:					static_cast<float>(transform_apw.getMatrix()[2][1]),
550:					static_cast<float>(transform_apw.getMatrix()[2][2]),
