923:SystemVertexBuffer const *SoftwareBlendSkeletalShaderPrimitive::getSkinnedVertexBuffer() const
924:{
925:	//-- Can't return anything if multi-streaming: no cached system VB data.
926:	if (ms_useMultiStreamVertexBuffers)
927:		return 0;
928:
929:	//-- Do proper skinning, which may be to do no skinning.
930:	const Skeleton &skeleton = m_appearance.getSkeleton(m_lodIndex);
931:
932:	NOT_NULL(m_systemStream);
933:	VertexBufferWriteIterator  writeIterator = m_systemStream->beginWriteOnly();
934:	skinData(skeleton.getTransformCount(), skeleton.getBindPoseModelToRootTransforms(), writeIterator);
935:
936:	return m_systemStream;
937:}
