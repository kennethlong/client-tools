378:Skeleton::Segment::Segment(const BasicSkeletonTemplate &skeletonTemplate, Segment *parentSegment, int parentLocalTransformIndex)
379::	m_skeletonTemplate(skeletonTemplate),
380:	m_parentSegment(parentSegment),
381:	m_parentLocalTransformIndex(parentLocalTransformIndex),
382:	m_firstTransformIndex(-1),
383:	m_lastTransformIndex(-1),
384:	m_parentTransformIndex(-1),
385:	m_bindPoseModelToJointTransforms(0),
386:	m_modelToJointInfo(0),
387:	m_hardpoints(0),
388:	m_hardpointNameToLocalIndexMap(0),
389:	m_transformResolverJointIndexMap(skeletonTemplate.getJointCount(), -1)
390:{
391:	DEBUG_FATAL(!parentSegment && (parentLocalTransformIndex >= 0), ("looks like parent transform index set [%d] with NULL parent segment", parentLocalTransformIndex));
392:
393:	//-- Fetch local reference.
394:	skeletonTemplate.fetch();
395:}
