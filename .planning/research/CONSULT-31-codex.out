1498:void Skeleton::calculateBindPoseModelToRootTransforms() const
1499:{
1500:	// -TRF- NOTE: we do not support bind pose model to root calculation for
1501:	//             hardpoints yet (these potentially require per-skeleton
1502:	//             bindPoseModelToJoint transforms).
1503:
1504:	NOT_NULL(m_skeletonSegments);
1505:	NOT_NULL(m_bindPoseModelToRootTransforms);
1506:	NOT_NULL(m_jointToRootTransforms);
1507:
1508:	NP_PROFILER_AUTO_BLOCK_DEFINE("Skeleton::calculateBindPoseModelToRootTransforms");
1509:
1510:	const int frameNumber = Os::getNumberOfUpdates();
1511:	if (m_frameLastBindPoseModelToRootCalculate == frameNumber)
1512:	{
1513:		// we've already calculated this
1514:		return;
1515:	}
1516:
1517:#if PRODUCTION == 0
1518:	++s_calculateBindPoseModelToRootTransformsEvalCount;
1519:#endif
1520:
1521:	//-- make sure JointToRootTransforms are calculated already
1522:	calculateJointToRootTransforms();
1523:
1524:	//-- sweep through the skeleton segments
1525:	const size_t segmentCount = m_skeletonSegments->size();
1526:	for (size_t segmentIndex = 0; segmentIndex < segmentCount; ++segmentIndex)
1527:	{
1528:		const Segment *const    segment                = NON_NULL((*m_skeletonSegments)[segmentIndex]);
1529:		const int               jointCount             = segment->getSkeletonTemplate().getJointCount();
1530:		const TransformVector  &modelToJointTransforms = segment->getBindPoseModelToJointTransforms();
1531:
1532:		for (int localJointIndex = 0; localJointIndex < jointCount; ++localJointIndex)
1533:		{
1534:			//-- build the bindPoseModel -> Animated Joint
1535:			const size_t        modelTransformIndex             = static_cast<size_t>(segment->getFirstTransformIndex() + localJointIndex);
1536:			PoseModelTransform &destTransform                   = m_bindPoseModelToRootTransforms[modelTransformIndex];
1537:			const Transform    &bindPoseModelToJointTransform   = modelToJointTransforms[static_cast<size_t>(localJointIndex)];
1538:			const Transform    &jointToRootTransform            = m_jointToRootTransforms[modelTransformIndex];
1539:
1540:			Transform tempXF(Transform::IF_none);
1541:			tempXF.multiply(jointToRootTransform, bindPoseModelToJointTransform);
1542:			destTransform=tempXF;
1543:		}
1544:	}
1545:
1546:	//-- sweep through the hardpoints
1547:	// -TRF- to do
1548:
1549:	//-- remember we calculated this already for this frame
1550:	m_frameLastBindPoseModelToRootCalculate = frameNumber;
1551:}
