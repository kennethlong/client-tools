575:
576:void Skeleton::Segment::calculateHardpointToRootTransforms(int firstSegmentTransformIndex, Transform *jointToRootTransforms) const
577:{
578:	if (m_hardpoints)
579:	{
580:		const size_t baseHardpointIndex = static_cast<size_t>(firstSegmentTransformIndex + m_skeletonTemplate.getJointCount());
581:
582:		size_t localHardpointIndex = 0;
583:
584:		const HardpointVector::const_iterator itEnd = m_hardpoints->end();
585:		for (HardpointVector::const_iterator it = m_hardpoints->begin(); it != itEnd; ++it, ++localHardpointIndex)
586:		{
587:			NOT_NULL(*it);
588:			const Hardpoint &hardpoint = *(*it);
589:
590:			const Transform &parentToRoot = jointToRootTransforms[firstSegmentTransformIndex + hardpoint.getParentLocalTransformIndex()];
591:			Transform &destTransform      = jointToRootTransforms[baseHardpointIndex + localHardpointIndex];
592:
593:			destTransform.multiply(parentToRoot, hardpoint.getLocalToParent());
594:		}
595:	}
596:}
