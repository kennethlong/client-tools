498:
499:CrcString const &Skeleton::Segment::getTransformName(int localTransformIndex) const
500:{
501:	const int jointCount = m_skeletonTemplate.getJointCount();
502:
503:	//-- handle joints
504:	if (localTransformIndex < jointCount)
505:	{
506:		// transform is a joint
507:		return m_skeletonTemplate.getJointName(localTransformIndex);
508:	}
509:
510:	// must be a hardpoint
511:	NOT_NULL(m_hardpoints);
512:
513:	// transform is a hardpoint
514:	const int hardpointIndex = localTransformIndex - jointCount;
515:	VALIDATE_RANGE_INCLUSIVE_EXCLUSIVE(0, hardpointIndex, static_cast<int>(m_hardpoints->size()));
516:
517:	const Hardpoint *const hardpoint = (*m_hardpoints)[static_cast<size_t>(hardpointIndex)];
518:	return hardpoint->getName();
519:}
