1421:struct IndexedTriangle
1422:{
1423:	IndexedTriangle() {}
1424:
1425:	IndexedTriangle(int i_i0, int i_i1, int i_i2)
1426:	{
1427:		indeces[0]=i_i0;
1428:		indeces[1]=i_i1;
1429:		indeces[2]=i_i2;
1430:	}
1431:
1432:	bool operator<(const IndexedTriangle &o) const
1433:	{
1434:		if (indeces[0]<o.indeces[0])
1435:		{
1436:			return true;
1437:		}
1438:		else if (indeces[0]>o.indeces[0])
1439:		{
1440:			return false;
1441:		}
1442:		else if (indeces[1]<o.indeces[1])
1443:		{
1444:			return true;
1445:		}
1446:		else if (indeces[1]>o.indeces[1])
1447:		{
1448:			return false;
1449:		}
1450:		else
1451:		{
1452:			return indeces[2]<o.indeces[2];
1453:		}
1454:
1455:	}
1456:	int indeces[3];
1457:};
