1137:void Skeleton::rebuildLinkedSkeletonDefinition()
1138:{
1139:	NP_PROFILER_AUTO_BLOCK_DEFINE("Skeleton::rebuildLinkedSkeletonDefinition");
1140:
1141:	m_transformCount = std::accumulate(m_skeletonSegments->begin(), m_skeletonSegments->end(), 0, Segment::transformCountAccumulate);
1142:
1143:	//-- resize containers associated with transform count
1144:	allocateTransformArrays(m_transformCount);
1145:
1146:	//-- walk through each skeleton segment and build required data
1147:	// NOTE: this code assumes an earlier segment never attaches to a later segment.
1148:	//       that implies that attached skeleton segments should be added after the
1149:	//       the skeleton segment to which they attach.
1150:
1151:	AttachmentChainVector attachmentChains;
1152:	attachmentChains.resize(m_skeletonSegments->size());
1153:
1154:	const size_t segmentCount = m_skeletonSegments->size();
1155:
1156:	int nextSegmentBaseTransformIndex = 0;
1157:	for (size_t segmentIndex = 0; segmentIndex < segmentCount; ++segmentIndex)
1158:	{
1159:		//-- get the skeleton segment
1160:		Segment &segment = *NON_NULL((*m_skeletonSegments)[segmentIndex]);
1161:
1162:		//-- find the parent transform index if this segment is attached to another.
1163:		//   also get the bind pose modelToJoint transforms for this skeleton segment hierarchy.
1164:		const BasicSkeletonTemplate::ModelToJointInfo *oldModelToJointInfo = segment.getModelToJointInfo();
1165:
1166:		if (segment.isAttached())
1167:		{
1168:			//-- calculate global transform index of parent
1169:			segment.setParentGlobalTransformIndex(segment.getParentSegment().getFirstTransformIndex() + segment.getParentLocalTransformIndex());
1170:
1171:			//-- setup attachment chain
1172:			// get index of parent segment
1173:			const SegmentVector::iterator findIt = std::find(m_skeletonSegments->begin(), m_skeletonSegments->end(), &segment.getParentSegment());
1174:			DEBUG_FATAL(findIt == m_skeletonSegments->end(), ("failed to find parent segment in segment list"));
1175:
1176:			const size_t parentSegmentIndex = static_cast<size_t>(std::distance(m_skeletonSegments->begin(), findIt));
1177:
1178:			// set attachment chain to that of parent
1179: 			AttachmentChain &attachmentChain = attachmentChains[segmentIndex];
1180:			attachmentChain = attachmentChains[parentSegmentIndex];
1181:
1182:			// add in the current attachment info
1183:			// -TRF- get the getTransformName() call out of this; possibly rework attachment chain to use local transform index
1184:			const char *const parentSkeletonTemplateName = segment.getParentSegment().getSkeletonTemplate().getName().getString();
1185:			attachmentChain.push_back(AttachmentChain::value_type(parentSkeletonTemplateName, getTransformName(segment.getParentGlobalTransformIndex()).getString()));
1186:
1187:			//-- fetch the modelToJoint transforms for this skeleton template configuration
1188:			const Transform &parentModelToJointTransform = segment.getParentSegment().getBindPoseModelToJointTransforms()[static_cast<size_t>(segment.getParentLocalTransformIndex())];
1189:
1190:			segment.setupBindPoseModelToJointTransforms(attachmentChains[segmentIndex], parentModelToJointTransform);
1191:		}
1192:		else
1193:		{
1194:			// segment is not attached to a parent skeleton
1195:			segment.setupBindPoseModelToJointTransforms(attachmentChains[segmentIndex], Transform::identity);
1196:		}
1197:
1198:		//-- release old model to joint transforms
1199:		if (oldModelToJointInfo)
1200:			segment.getSkeletonTemplate().releaseBindPoseModelToJointTransforms(oldModelToJointInfo);
1201:
1202:		//-- get number of transforms in skeleton template
1203:		const int segmentTransformCount = Segment::transformCountAccumulate(0, &segment);
1204:
1205:		//-- setup transform index range and adjust transform count
1206:		segment.setFirstTransformIndex(nextSegmentBaseTransformIndex);
1207:
1208:		nextSegmentBaseTransformIndex += segmentTransformCount;
1209:		segment.setLastTransformIndex(nextSegmentBaseTransformIndex - 1);
1210:
1211:		//-- Rebuild the segment's transform resolver joint index lookup
1212:		segment.buildTransformResolverJointIndexMap(m_animationResolver);
1213:	}
1214:}
