521:TransformAnimationResolver::~TransformAnimationResolver()
522:{
523:	delete [] m_transformEvaluatedFlags;
524:	delete m_translations;
525:	delete m_rotations;
526:
527:	if (m_skeletonTemplateDataVector)
528:	{
529:		std::for_each(m_skeletonTemplateDataVector->begin(), m_skeletonTemplateDataVector->end(), PointerDeleter());
530:		delete m_skeletonTemplateDataVector;
531:	}
532:
533:	//-- Release local reference.
534:	AppearanceTemplateList::release(&m_appearanceTemplate);
535:}
