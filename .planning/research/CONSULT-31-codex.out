399:Skeleton::Segment::~Segment()
400:{
401:	delete m_hardpointNameToLocalIndexMap;
402:
403:	if (m_hardpoints)
404:	{
405:		std::for_each(m_hardpoints->begin(), m_hardpoints->end(), PointerDeleter());
406:		delete m_hardpoints;
407:	}
408:
409:	m_bindPoseModelToJointTransforms = 0;
410:
411:	if (m_modelToJointInfo)
412:	{
413:		m_skeletonTemplate.releaseBindPoseModelToJointTransforms(m_modelToJointInfo);
414:		m_modelToJointInfo = 0;
415:	}
416:
417:	m_skeletonTemplate.release();
418:
419:	m_parentSegment = 0;
420:}
