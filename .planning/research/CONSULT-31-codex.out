723:					{
724:						fprintf(capeFp,
725:							"COLLAPSE this=%p lod=%d vc=%d longestRun=%d runStart=%d "
726:							"pos=[%.4f %.4f %.4f] firstXform=%d rotUnitXmag=%.5f xformCount=%d\n",
