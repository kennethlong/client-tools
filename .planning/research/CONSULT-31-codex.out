508:	{
509:		static int s_iter36dCount = 0;
510:		static int s_iter36dCallNum = 0;
511:		++s_iter36dCallNum;
512:		// Iter-36D2: first 100 (covers char-select preview burst) + every
513:		// 100th thereafter (sample of in-world SBSSP draws). The original
514:		// 100-cap filled with char-select-only entries; we need in-world
515:		// SBSSP transforms to confirm whether the bug is upstream (engine
516:		// not calling setTransform_w for the player) or in-world too.
517:		bool const early  = (s_iter36dCallNum <= 100);
518:		bool const sample = (s_iter36dCallNum > 100) && (s_iter36dCallNum % 100 == 0);
519:		if ((early || sample) && s_iter36dCount < 500)
520:		{
521:			++s_iter36dCount;
522:			static bool s_iter36dFirstWrite = true;
523:			char const * const mode = s_iter36dFirstWrite ? "wb" : "ab";
524:			s_iter36dFirstWrite = false;
525:			FILE *fp = nullptr;
526:			// Iter-37A: cwd at runtime is already stage/, so the previous
527:			// "stage/iter36d-..." path landed the artifact at stage/stage/.
528:			// Use a bare filename to keep it next to d3d11-debug.log.
529:			fopen_s(&fp, "iter36d-sbssp-transform.txt", mode);
530:			if (fp)
531:			{
532:				Vector const pos = transform_apw.getPosition_p();
533:				fprintf(fp,
534:					"sbssp#%d (call#%d) pos=[%.3f %.3f %.3f] "
