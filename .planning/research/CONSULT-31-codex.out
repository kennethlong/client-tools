1303:		const int localVertexTransformCount = mesh.getVertexTransformCount(vertexData);
1304:		if (localVertexTransformCount>1)
1305:		{
1306:			numberOfExtraTransformWeightPairs += localVertexTransformCount-1;
1307:		}
1308:	}
