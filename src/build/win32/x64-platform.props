<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================================
  x64-platform.props : committed x64 compile-settings single source of truth
  (Phase 33, X64-04/X64-01). Promoted from the Phase-31 scratch props
  (src/build/win32/x64-scratch/x64-compile.props, gitignored signal-generator).

  This is the COMMITTED x64 ClCompile parity block every boot-path .vcxproj
  imports for its Debug|x64 / Release|x64 ItemDefinitionGroups (wired by Plans
  04/05). This file does NOT import itself into any project, so it cannot
  regress the shipped 32-bit build.

  STRUCTURE (reviews fix #2, 4/4 HIGH : the Release-miscompile guard):
    THREE ItemDefinitionGroups, SPLIT by configuration. A single
    '$(Platform)'=='x64'-only group that hardcoded the debug defines would
    silently compile the Release config with debug semantics enabled, pulling in
    debug-only FATAL/memory-tracker paths in a shipped Release binary.
      (1) shared, config-INDEPENDENT '$(Platform)'=='x64': warnings, std, RTTI,
          EH, the N1 /we 4311/4312 guardrail, config-independent defines.
      (2) the Debug config ONLY carries the debug defines (DEBUG_LEVEL 2).
      (3) the Release config ONLY carries the release defines (DEBUG_LEVEL 0).

  DELIBERATE OMISSIONS (see the per-group ClCompile blocks below for the defines):
    * The 32-bit-time flag is NOT carried on x64. The UCRT corecrt.h hard-errors
      (#error C1189) on that flag under _WIN64; time_t is 8 bytes on x64. That is a
      BITS-03 serialization concern (handled in Phase 31), NOT a compile flag
      (A2-TIME-T).
    * 4244 / the size-narrowing count-path warning are NOT promoted to errors. The
      committed 32-bit tree never had /wd 4244, and the size-narrowing warning is
      the D-07-EXCLUDED noise class (N2 carry-forward). Only 4311/4312 (pointer
      truncation) are the re-established N1 guardrail.
    * The StaticLibrary define and ConfigurationType-specific defines
      (_USRDLL;DIRECT3D9_EXPORTS, etc.) are NOT baked in here. They are per-project
      ConfigurationType defines and stay in each importing .vcxproj's own block
      (Direct3d9.vcxproj:91 / :152, SwgClient.vcxproj:195).

  PARITY SOURCE (the committed Debug|Win32 / Release|Win32 ClCompile blocks):
    src/engine/shared/library/sharedMath/build/win32/sharedMath.vcxproj:69-177
  ============================================================================
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- (1) Shared x64 ClCompile (config-INDEPENDENT): warnings, std, RTTI, EH,
       the N1 guardrail, and the config-independent preprocessor defines. -->
  <ItemDefinitionGroup Condition="'$(Platform)'=='x64'">
    <ClCompile>
      <PreprocessorDefinitions>PLATFORM_WIN32;WIN32;_MBCS;_CRT_SECURE_NO_DEPRECATE=1;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeTypeInfo>true</RuntimeTypeInfo>
      <TreatWChar_tAsBuiltInType>true</TreatWChar_tAsBuiltInType>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <WarningLevel>Level4</WarningLevel>
      <TreatSpecificWarningsAsErrors>4311;4312</TreatSpecificWarningsAsErrors>
      <ExceptionHandling>Sync</ExceptionHandling>
    </ClCompile>
  </ItemDefinitionGroup>

  <!-- (2) Debug config ONLY: the debug define + DEBUG_LEVEL=2 -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <PreprocessorDefinitions>_DEBUG;DEBUG_LEVEL=2;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>

  <!-- (3) Release config ONLY: the release define + DEBUG_LEVEL=0 (no debug define) -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <PreprocessorDefinitions>NDEBUG;DEBUG_LEVEL=0;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>

</Project>
