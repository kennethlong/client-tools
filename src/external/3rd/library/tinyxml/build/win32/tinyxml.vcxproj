    </Lib>
    <PostBuildEvent>
      <Command>copy /Y "$(OutDir)tinyxmld_STL.lib" "$(OutDir)tinyxmld.lib"</Command>
      <Message>tinyxml x64: emit tinyxmld.lib alias for SwgClient AdditionalDependencies</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>
  <ItemGroup>
